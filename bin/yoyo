    loop = sub.add_parser("loop", help="Run a task as repeated fresh-context agent iterations with a shared state file")
    loop.add_argument(
        "agent",
        help="Agent name (codex, claude, pi, or a configured custom agent), or a comma-separated list rotated across iterations so each fresh context gets a different vendor's eyes",
    )
    loop.add_argument("prompt", nargs="*", help="The overall loop goal. Or use --input FILE.")
    loop.add_argument("--input", help="Read the loop task from a file instead of positional text")
    loop.add_argument(
        "--state",
        default=os.path.join(".yoyo", "loop-state.md"),
        help="State file carrying continuity between iterations (default: .yoyo/loop-state.md, relative to --cwd)",
    )
    loop.add_argument("--max-iter", type=int, default=20, help="Hard iteration cap (default: 20)")
    loop.add_argument("--interval", type=float, default=0.0, help="Seconds to sleep between iterations (default: 0)")
    loop.add_argument(
        "--budget-usd",
        type=float,
        default=None,
        help="Stop once cumulative reported cost reaches this; enforced only for agents that report cost (claude)",
    )
    loop.add_argument("--max-fail", type=int, default=3, help="Stop after N consecutive failed iterations (default: 3)")
    loop.add_argument("--role", choices=sorted(ROLE_PROMPTS), default="worker", help="Role prompt for each iteration (default: worker)")
    loop.add_argument("--caller", default=os.environ.get("YOYO_CALLER", "unknown"))
    loop.add_argument("--cwd", default=os.getcwd())
    loop.add_argument("--skill", action="append", default=[], help="Inject a named skill (SKILL.md) into every iteration; repeatable")
    loop.add_argument(
        "--timeout",
        type=float,
        default=float(os.environ.get("YOYO_TIMEOUT", str(DEFAULT_TIMEOUT_SECONDS))),
        help="Per-iteration timeout in seconds",
    )
    loop.add_argument(
        "--trace-id",
        default=os.environ.get("YOYO_TRACE_ID") or generate_run_id(),
        help="Loop id; stamped on every iteration's run-ledger record",
    )
    loop.add_argument("--max-input-bytes", type=int, default=int(os.environ.get("YOYO_MAX_INPUT_BYTES", str(DEFAULT_MAX_INPUT_BYTES))))
    loop.add_argument("--max-output-bytes", type=int, default=int(os.environ.get("YOYO_MAX_OUTPUT_BYTES", str(DEFAULT_MAX_OUTPUT_BYTES))))
    loop.add_argument("--idle-timeout", type=float, default=None, help="Kill an iteration if it emits no output for this many seconds (hang guard)")
    loop.add_argument("--quiet", action="store_true", help="Suppress the periodic progress heartbeat on stderr")
    loop.add_argument("--model", help="Pass a model name to agents that support --model")
    loop.add_argument(
        "--gate",
        action="append",
        default=[],
        metavar="CMD",
        help="Closed-form completion gate: a shell command (e.g. 'pytest -q'). STATUS: DONE is only accepted when every gate exits 0. Repeatable; CLI-only (never read from the state file).",
    )
    loop.add_argument(
        "--done-policy",
        choices=["worker", "gate", "checker", "gate+checker"],
        default=None,
        help="How STATUS: DONE is verified: worker (self-declared; the default when no verifier is given), gate (--gate commands pass), checker (--checker agent approves), or gate+checker. Auto-derived when --gate/--checker is passed.",
    )
    loop.add_argument(
        "--checker",
        help="Agent that independently verifies completion, blind to the worker's state-file prose (judges goal + git diff + repo, read-only). Implies a checker done-policy.",
    )
    loop.add_argument("--checker-model", help="Model for the --checker agent (recommend a cheaper tier than the worker, e.g. sonnet; not Haiku for completion judgment)")
    loop.add_argument(
        "--spec",
        help="Immutable standing-spec file re-read every iteration and never rewritten (fights goal drift); distinct from the mutable --state file",
    )
    loop.add_argument(
        "--queue",
        metavar="FILE",
        help="Markdown checklist ('- [ ] task' lines) used as the loop's work list: each iteration is instructed to do one unchecked item and check it off; STATUS: DONE is rejected while any item is unchecked (fails closed if the queue is unreadable or loses its checklist). Combine with --gate/--checker for independent verification.",
    )
    loop.add_argument(
        "--brief",
        metavar="FILE",
        help="Shared-context brief (repo map, conventions, commands, prior findings) injected read-only into every iteration so fresh contexts stop re-deriving it. Generate it with one agent call before the loop; workers never rewrite it.",
    )
    loop.add_argument(
        "--read-only",
        action="store_true",
        help="Constrain each iteration to read-only mode where supported (the agent then cannot update the state file)",
    )
    loop.add_argument("--agent-arg", action="append", help="Append a raw argument to the target agent command")
    loop.add_argument("--session", help=argparse.SUPPRESS)
    loop.add_argument("--json", action="store_true", help="Emit a final JSON loop summary (per-iteration lines go to stderr)")
    loop.add_argument("--dry-run", action="store_true", help="Print the composed iteration-1 command and prompt without running")
    loop.add_argument("--background", action="store_true", help="Detach the whole loop and record it in the run ledger")
    loop.set_defaults(func=cmd_loop, collect_unknown_prompt=True, file=[], use_stdin_context=False)

    review = sub.add_parser("review", help="Cross-agent consensus review of the current git diff")
    review.add_argument(
