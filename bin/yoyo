        default="codex,claude",
        help="Comma-separated reviewer agents run in parallel, each read-only (default: codex,claude)",
    )
    review.add_argument("--base", default=None, help="Base ref for the committed-changes diff when the tree is clean (default: auto-detect origin HEAD, then main, then master)")
    review.add_argument("--synthesizer", default=None, help="Agent that merges the reviews into a consensus report (default: first of --agents)")
    review.add_argument("--pr", action="store_true", help="Post the consolidated review as a GitHub PR comment via gh")
    review.add_argument("--caller", default=os.environ.get("YOYO_CALLER", "unknown"))
    review.add_argument("--cwd", default=os.getcwd())
    review.add_argument("--timeout", type=float, default=float(os.environ.get("YOYO_TIMEOUT", str(DEFAULT_TIMEOUT_SECONDS))), help="Per-agent timeout in seconds")
    review.add_argument("--trace-id", default=os.environ.get("YOYO_TRACE_ID") or uuid.uuid4().hex)
    review.add_argument("--max-input-bytes", type=int, default=int(os.environ.get("YOYO_MAX_INPUT_BYTES", str(DEFAULT_MAX_INPUT_BYTES))))
    review.add_argument("--max-output-bytes", type=int, default=int(os.environ.get("YOYO_MAX_OUTPUT_BYTES", str(DEFAULT_MAX_OUTPUT_BYTES))))
    review.add_argument("--model", help="Pass a model name to reviewer agents that support --model")
    review.add_argument("--quiet", action="store_true", help="Suppress the periodic progress heartbeat on stderr")
    review.add_argument("--json", action="store_true", help="Emit a JSON result envelope with per-agent reviews and the synthesis")
    review.add_argument("--dry-run", action="store_true", help="Print the reviewer commands and prompts without running them")
    review.set_defaults(func=cmd_review)

    research = sub.add_parser("research", help="Deep research: fan a topic out to agents under distinct lenses, then synthesize a decision brief")
    research.add_argument("prompt", nargs="*", help="The research topic or question")
    research.add_argument(
        "--agents",
        default="codex,claude,pi",
        help="Comma-separated agent pool; lenses are assigned to agents round-robin (default: codex,claude,pi)",
    )
    research.add_argument(
        "--lenses",
        default=None,
        help=(
            "Comma-separated research lenses, one parallel call each. Catalog: "
            + ", ".join(RESEARCH_LENSES)
            + ". Unknown names become ad-hoc angles (e.g. regulatory,market); repeating a lens is allowed "
            "(same angle, different agents = a best-of-n sample). Default: "
            + RESEARCH_DEFAULT_LENSES
        ),
    )
    research.add_argument(
        "--lens",
        action="append",
        default=[],
        help="A free-text lens written as full investigative instructions (commas and spaces allowed); repeatable and combinable with --lenses",
    )
    research.add_argument("--synthesizer", default=None, help="Agent that merges the perspectives into a decision brief (default: first of --agents)")
    research.add_argument(
        "--no-synthesis",
        action="store_true",
        help="Skip the synthesis call and print the raw per-lens perspectives (the caller synthesizes them itself)",
    )
    research.add_argument(
        "--synthesis-prompt",
        help="Custom synthesis instructions replacing the default decision-brief format (the topic and perspectives are appended)",
    )
    research.add_argument("--file", action="append", default=[], help="Add a file as shared context for every researcher; repeatable")
    research.add_argument("--read-only", action="store_true", help="Constrain researchers to read-only mode (limits web/tool access on some agents; default is full-access so investigation tools work)")
    research.add_argument("--caller", default=os.environ.get("YOYO_CALLER", "unknown"))
    research.add_argument("--cwd", default=os.getcwd())
    research.add_argument("--timeout", type=float, default=float(os.environ.get("YOYO_TIMEOUT", str(DEFAULT_TIMEOUT_SECONDS))), help="Per-agent timeout in seconds")
    research.add_argument("--trace-id", default=os.environ.get("YOYO_TRACE_ID") or uuid.uuid4().hex)
    research.add_argument("--max-input-bytes", type=int, default=int(os.environ.get("YOYO_MAX_INPUT_BYTES", str(DEFAULT_MAX_INPUT_BYTES))))
    research.add_argument("--max-output-bytes", type=int, default=int(os.environ.get("YOYO_MAX_OUTPUT_BYTES", str(DEFAULT_MAX_OUTPUT_BYTES))))
    research.add_argument("--model", help="Pass a model name to agents that support --model")
    research.add_argument("--quiet", action="store_true", help="Suppress the periodic progress heartbeat on stderr")
    research.add_argument("--json", action="store_true", help="Emit a JSON result envelope with per-lens perspectives and the synthesis")
    research.add_argument("--dry-run", action="store_true", help="Print the researcher commands and prompts without running them")
    research.set_defaults(func=cmd_research, collect_unknown_prompt=True)

    runs = sub.add_parser("runs", help="List, show, and prune background run records")
    runs.add_argument("runs_action", nargs="?", choices=["list", "show", "prune"], default="list")
    runs.add_argument("run_id", nargs="?")
    runs.add_argument("--json", action="store_true")
    runs.add_argument("--limit", type=int, default=20)
    runs.add_argument("--days", type=int, default=7)
    runs.add_argument("--dry-run", action="store_true")
    runs.set_defaults(func=cmd_runs)

    wait = sub.add_parser("wait", help="Wait for a background run to finish")
    wait.add_argument("run_id")
    wait.add_argument("--timeout", type=float, default=DEFAULT_TIMEOUT_SECONDS)
    wait.add_argument("--poll", type=float, default=2.0)
    wait.add_argument("--json", action="store_true")
    wait.set_defaults(func=wait_run)

    sessions = sub.add_parser("sessions", help="List and remove named backend session mappings")
    sessions.add_argument("sessions_action", nargs="?", choices=["list", "rm"], default="list")
    sessions.add_argument("sessions_target", nargs="?")
    sessions.add_argument("--json", action="store_true")
    sessions.add_argument("--all", action="store_true", help="Remove all recorded session mappings")
    sessions.set_defaults(func=cmd_sessions)

    cron = sub.add_parser("cron", help="Schedule yoyo commands via the user's crontab: add, list, rm, run")
    cron.add_argument("cron_action", nargs="?", choices=["add", "list", "rm", "run"], default="list")
    cron.add_argument("name", nargs="?", help="Entry name (required for add/rm/run)")
    cron.add_argument("--schedule", help="Cron schedule: five fields ('0 2 * * *') or a macro (@hourly, @daily, @weekly, ...)")
    cron.add_argument("--cwd", default=os.getcwd(), help="Working directory the scheduled command runs from")
    cron.add_argument("--log", help="Append the scheduled run's output to this file (default: state dir cron/<name>.log)")
    cron.add_argument("--force", action="store_true", help="Replace an existing entry with the same name")
    cron.add_argument("--json", action="store_true")
    cron.set_defaults(func=cmd_cron)

    agents = sub.add_parser("agents", help="List configured agents")
    agents.add_argument("--json", action="store_true")
    agents.set_defaults(func=list_agents)

    skills = sub.add_parser("skills", help="List skills discoverable for --skill injection")
    skills.add_argument("--json", action="store_true")
    skills.set_defaults(func=list_skills)

    diag = sub.add_parser("doctor", help="Check whether configured agent commands exist")
    diag.add_argument("--strict", action="store_true", help="Exit non-zero if any configured agent is missing")
    diag.add_argument("--live", action="store_true", help="Run live smoke probes through found agent commands")
    diag.add_argument("--agent", action="append", help="Probe only the named agent; repeatable")
    diag.add_argument("--timeout", type=float, default=None, help="Per-probe timeout in seconds for --live (default 120)")
    diag.add_argument("--json", action="store_true", help="Emit a JSON live doctor report")
    diag.set_defaults(func=doctor)

    skill = sub.add_parser("install-skill", help="Install the bundled yoyo coordination skill")
    skill.set_defaults(func=install_skill)

    update = sub.add_parser("update", help="Update installed yoyo from the recorded source checkout")
    update.add_argument("--branch", help="Git branch to pull before reinstalling. Defaults to the current source branch.")
    update.add_argument("--no-pull", action="store_true", help="Reinstall from the recorded source checkout without pulling")
    update.add_argument("--prefix", help="Install prefix to pass through to install.sh")
    update.add_argument("--dry-run", action="store_true", help="Print update commands without running them")
    update.set_defaults(func=update_yoyo)
    return parser


def main(argv: list[str] | None = None) -> int:
    _install_signal_handlers()
    parser = build_parser()
    raw_argv = list(sys.argv[1:] if argv is None else argv)
    # `yoyo cron add <name> --schedule ... -- <yoyo command...>`: everything
    # after the first standalone `--` is the command to schedule, kept out of
    # argparse so its own flags are never parsed here.
    cron_command: list[str] = []
    if raw_argv[:1] == ["cron"] and "--" in raw_argv:
        split_at = raw_argv.index("--")
        cron_command = raw_argv[split_at + 1 :]
        raw_argv = raw_argv[:split_at]
    try:
        try:
            args, extras = parser.parse_known_args(raw_argv)
        except SystemExit as exc:
            return int(exc.code or 0) if isinstance(exc.code, int) else 2
        if extras:
            if getattr(args, "collect_unknown_prompt", False) and all(not item.startswith("-") for item in extras):
                args.prompt.extend(extras)
            else:
                raise YoyoError("unrecognized arguments: " + " ".join(extras))
        args._raw_argv = raw_argv
        args.cron_command = cron_command
        return int(args.func(args))
    except BrokenPipeError:
        return 141
    except YoyoError as exc:
        eprint(f"yoyo: {exc}")
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
