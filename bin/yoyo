VERSION = "0.16.0"
# A deadman guard against hung subprocesses, not a work budget: real agent
# tasks can legitimately run for hours, so the ceiling is high. Use
# --idle-timeout to catch stalls early on agents that stream output.
DEFAULT_TIMEOUT_SECONDS = 14400
DEFAULT_MAX_OUTPUT_BYTES = 2_000_000
DEFAULT_MAX_INPUT_BYTES = 2_000_000
DEFAULT_WORKFLOW_MAX_CONCURRENCY = 4
DEFAULT_WORKFLOW_MAX_JOBS = 1000
DEFAULT_WORKFLOW_CONTEXT_BYTES = 200_000
DEFAULT_HEARTBEAT_SECONDS = 20.0
DEFAULT_SKILL_MAX_BYTES = 100_000
DEFAULT_GATE_OUTPUT_BYTES = 65_536
DEFAULT_STATE_DIR = "~/.local/state/yoyo"
SESSION_NAME_RE = re.compile(r"^[A-Za-z0-9._-]+$")
CODEX_SESSION_ID_RE = re.compile(r"session id:\s*([0-9a-f-]{36})")


ROLE_PROMPTS = {
    "opinion": """You are being called as an independent second-opinion agent.

Do not edit files. Focus on disagreement, missing evidence, hidden failure modes, and the smallest next step that would change the conclusion.

Return concise sections:
- Verdict
- Reasons
- Risks
- Recommendation
""",
    "review": """You are being called as an independent code reviewer.

Do not edit files. Prioritize concrete bugs, security issues, behavioral regressions, missing tests, and overcomplication. Findings must include file/line references when the context allows it.

Return findings first, ordered by severity. If you find no issues, say that directly and name residual test gaps.
""",
    "worker": """You are being called as a delegated worker by another agent.

Stay inside the requested scope. Make the minimum change needed. You may edit files and run commands unless the prompt or yoyo mode says this is read-only. Report exactly what changed and how you verified it.

Return concise sections:
- Result
- Changed files
- Verification
- Open risks
""",
}


LOOP_PROTOCOL = """=== LOOP PROTOCOL (yoyo loop) ===
You are one iteration of a fresh-context loop. You have NO memory of prior
iterations; the state file is your only continuity.

State file: {state_path}
1. Read the state file FIRST. It records the goal, done work, and next step.
2. Do ONE meaningful increment of work this iteration. Keep this session small.
3. Before ending, REWRITE the state file: goal, what is done (terse list),
   exactly what the next iteration should do first, and any gotchas learned.
4. When the overall goal is fully complete and verified, write a line
   containing exactly "STATUS: DONE" in the state file.
=== END LOOP PROTOCOL ===

TASK:
{task}"""


# Kept out of the protocol header on purpose: the counter changes every
# iteration, and anything before it can never be a stable, cacheable prompt
# prefix across iterations. It rides at the end of the iteration prompt.
LOOP_POSITION = "Loop position: iteration {iteration} of at most {max_iter}."


LOOP_STATE_SEED = """# yoyo loop state

GOAL:
{task}

DONE:
(nothing yet)

NEXT:
Start from scratch.
"""


# Re-read every iteration, never rewritten — the standing spec that fights goal
# drift when the mutable state file's lossy summaries shed the original
# constraints. Prepended ahead of the loop protocol so it anchors each fresh
# context.
LOOP_SPEC_BLOCK = """=== STANDING SPEC (immutable; defines the goal and constraints; re-read every iteration; DO NOT edit) ===
{spec}
=== END STANDING SPEC ==="""


# Appended after the task when a --done-policy gates completion, so the worker
# knows its self-declared STATUS: DONE is a candidate that yoyo will verify.
LOOP_COMPLETION_CHECK = """=== COMPLETION CHECK ===
Your "STATUS: DONE" is a CANDIDATE, not the final word. When you write it, yoyo
verifies the goal with {verifiers}. If verification fails, yoyo removes your
STATUS: DONE line, appends the failure to the state file, and a fresh iteration
continues. Do not write STATUS: DONE until the work genuinely passes these
checks — declaring done early only wastes an iteration.
=== END COMPLETION CHECK ==="""


# Shared context a fresh iteration would otherwise re-derive (repo map,
# conventions, build/test commands, prior findings). Written by the caller —
# typically one agent call before the loop — re-read every iteration, and
# never rewritten by the worker. Injected in the stable prefix region: its
# content should not change during a loop, so it can prefix-cache.
LOOP_BRIEF_BLOCK = """=== BACKGROUND BRIEF (shared knowledge; re-read every iteration; DO NOT edit) ===
{brief}
=== END BACKGROUND BRIEF ===
The brief is context gathered before this loop started. Trust it as a starting
point, verify against the worktree when it matters, and do not spend the
iteration re-deriving what it already records."""


# The queue file is the loop's work list. The worker edits it (checking items
# off); yoyo only counts unchecked boxes when DONE is claimed — mechanical
# file inspection like a gate, never grading prose. Injected near the prompt
# tail because its content changes every iteration.
LOOP_QUEUE_BLOCK = """=== WORK QUEUE (file: {queue_path}) ===
{queue}
=== END WORK QUEUE ===
Queue rules: this iteration, pick exactly ONE unchecked item ("- [ ]") —
normally the first — and complete it. Then edit the queue file to mark that
item "- [x]". Never check off an item you did not complete this iteration.
STATUS: DONE is only accepted once every queue item is checked."""


# The independent checker is blind to the worker's state-file prose by design:
# it gets the immutable goal, the standing spec, and the diff, then re-derives
# whether the repository meets the goal. The only thing yoyo parses is the
# explicitly-demanded VERDICT marker — never the surrounding prose.
LOOP_CHECKER_PROMPT = """You are an INDEPENDENT completion checker. A different agent claims the task
below is finished. You did not write this code and must not assume it is
correct. Judge ONLY whether the repository at {cwd} actually satisfies the goal.
Read the repository as needed.

GOAL:
{task}
{spec_block}
What changed (git diff HEAD; may be empty if the work was already committed):
<diff>
{diff}
</diff>

List anything missing, broken, or unverified. Then end your reply with exactly
one line — either "VERDICT: PASS" if the goal is fully and correctly met, or
"VERDICT: FAIL" if anything is incomplete or unproven."""


@dataclass(frozen=True)
class AgentSpec:
    name: str
    command: list[str]
    flavor: str | None = None
    read_only_args: list[str] | None = None
    full_access_args: list[str] | None = None


# agy takes the prompt as the value of its -p flag rather than on stdin. The
# final prompt is not known where command_for_agent builds argv, so the flavor
# emits this sentinel as the -p value and execute_agent_call swaps it for the
# real prompt (and feeds empty stdin). NUL makes accidental collisions with real
# prompt text impossible.
AGY_PROMPT_SENTINEL = "\x00YOYO_AGY_PROMPT\x00"


DEFAULT_AGENTS: dict[str, AgentSpec] = {
    "codex": AgentSpec("codex", ["codex", "exec"], flavor="codex"),
    "claude": AgentSpec("claude", ["claude", "-p", "--no-session-persistence"], flavor="claude"),
    "pi": AgentSpec("pi", ["pi", "-p", "--no-session", "--mode", "text"], flavor="pi"),
    # On-demand agents: one-shot only (no --session), useful for cross-vendor
    # opinions. cursor-agent reads the prompt from piped stdin in print mode;
    # grok has no stdin sentinel, so the prompt arrives via --prompt-file
    # /dev/stdin; agy (Google Antigravity, the Gemini CLI successor) takes the
    # prompt as the value of -p — injected into argv via AGY_PROMPT_SENTINEL —
    # and has no headless read-only mode.
    "cursor": AgentSpec("cursor", ["cursor-agent", "-p", "--output-format", "text"], flavor="cursor"),
    "agy": AgentSpec("agy", ["agy"], flavor="agy"),
    "grok": AgentSpec("grok", ["grok", "--prompt-file", "/dev/stdin", "--output-format", "plain"], flavor="grok"),
}


class YoyoError(Exception):
    pass


class AgentIdleTimeout(Exception):
    """Raised when a child agent produces no output for the idle window."""

    def __init__(self, idle_seconds: float, captured_bytes: int) -> None:
        super().__init__(f"No output for {idle_seconds}s")
        self.idle_seconds = idle_seconds
        self.captured_bytes = captured_bytes


def eprint(*parts: object, **kwargs: Any) -> None:
    print(*parts, file=sys.stderr, **kwargs)


# --- Child process lifecycle ------------------------------------------------
# Active child process groups, so a yoyo that is itself signalled or exits does
# not orphan the nested agents it launched (which keep burning tokens).
_ACTIVE_PGIDS: set[int] = set()
_ACTIVE_PGIDS_LOCK = threading.Lock()


def _register_child(pgid: int) -> None:
    with _ACTIVE_PGIDS_LOCK:
        _ACTIVE_PGIDS.add(pgid)


def _unregister_child(pgid: int) -> None:
    with _ACTIVE_PGIDS_LOCK:
        _ACTIVE_PGIDS.discard(pgid)


def _kill_active_children(sig: int) -> None:
    if os.name != "posix":
        return
    with _ACTIVE_PGIDS_LOCK:
        pgids = list(_ACTIVE_PGIDS)
    for pgid in pgids:
        try:
            os.killpg(pgid, sig)
        except OSError:
            pass


_SIGNAL_HANDLERS_INSTALLED = False


def _install_signal_handlers() -> None:
    global _SIGNAL_HANDLERS_INSTALLED
    if _SIGNAL_HANDLERS_INSTALLED or os.name != "posix":
        return
    if threading.current_thread() is not threading.main_thread():
        return

    def handler(signum: int, _frame: Any) -> None:
        _kill_active_children(signal.SIGKILL)
        signal.signal(signum, signal.SIG_DFL)
        os.kill(os.getpid(), signum)

    for sig in (signal.SIGINT, signal.SIGTERM, signal.SIGHUP):
        try:
            signal.signal(sig, handler)
        except (ValueError, OSError):
            pass
    atexit.register(_kill_active_children, signal.SIGKILL)
    _SIGNAL_HANDLERS_INSTALLED = True


def _terminate_child(proc: subprocess.Popen, pgid: int | None) -> None:
    if pgid is not None and os.name == "posix":
        try:
            os.killpg(pgid, signal.SIGKILL)
            return
        except OSError:
            pass
    try:
        proc.kill()
    except OSError:
        pass


def _safe_size(path: Path) -> int:
    try:
        return path.stat().st_size
    except OSError:
        return 0


def _stdin_isatty() -> bool:
    try:
        return sys.stdin.isatty()
    except (ValueError, OSError):
        return False


def _stdin_pending(grace: float) -> bool:
    """Whether stdin has data ready, without blocking on an idle open pipe.

    Returns True for in-memory streams that expose no real fd (e.g. test
    harnesses) and when readiness cannot be probed, so explicit input is never
    silently dropped; returns the actual readiness for real file descriptors so
    an open-but-idle pipe (the agent-to-agent case) never hangs the caller.
    """
    stream = sys.stdin
    try:
        fd = stream.fileno()
    except (OSError, ValueError, AttributeError):
        return True
    try:
        ready, _, _ = select.select([fd], [], [], max(0.0, grace))
    except (OSError, ValueError):
        return True
    return bool(ready)


def _stdin_wait_seconds(args: argparse.Namespace) -> float:
    cli = getattr(args, "stdin_wait", None)
    if cli is not None:
        return max(0.0, float(cli))
    raw = os.environ.get("YOYO_STDIN_WAIT")
    if raw is not None:
        try:
            return max(0.0, float(raw))
        except ValueError as exc:
            raise YoyoError("YOYO_STDIN_WAIT must be a number") from exc
    return 0.0


def resolve_heartbeat(args: argparse.Namespace) -> float | None:
    if getattr(args, "quiet", False):
        return None
    raw = os.environ.get("YOYO_HEARTBEAT_SECS")
    if raw is None:
        return DEFAULT_HEARTBEAT_SECONDS
    try:
        value = float(raw)
    except ValueError as exc:
        raise YoyoError("YOYO_HEARTBEAT_SECS must be a number") from exc
    return None if value <= 0 else value


def resolve_idle_timeout(args: argparse.Namespace) -> float | None:
    cli = getattr(args, "idle_timeout", None)
    if cli is not None:
        if cli <= 0:
            raise YoyoError("--idle-timeout must be greater than 0")
        return float(cli)
    raw = os.environ.get("YOYO_IDLE_TIMEOUT")
    if raw is None:
        return None
    try:
        value = float(raw)
    except ValueError as exc:
        raise YoyoError("YOYO_IDLE_TIMEOUT must be a number") from exc
    return None if value <= 0 else value


def config_path() -> Path:
    return Path(os.environ.get("YOYO_CONFIG", "~/.config/yoyo/agents.json")).expanduser()


def positive_env_int(name: str, default: int) -> int:
    raw = os.environ.get(name)
    if raw is None:
        return default
    try:
        value = int(raw)
    except ValueError as exc:
        raise YoyoError(f"{name} must be an integer") from exc
    if value < 1:
        raise YoyoError(f"{name} must be at least 1")
    return value


def source_record_path() -> Path:
    return Path(os.environ.get("YOYO_SOURCE_RECORD", "~/.config/yoyo/source")).expanduser()


def read_recorded_source() -> Path:
    override = os.environ.get("YOYO_SOURCE_ROOT")
    if override:
        source = Path(override).expanduser().resolve()
    else:
        path = source_record_path()
        if not path.exists():
            raise YoyoError(
                f"No recorded yoyo source checkout at {path}. Run ./install.sh from a cloned checkout or set YOYO_SOURCE_ROOT."
            )
        source = Path(path.read_text(encoding="utf-8").strip()).expanduser().resolve()
    if not source.exists():
        raise YoyoError(f"Recorded yoyo source checkout does not exist: {source}")
    if not (source / "install.sh").is_file():
        raise YoyoError(f"Recorded yoyo source checkout has no install.sh: {source}")
    return source


def resolve_cwd(raw: str) -> Path:
    cwd = Path(raw).expanduser().resolve()
    if not cwd.exists():
        raise YoyoError(f"Working directory does not exist: {cwd}")
    if not cwd.is_dir():
        raise YoyoError(f"Working directory is not a directory: {cwd}")
    return cwd


def display_path(path: Path, base: Path) -> str:
    try:
        return os.path.relpath(path, base)
    except ValueError:
        return path.name


def read_limited_text(path: Path, limit: int) -> tuple[str, bool]:
    with path.open("rb") as handle:
        data = handle.read(limit + 1)
    truncated = len(data) > limit
    if truncated:
        data = data[:limit]
    text = data.decode("utf-8", errors="replace")
    if truncated:
        text += f"\n...[truncated after {limit} bytes]\n"
    return text, truncated


def read_limited_stdin(limit: int) -> tuple[str, bool, int]:
    chunks: list[str] = []
    total = 0
    truncated = False
    while True:
        chunk = sys.stdin.read(min(65536, max(1, limit + 1 - total)))
        if not chunk:
            break
        chunks.append(chunk)
        total += len(chunk.encode("utf-8", errors="replace"))
        if total > limit:
            truncated = True
            break
    text = "".join(chunks)
    encoded = text.encode("utf-8", errors="replace")
    if len(encoded) > limit:
        text = encoded[:limit].decode("utf-8", errors="replace")
    if truncated:
        text += f"\n...[stdin truncated after {limit} bytes]\n"
    consumed = min(len(encoded), limit)
    return text, truncated, consumed


def _feed_stdin(proc: subprocess.Popen, prompt: str) -> None:
    """Write the prompt to the child off the main thread.

    Running this on its own thread keeps a large prompt (which can exceed the OS
    pipe buffer before the child starts reading) from blocking yoyo's own
    timeout/heartbeat loop.
    """
    try:
        if proc.stdin is not None:
            proc.stdin.write(prompt)
            proc.stdin.flush()
    except (BrokenPipeError, OSError, ValueError):
        pass
    finally:
        try:
            if proc.stdin is not None:
                proc.stdin.close()
        except (OSError, ValueError):
            pass


def run_to_files(
    cmd: list[str],
    prompt: str,
    cwd: Path,
    stdout_path: Path,
    stderr_path: Path,
    timeout: float,
    *,
    idle_timeout: float | None = None,
    heartbeat: float | None = None,
    label: str = "",
) -> subprocess.CompletedProcess[str]:
    with stdout_path.open("wb") as stdout_file, stderr_path.open("wb") as stderr_file:
        proc = subprocess.Popen(
            cmd,
            stdin=subprocess.PIPE,
            stdout=stdout_file,
            stderr=stderr_file,
            text=True,
            cwd=str(cwd),
            start_new_session=os.name == "posix",
        )
        pgid: int | None = None
        if os.name == "posix":
            try:
                pgid = os.getpgid(proc.pid)
            except OSError:
                pgid = None
        if pgid is not None:
            _register_child(pgid)

        feeder = threading.Thread(target=_feed_stdin, args=(proc, prompt), daemon=True)
        feeder.start()

        start = time.monotonic()
        last_size = 0
        last_activity = start
        last_heartbeat = start
        try:
            while True:
                now = time.monotonic()
                if timeout is not None and now - start >= timeout:
                    _terminate_child(proc, pgid)
                    proc.wait()
                    raise subprocess.TimeoutExpired(cmd, timeout)

                size = _safe_size(stdout_path) + _safe_size(stderr_path)
                if size != last_size:
                    last_size = size
                    last_activity = now
                if idle_timeout is not None and now - last_activity >= idle_timeout:
                    _terminate_child(proc, pgid)
                    proc.wait()
                    raise AgentIdleTimeout(round(now - last_activity, 1), size)
                if heartbeat is not None and now - last_heartbeat >= heartbeat:
                    last_heartbeat = now
                    tag = f"[{label}] " if label else ""
                    eprint(f"yoyo: {tag}still running, {int(now - start)}s elapsed, {size} bytes captured")

                deadlines = [0.5]
                if timeout is not None:
                    deadlines.append(timeout - (now - start))
                if idle_timeout is not None:
                    deadlines.append(idle_timeout - (now - last_activity))
                if heartbeat is not None:
                    deadlines.append(heartbeat - (now - last_heartbeat))
                wait_slice = max(0.02, min(deadlines))
                try:
                    proc.wait(timeout=wait_slice)
                    break
                except subprocess.TimeoutExpired:
                    continue
        finally:
            if pgid is not None:
                _unregister_child(pgid)
        feeder.join(timeout=1.0)
    return subprocess.CompletedProcess(cmd, proc.returncode)


def load_configured_agents() -> dict[str, AgentSpec]:
    path = config_path()
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except OSError as exc:
        raise YoyoError(f"Could not read {path}: {exc}") from exc
    except json.JSONDecodeError as exc:
        raise YoyoError(f"Invalid JSON in {path}: {exc}") from exc

    agents: dict[str, AgentSpec] = {}
    for name, raw in data.get("agents", {}).items():
        read_only_args: list[str] = []
        full_access_args: list[str] = []
        flavor: str | None = None
        if isinstance(raw, str):
            command = shlex.split(raw)
        elif isinstance(raw, dict) and isinstance(raw.get("command"), list):
            command = [str(part) for part in raw["command"]]
            read_only_args = [str(part) for part in raw.get("read_only_args", [])]
            full_access_args = [str(part) for part in raw.get("full_access_args", [])]
            flavor = raw.get("kind")
            if flavor is not None:
                flavor = str(flavor)
        else:
            raise YoyoError(f"Invalid agent config for {name!r}; use a string or {{\"command\": [...]}}")
        if not command:
            raise YoyoError(f"Agent {name!r} has an empty command")
        agents[name] = AgentSpec(name, command, flavor=flavor, read_only_args=read_only_args, full_access_args=full_access_args)
    return agents


def load_agents() -> dict[str, AgentSpec]:
    agents = dict(DEFAULT_AGENTS)
    agents.update(load_configured_agents())

    for key, value in os.environ.items():
        if key.startswith("YOYO_AGENT_") and value.strip():
            name = key.removeprefix("YOYO_AGENT_").lower().replace("_", "-")
            agents[name] = AgentSpec(name, shlex.split(value))
    return agents


def read_input_file(path: Path, limit: int) -> tuple[str, bool, int]:
    with path.open("rb") as handle:
        data = handle.read(limit + 1)
    truncated = len(data) > limit
    consumed = min(len(data), limit)
    if truncated:
        data = data[:limit]
    text = data.decode("utf-8", errors="replace")
    if truncated:
        text += f"\n...[file truncated after input budget limit]\n"
    return text, truncated, consumed


def read_file_context(paths: list[str], base: Path, limit: int) -> str:
    blocks: list[str] = []
    remaining = limit
    for item in paths:
        path = Path(item).expanduser()
        if not path.is_absolute():
            path = base / path
        if not path.exists():
            raise YoyoError(f"Context file not found: {path}")
        if not path.is_file():
            raise YoyoError(f"Context path is not a file: {path}")
        label = display_path(path, base)
        if remaining < 1:
            blocks.append(f"<file path=\"{label}\">\n...[input budget exhausted before this file]\n</file>")
            continue
        text, _, consumed = read_input_file(path, remaining)
        remaining -= consumed
        blocks.append(f"<file path=\"{label}\">\n{text}\n</file>")
    return "\n\n".join(blocks)


def skill_search_roots() -> list[Path]:
    roots: list[Path] = []
    raw = os.environ.get("YOYO_SKILL_PATH")
    if raw:
        roots.extend(Path(part).expanduser() for part in raw.split(os.pathsep) if part.strip())
    roots.extend(
        [
            Path("~/.claude/skills").expanduser(),
            Path("~/.codex/skills").expanduser(),
            Path("~/.agents/skills").expanduser(),
            Path("~/.config/opencode/skills").expanduser(),
            Path(os.environ.get("PI_CODING_AGENT_DIR", "~/.pi/agent")).expanduser() / "skills",
        ]
    )
    ordered: list[Path] = []
    seen: set[Path] = set()
    for root in roots:
        if root not in seen:
            seen.add(root)
            ordered.append(root)
    return ordered


def resolve_skill(name: str) -> Path:
    if not name:
        raise YoyoError("Invalid skill name: empty")
    if os.sep in name or "/" in name or name.startswith("."):
        # An explicit path: a markdown rules file (e.g. a ponytail-style
        # overlay) or a directory containing SKILL.md. Relative paths resolve
        # against the caller's working directory.
        path = Path(name).expanduser()
        if path.is_dir():
            candidate = path / "SKILL.md"
            if candidate.is_file():
                return candidate
            raise YoyoError(f"Skill directory has no SKILL.md: {path}")
        if path.is_file():
            return path
        raise YoyoError(f"Skill path not found: {name}")
    roots = skill_search_roots()
    for root in roots:
        candidate = root / name / "SKILL.md"
        if candidate.is_file():
            return candidate
    searched = ", ".join(str(root) for root in roots)
    raise YoyoError(f"Skill not found: {name!r}. Searched: {searched}")


def discover_skills() -> list[dict[str, str]]:
    rows: list[dict[str, str]] = []
    seen: set[str] = set()
    for root in skill_search_roots():
        if not root.is_dir():
            continue
        try:
            children = sorted(root.iterdir())
        except OSError:
            continue
        for child in children:
            if child.name in seen or not (child / "SKILL.md").is_file():
                continue
            seen.add(child.name)
            rows.append({"name": child.name, "path": str(child)})
    return rows


def skill_prompt_block(names: list[str]) -> str:
    limit = positive_env_int("YOYO_SKILL_MAX_BYTES", DEFAULT_SKILL_MAX_BYTES)
    blocks: list[str] = []
    for name in names:
        path = resolve_skill(name)
        if os.sep in name or "/" in name or name.startswith("."):
            # Path-based skill: label with a readable name, not the path.
            label = path.parent.name if path.name == "SKILL.md" else path.stem
        else:
            label = name
        text, _ = read_limited_text(path, limit)
        blocks.append(f"<skill name=\"{label}\">\n{text.rstrip()}\n</skill>")
    return (
        "Skill guidance: follow the practices in these skill documents while doing the task. "
        "They constrain how the work should be done, not what the task is.\n\n" + "\n\n".join(blocks)
    )


def default_skills_from_env() -> list[str]:
    """Skills injected into every non-raw call, from YOYO_DEFAULT_SKILLS (comma-separated).

    Unresolvable names are skipped with a stderr warning rather than failing the
    call: a broken default must not take down delegation itself.
    """
    raw = os.environ.get("YOYO_DEFAULT_SKILLS", "").strip()
    if not raw:
        return []
    names: list[str] = []
    for name in (part.strip() for part in raw.split(",")):
        if not name:
            continue
        try:
            resolve_skill(name)
        except YoyoError as exc:
            print(f"yoyo: warning: default skill {name!r} skipped: {exc}", file=sys.stderr)
            continue
        names.append(name)
    return names


def build_prompt(args: argparse.Namespace) -> str:
    cwd = resolve_cwd(args.cwd)
    want_stdin = (
        bool(getattr(args, "use_stdin_context", True))
        and not getattr(args, "no_stdin", False)
        and not _stdin_isatty()
    )
    stdin_context_used = False
    raw_mode = bool(getattr(args, "raw", False))
    prompt_parts: list[str] = []
    if raw_mode:
        # Verbatim pass-through, prompt first: a leading "/command" must reach
        # the target CLI as the first token or it is never expanded.
        if args.prompt:
            prompt_parts.append(" ".join(args.prompt).strip())
    else:
        if args.role:
            prompt_parts.append(ROLE_PROMPTS[args.role].strip())

    skills = list(getattr(args, "skill", None) or [])
    if not raw_mode:
        for name in default_skills_from_env():
            if name not in skills:
                skills.append(name)
    if skills:
        prompt_parts.append(skill_prompt_block(skills))

    if not raw_mode and args.prompt:
        prompt_parts.append("Task:\n" + " ".join(args.prompt).strip())

    remaining_input = args.max_input_bytes
    if want_stdin and _stdin_pending(_stdin_wait_seconds(args)):
        stdin_text, _, consumed = read_limited_stdin(remaining_input)
        remaining_input -= consumed
        if stdin_text.strip():
            stdin_context_used = True
            prompt_parts.append("<stdin>\n" + stdin_text.rstrip() + "\n</stdin>")

    if args.file:
        prompt_parts.append("Context files:\n" + read_file_context(args.file, cwd, remaining_input))

    if not args.read_only and (args.file or stdin_context_used) and not os.environ.get("YOYO_SUPPRESS_FULL_ACCESS_WARNING"):
        eprint("warning: full-access delegation includes stdin/--file context; use --read-only for untrusted input")

    if not raw_mode:
        # Last on purpose: the per-call-unique trace_id would otherwise poison
        # vendor prompt-cache prefix matching for everything after it.
        scope = "read-only delegation" if args.read_only else "full-access delegation"
        prompt_parts.append(f"Calling context: cwd={cwd}; mode={scope}; caller={args.caller}; trace_id={args.trace_id}.")

    prompt = "\n\n".join(part for part in prompt_parts if part.strip()).strip()
    if not prompt:
        raise YoyoError("No prompt provided. Pass text, pipe stdin, or use --file.")
    return prompt + "\n"


def command_for_agent(
    spec: AgentSpec,
    args: argparse.Namespace,
    codex_output_file: str | None = None,
    *,
    interactive: bool = False,
) -> list[str]:
    cmd = list(spec.command)
    cwd = str(resolve_cwd(args.cwd))
    session_info = getattr(args, "session_info", None)
    session_mode = session_info.get("mode") if isinstance(session_info, dict) else None
    session_backend_id = session_info.get("backend_id") if isinstance(session_info, dict) else None
    codex_exec_command = len(spec.command) >= 2 and spec.command[1] == "exec"

    # Each branch only builds the flavor-specific flags. The shared tail
    # (--model, raw --agent-arg passthrough, and the trailing prompt/stdin
    # sentinel) is applied once below so a new agent cannot silently drop it.
    if spec.flavor == "codex":
        codex_bin = spec.command[0]
        if interactive:
            cmd = [codex_bin, "resume", "-C", cwd] if session_info and session_mode == "resume" else [codex_bin, "-C", cwd]
            if args.read_only:
                cmd.extend(["--sandbox", "read-only"])
            else:
                cmd.extend(["--sandbox", "danger-full-access", "--ask-for-approval", "never"])
        else:
            cmd = [codex_bin] if codex_exec_command else list(spec.command)
            if session_info:
                cmd = [part for part in cmd if part != "--ephemeral"]
            if not args.read_only:
                cmd.extend(["--ask-for-approval", "never"])
            cmd.append("exec")
            if session_info and session_mode == "resume":
                # `codex exec resume` rejects --color/-C/--sandbox; the process
                # cwd is already set by yoyo and the sandbox goes through -c.
                sandbox_mode = "read-only" if args.read_only else "danger-full-access"
                cmd.extend(["resume", str(session_backend_id), "--skip-git-repo-check"])
                cmd.extend(["-c", f'sandbox_mode="{sandbox_mode}"'])
            else:
                if codex_exec_command and len(spec.command) > 2:
                    cmd.extend(part for part in spec.command[2:] if part != "--ephemeral")
                cmd.extend(["--skip-git-repo-check"])
                if not session_info:
                    cmd.append("--ephemeral")
                cmd.extend(["--color", "never", "-C", cwd])
                if args.read_only:
                    cmd.extend(["--sandbox", "read-only"])
                else:
                    cmd.extend(["--sandbox", "danger-full-access"])
        if codex_output_file:
            cmd.extend(["--output-last-message", codex_output_file])
    elif spec.flavor == "claude":
        if session_info:
            cmd = [part for part in cmd if part != "--no-session-persistence"]
        if interactive:
            cmd = [spec.command[0]]
        if session_info:
            if session_mode == "resume":
                cmd.extend(["--resume", str(session_backend_id)])
            else:
                cmd.extend(["--session-id", str(session_backend_id)])
        if args.read_only:
            cmd.extend(["--tools", "Read,Grep,Glob,LS"])
        else:
            cmd.extend(["--permission-mode", "bypassPermissions"])
    elif spec.flavor == "pi":
        if session_info:
            cmd = [part for part in cmd if part != "--no-session"]
        if interactive:
            cmd = [spec.command[0]]
        if session_info:
            cmd.extend(["--session-id", str(session_backend_id)])
        if args.read_only:
            cmd.extend(["--tools", "read,grep,find,ls"])
        else:
            cmd.extend(["--tools", "read,grep,find,ls,bash,edit,write"])
    elif spec.flavor == "cursor":
        if interactive:
            cmd = [spec.command[0]]
        else:
            # --trust only applies to --print/headless mode.
            cmd.append("--trust")
        if args.read_only:
            cmd.extend(["--mode", "plan"])
        else:
            cmd.append("--force")
    elif spec.flavor == "agy":
        if args.read_only:
            raise YoyoError(
                "agy has no headless read-only mode (its --sandbox only restricts the terminal, "
                "not file writes), so --read-only cannot be enforced; use codex, claude, or pi "
                "for read-only review or as a loop --checker"
            )
        if interactive:
            if args.prompt:
                raise YoyoError("agy chat takes no inline prompt; run `yoyo chat agy` and type in the session")
            cmd = [spec.command[0], "--dangerously-skip-permissions"]
        else:
            # agy reads the prompt as the value of -p (not stdin); execute_agent_call
            # swaps the sentinel for the real prompt and feeds empty stdin instead.
            cmd = [spec.command[0], "-p", AGY_PROMPT_SENTINEL, "--add-dir", cwd, "--dangerously-skip-permissions"]
    elif spec.flavor == "grok":
        if interactive:
            if args.prompt:
                raise YoyoError("grok rejects a positional prompt; run yoyo chat grok without one")
            cmd = [spec.command[0]]
        if args.read_only:
            cmd.extend(["--permission-mode", "plan"])
        else:
            cmd.extend(["--permission-mode", "bypassPermissions"])
    else:
        if args.read_only and not spec.read_only_args:
            raise YoyoError(f"Agent {spec.name!r} has no configured read_only_args, so --read-only cannot be enforced")
        if args.read_only:
            cmd.extend(spec.read_only_args or [])
        else:
            cmd.extend(spec.full_access_args or [])

    if spec.flavor in ("codex", "claude", "pi", "cursor", "agy", "grok") and args.model:
        cmd.extend(["--model", args.model])
    cmd.extend(args.agent_arg or [])
    if interactive:
        if spec.flavor == "codex" and session_info and session_mode == "resume":
            cmd.append(str(session_backend_id))
        if args.prompt:
            cmd.append(" ".join(args.prompt).strip())
    elif spec.flavor == "codex":
        cmd.append("-")
    return cmd


def validate_ask_args(args: argparse.Namespace) -> dict[str, AgentSpec]:
    if getattr(args, "raw", False):
        if args.role is not None:
            raise YoyoError("--raw sends the prompt verbatim; it cannot be combined with --role")
        if not args.prompt:
            raise YoyoError("--raw requires positional prompt text")
    elif getattr(args, "role", "absent") is None:
        args.role = "opinion"
    agents = load_agents()
    if args.agent not in agents:
        known = ", ".join(sorted(agents))
        raise YoyoError(f"Unknown agent {args.agent!r}. Known agents: {known}")
    if args.max_output_bytes < 1:
        raise YoyoError("--max-output-bytes must be at least 1")
    if args.max_input_bytes < 1:
        raise YoyoError("--max-input-bytes must be at least 1")
    if args.timeout <= 0:
        raise YoyoError("--timeout must be greater than 0")
    validate_session_request(args, agents[args.agent])
    cwd = resolve_cwd(args.cwd)
    for item in args.file:
        path = Path(item).expanduser()
        if not path.is_absolute():
            path = cwd / path
        if not path.exists():
            raise YoyoError(f"Context file not found: {path}")
        if not path.is_file():
            raise YoyoError(f"Context path is not a file: {path}")
    for skill_name in getattr(args, "skill", None) or []:
        resolve_skill(skill_name)
    command_for_agent(agents[args.agent], args)
    return agents


def ask_wants_stdin(args: argparse.Namespace) -> bool:
    return (
        bool(getattr(args, "use_stdin_context", True))
        and not getattr(args, "no_stdin", False)
        and not _stdin_isatty()
    )


def read_background_stdin(args: argparse.Namespace) -> bytes | None:
    if not ask_wants_stdin(args) or not _stdin_pending(_stdin_wait_seconds(args)):
        return None

    limit = args.max_input_bytes
    stream = sys.stdin
    chunks: list[bytes] = []
    total = 0
    while total < limit:
        size = min(65536, limit - total)
        try:
            if hasattr(stream, "buffer"):
                raw = stream.buffer.read(size)
            else:
                text = stream.read(size)
                raw = text.encode("utf-8", errors="replace")
        except (OSError, ValueError):
            break
        if not raw:
            break
        if len(raw) > size:
            raw = raw[:size]
        chunks.append(raw)
        total += len(raw)
    return b"".join(chunks)


def state_dir() -> Path:
    return Path(os.environ.get("YOYO_STATE_DIR", DEFAULT_STATE_DIR)).expanduser()


def sessions_path() -> Path:
    return state_dir() / "sessions.json"


def session_key(agent: str, name: str) -> str:
    return f"{agent}:{name}"


def validate_session_name(name: str) -> None:
    if not SESSION_NAME_RE.fullmatch(name):
        raise YoyoError(f"Invalid session name {name!r}; use [A-Za-z0-9._-]+")


def read_session_registry() -> dict[str, Any]:
    path = sessions_path()
    if not path.exists():
        return {"sessions": {}}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except OSError as exc:
        raise YoyoError(f"Could not read {path}: {exc}") from exc
    except json.JSONDecodeError as exc:
        raise YoyoError(f"Invalid JSON in {path}: {exc}") from exc
    if not isinstance(data, dict) or not isinstance(data.get("sessions"), dict):
        raise YoyoError(f"Invalid session registry in {path}; expected a sessions object")
    return data


def write_session_registry(registry: dict[str, Any]) -> None:
    # Simple read-modify-write is intentional: concurrent first calls for the
    # same agent/name can race, and the last writer wins.
    path = sessions_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(registry, ensure_ascii=False, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def validate_session_request(args: argparse.Namespace, spec: AgentSpec) -> None:
    name = getattr(args, "session", None)
    if not name:
        return
    validate_session_name(str(name))
    if spec.flavor not in ("codex", "claude", "pi"):
        raise YoyoError(f"agent {args.agent} does not support --session")


def prepare_session(args: argparse.Namespace, spec: AgentSpec, *, interactive: bool = False) -> None:
    args.session_info = None
    name = getattr(args, "session", None)
    if not name:
        return
    validate_session_request(args, spec)

    key = session_key(args.agent, str(name))
    now = iso_utc(utc_now())
    registry = read_session_registry()
    sessions = registry["sessions"]
    existing = sessions.get(key)
    if existing is not None:
        if not isinstance(existing, dict):
            raise YoyoError(f"Invalid session record for {key}")
        backend_id = existing.get("backend_id")
        if not backend_id:
            raise YoyoError(f"session {key} has no recorded backend_id")
        existing["last_used"] = now
        sessions[key] = existing
        write_session_registry(registry)
        args.session_info = {
            "key": key,
            "name": str(name),
            "backend_id": str(backend_id),
            "mode": "resume",
            "created_at": existing.get("created_at") or now,
        }
        return

    if spec.flavor == "codex":
        if interactive:
            raise YoyoError("codex chat --session requires an existing recorded session")
        args.session_info = {
            "key": key,
            "name": str(name),
            "backend_id": None,
            "mode": "create",
            "created_at": now,
        }
        return

    backend_id = str(uuid.uuid4())
    record = {
        "agent": args.agent,
        "name": str(name),
        "backend_id": backend_id,
        "created_at": now,
        "last_used": now,
    }
    sessions[key] = record
    write_session_registry(registry)
    args.session_info = {
        "key": key,
        "name": str(name),
        "backend_id": backend_id,
        "mode": "create",
        "created_at": now,
    }


def record_codex_session(args: argparse.Namespace, backend_id: str) -> None:
    session_info = getattr(args, "session_info", None)
    if not isinstance(session_info, dict):
        return
    name = str(session_info["name"])
    key = str(session_info["key"])
    created_at = str(session_info.get("created_at") or iso_utc(utc_now()))
    now = iso_utc(utc_now())
    registry = read_session_registry()
    registry["sessions"][key] = {
        "agent": args.agent,
        "name": name,
        "backend_id": backend_id,
        "created_at": created_at,
        "last_used": now,
    }
    write_session_registry(registry)
    session_info["backend_id"] = backend_id


def result_session(args: argparse.Namespace) -> dict[str, Any] | None:
    session_info = getattr(args, "session_info", None)
    if not isinstance(session_info, dict):
        return None
    return {
        "name": session_info.get("name"),
        "backend_id": session_info.get("backend_id"),
    }


def attach_session_result(args: argparse.Namespace, spec: AgentSpec, result: dict[str, Any]) -> None:
    session = result_session(args)
    if session is None:
        return
    session_info = getattr(args, "session_info", None) or {}
    if spec.flavor == "codex" and session_info.get("mode") == "create":
        match = CODEX_SESSION_ID_RE.search(str(result.get("stderr", "")))
        if match:
            record_codex_session(args, match.group(1))
            session = result_session(args)
        else:
            eprint("session not recorded for codex; follow-up calls will fail")
    result["session"] = session


def runs_root() -> Path:
    return state_dir() / "runs"


def utc_now() -> datetime:
    return datetime.now(timezone.utc)


def iso_utc(value: datetime) -> str:
    return value.astimezone(timezone.utc).isoformat().replace("+00:00", "Z")


def parse_iso_utc(raw: Any) -> datetime | None:
    if not isinstance(raw, str) or not raw:
        return None
    try:
        return datetime.fromisoformat(raw.replace("Z", "+00:00")).astimezone(timezone.utc)
    except ValueError:
        return None


def generate_run_id() -> str:
    return utc_now().strftime("%Y%m%dT%H%M%S") + "-" + uuid.uuid4().hex[:8]


def validate_run_id(run_id: str) -> None:
    if not run_id or run_id in (".", "..") or "/" in run_id or "\\" in run_id or os.sep in run_id:
        raise YoyoError(f"Invalid run_id: {run_id!r}")


def run_dir_for(run_id: str) -> Path:
    validate_run_id(run_id)
    path = runs_root() / run_id
    if not path.is_dir():
        raise YoyoError(f"Unknown run_id: {run_id}")
    return path


def load_json_file(path: Path) -> dict[str, Any] | None:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    return data if isinstance(data, dict) else None


def run_meta(run_dir: Path) -> dict[str, Any] | None:
    return load_json_file(run_dir / "meta.json")


def run_result(run_dir: Path) -> dict[str, Any] | None:
    return load_json_file(run_dir / "result.json")


def pid_is_running(pid: Any) -> bool:
    try:
        value = int(pid)
    except (TypeError, ValueError):
        return False
    if value <= 0:
        return False
    try:
        os.kill(value, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return False
    return True


def run_status(run_dir: Path) -> str:
    meta = run_meta(run_dir)
    if meta is None:
        return "unknown"
    if run_result(run_dir) is not None:
        return "done"
    return "running" if pid_is_running(meta.get("pid")) else "dead"


def run_started_at(meta: dict[str, Any] | None, run_dir: Path) -> datetime | None:
    parsed = parse_iso_utc((meta or {}).get("started_at"))
    if parsed is not None:
        return parsed
    try:
        return datetime.fromtimestamp(run_dir.stat().st_mtime, timezone.utc)
    except OSError:
        return None


def run_duration_seconds(status: str, meta: dict[str, Any] | None, result: dict[str, Any] | None, run_dir: Path) -> float | None:
    if status == "done" and result is not None:
        try:
            return float(result.get("duration_s"))
        except (TypeError, ValueError):
            return None
    started = run_started_at(meta, run_dir)
    if started is None:
        return None
    return max(0.0, (utc_now() - started).total_seconds())


def run_summary(run_dir: Path) -> dict[str, Any]:
    meta = run_meta(run_dir)
    result = run_result(run_dir)
    status = run_status(run_dir)
    started = run_started_at(meta, run_dir)
    duration = run_duration_seconds(status, meta, result, run_dir)
    return {
        "run_id": run_dir.name,
        "agent": (meta or {}).get("agent"),
        "status": status,
        "started_at": iso_utc(started) if started is not None else None,
        "duration": round(duration, 3) if duration is not None else None,
        "trace_id": (meta or {}).get("trace_id"),
        "exit_code": result.get("exit_code") if status == "done" and result is not None else None,
        "loop_id": (meta or {}).get("loop_id"),
        "iteration": (meta or {}).get("iteration"),
    }


def background_child_argv(args: argparse.Namespace) -> list[str]:
    raw = list(getattr(args, "_raw_argv", sys.argv[1:]))
    filtered: list[str] = []
    skip_next = False
    for item in raw:
        if skip_next:
            skip_next = False
            continue
        if item == "--background":
            continue
        # The child runs from the resolved run cwd, so a relative --cwd must be
        # rewritten to its absolute form or it would resolve a second time.
        if item == "--cwd":
            skip_next = True
            continue
        if item.startswith("--cwd="):
            continue
        filtered.append(item)
    filtered.extend(["--cwd", str(resolve_cwd(args.cwd))])
    if "--json" not in filtered:
        filtered.append("--json")
    has_trace = any(item == "--trace-id" or item.startswith("--trace-id=") for item in filtered)
    if not has_trace:
        filtered.extend(["--trace-id", args.trace_id])
    return [sys.executable, str(Path(__file__).resolve())] + filtered


def start_background_run(args: argparse.Namespace) -> int:
    stdin_bytes = read_background_stdin(args)
    if (
        not args.prompt
        and not args.file
        and not (getattr(args, "skill", None) or [])
        and not getattr(args, "input", None)
        and not (stdin_bytes and stdin_bytes.strip())
    ):
        raise YoyoError("No prompt provided. Pass text, pipe stdin, or use --file.")

    started = utc_now()
    root = runs_root()
    root.mkdir(parents=True, exist_ok=True)
    run_id = generate_run_id()
    run_dir = root / run_id
    run_dir.mkdir(mode=0o700)

    stdin_path: Path | None = None
    if stdin_bytes:
        stdin_path = run_dir / "stdin.txt"
        stdin_path.write_bytes(stdin_bytes)

    child_argv = background_child_argv(args)
    meta = {
        "run_id": run_id,
        "agent": args.agent,
        "role": args.role,
        "cwd": str(resolve_cwd(args.cwd)),
        "trace_id": args.trace_id,
        "caller": args.caller,
        "argv": child_argv,
        "pid": None,
        "started_at": iso_utc(started),
    }
    meta_path = run_dir / "meta.json"
    meta_path.write_text(json.dumps(meta, ensure_ascii=False, indent=2), encoding="utf-8")

    result_path = run_dir / "result.json"
    log_path = run_dir / "log.txt"
    stdin_file = stdin_path.open("rb") if stdin_path is not None else subprocess.DEVNULL
    try:
        with result_path.open("wb") as stdout_file, log_path.open("wb") as stderr_file:
            proc = subprocess.Popen(
                child_argv,
                stdin=stdin_file,
                stdout=stdout_file,
                stderr=stderr_file,
                cwd=str(resolve_cwd(args.cwd)),
                start_new_session=os.name == "posix",
            )
    except Exception:
        shutil.rmtree(run_dir, ignore_errors=True)
        raise
    finally:
        if stdin_path is not None and hasattr(stdin_file, "close"):
            stdin_file.close()

    meta["pid"] = proc.pid
    meta_path.write_text(json.dumps(meta, ensure_ascii=False, indent=2), encoding="utf-8")

    if args.json:
        print(json.dumps({"run_id": run_id, "run_dir": str(run_dir), "pid": proc.pid, "trace_id": args.trace_id}))
    else:
        print(run_id)
        eprint(f"run dir: {run_dir}")
    return 0


# Best-of-n: the same task fanned out to several agents in parallel, then an
# optional judge compares the independent answers. Diversity beats a single
# sample: different vendors fail differently, so genuine agreement is signal
# and disagreement marks exactly what to verify. The judge sees only the
# answers, not who is "usually right" — it must argue from content.
FANOUT_JUDGE_PROMPT = """You are judging {count} independent answers to the same task. Each was produced
by a different agent call that could not see the others. Compare them on
correctness, evidence, and completeness — never on confidence or length.

Task given to every agent:
<task>
{task}
</task>

{candidates}

Reply with:
1. VERDICT — which answer is best (name it), or say a merge beats any single one.
2. WHY — the decisive differences, citing the specific claims that mattered.
3. DISAGREEMENTS — where answers genuinely conflict, and how to settle each conflict.
4. BEST ANSWER — the full answer to act on: the winner as-is, or your merged version."""


def fanout_call_args(args: argparse.Namespace, agent_name: str, trace_suffix: str) -> argparse.Namespace:
    clone = argparse.Namespace(**vars(args))
    clone.agent = agent_name
    clone.trace_id = f"{args.trace_id}:{trace_suffix}"
    clone.session = None
    clone.session_info = None
    clone.background = False
    return clone


def fanout_judge_args(args: argparse.Namespace, judge_name: str, prompt_text: str) -> argparse.Namespace:
    clone = fanout_call_args(args, judge_name, "judge")
    clone.role = None
    clone.raw = False
    clone.prompt = [prompt_text]
    clone.file = []
    clone.skill = []
    clone.use_stdin_context = False
    # The judge prompt embeds the candidates' raw output — untrusted text. A
    # write-capable judge would be a prompt-injection target, so it always
    # runs read-only (agents without a read-only mode fail loudly up front).
    clone.read_only = True
    return clone


def spill_fanout_answers(trace_id: str, successful: list[dict[str, Any]]) -> Path:
    """Write raw candidate answers to files so a judged fan-out can return
    only the verdict. The answers stay retrievable by path instead of riding
    into the calling agent's context; each result gains a stdout_file field.
    """
    safe = re.sub(r"[^A-Za-z0-9._:-]", "-", trace_id).replace(":", "-")
    if not safe or set(safe) <= {".", "-"}:
        # "." / ".." / all-punctuation trace IDs must not escape the fanout dir.
        safe = "fanout"
    answers_dir = state_dir() / "fanout" / safe
    answers_dir.mkdir(parents=True, exist_ok=True)
    for index, result in enumerate(successful):
        path = answers_dir / f"{index + 1}-{result.get('agent', 'agent')}.md"
        path.write_text(str(result.get("stdout", "")), encoding="utf-8")
        result["stdout_file"] = str(path)
    return answers_dir


def run_fanout(args: argparse.Namespace, names: list[str]) -> int:
    if getattr(args, "session", None):
        raise YoyoError("--session needs a single agent; fan-out calls are one-shot")
    if getattr(args, "raw", False):
        if args.role is not None:
            raise YoyoError("--raw sends the prompt verbatim; it cannot be combined with --role")
        if not args.prompt:
            raise YoyoError("--raw requires positional prompt text")
    elif args.role is None:
        args.role = "opinion"
    if args.max_output_bytes < 1:
        raise YoyoError("--max-output-bytes must be at least 1")
    if args.max_input_bytes < 1:
        raise YoyoError("--max-input-bytes must be at least 1")
    if args.timeout <= 0:
        raise YoyoError("--timeout must be greater than 0")
    agents = load_agents()
    judge = getattr(args, "judge", None)
    unknown = sorted({name for name in [*names, *([judge] if judge else [])] if name not in agents})
    if unknown:
        known = ", ".join(sorted(agents))
        raise YoyoError(f"Unknown agent(s): {', '.join(unknown)}. Known agents: {known}")
    cwd = resolve_cwd(args.cwd)
    for item in args.file:
        path = Path(item).expanduser()
        if not path.is_absolute():
            path = cwd / path
        if not path.is_file():
            raise YoyoError(f"Context file not found: {path}")
    for skill_name in getattr(args, "skill", None) or []:
        resolve_skill(skill_name)
    # Fail loudly on flag problems (e.g. --read-only on an agent without a
    # read-only mode) before spending tokens on any call.
    for name in dict.fromkeys(names):
        command_for_agent(agents[name], fanout_call_args(args, name, "probe"))
    if judge:
        command_for_agent(agents[judge], fanout_judge_args(args, judge, "probe"))
    elif getattr(args, "judge_prompt", None):
        raise YoyoError("--judge-prompt has no effect without --judge; pass a judge agent too")
    elif getattr(args, "judge_only", False):
        raise YoyoError("--judge-only has no effect without --judge; pass a judge agent too")

    if getattr(args, "background", False) and not args.dry_run:
        return start_background_run(args)

    prompt = build_prompt(args)
    calls = [(index, name) for index, name in enumerate(names)]
    eprint(f"ask {args.trace_id}: fan-out agents={','.join(names)}" + (f" judge={judge}" if judge else ""))

    if args.dry_run:
        for index, name in calls:
            call_args = fanout_call_args(args, name, f"{name}.{index + 1}")
            emit_dry_run_result(execute_agent_call(name, call_args, prompt, agents), args.json)
        return 0

    with ThreadPoolExecutor(max_workers=len(calls)) as pool:
        futures = {}
        for index, name in calls:
            call_args = fanout_call_args(args, name, f"{name}.{index + 1}")
            futures[pool.submit(execute_agent_call, name, call_args, prompt, agents)] = index
        indexed: dict[int, dict[str, Any]] = {}
        for future in as_completed(futures):
            index = futures[future]
            name = names[index]
            try:
                result = future.result()
            except Exception as exc:
                result = {"agent": name, "exit_code": 2, "stdout": "", "stderr": str(exc), "stderr_plain": str(exc)}
            indexed[index] = result
            status = "ok" if int(result.get("exit_code", 1)) == 0 else f"exit {result.get('exit_code')}"
            eprint(f"ask {args.trace_id}: {name} {status}")
        results = [indexed[index] for index in range(len(calls))]

    successful = [r for r in results if int(r.get("exit_code", 1)) == 0 and str(r.get("stdout", "")).strip()]
    for result in results:
        if result not in successful:
            eprint(
                f"ask {args.trace_id}: {result.get('agent')} failed: "
                f"{str(result.get('stderr_plain') or result.get('stderr') or '')[:200]}"
            )
    if not successful:
        eprint(f"ask {args.trace_id}: all fan-out agents failed")
        return 1

    verdict: dict[str, Any] | None = None
    if judge and len(successful) >= 2:
        candidates = "\n\n".join(
            f'<answer agent="{r["agent"]}" call="{index + 1}">\n{str(r["stdout"]).strip()}\n</answer>'
            for index, r in enumerate(successful)
        )
        if args.judge_prompt:
            # Custom instructions are used verbatim (no .format, so braces are
            # safe); the task and candidate answers are appended after them.
            judge_text = (
                f"{args.judge_prompt.strip()}\n\nTask given to every agent:\n<task>\n{prompt.strip()}\n</task>\n\n{candidates}"
            )
        else:
            judge_text = FANOUT_JUDGE_PROMPT.format(count=len(successful), task=prompt.strip(), candidates=candidates)
        judge_args = fanout_judge_args(args, judge, judge_text)
        verdict = execute_agent_call(judge, judge_args, build_prompt(judge_args), agents)
        if int(verdict.get("exit_code", 1)) != 0 or not str(verdict.get("stdout", "")).strip():
            eprint(f"ask {args.trace_id}: judge via {judge} failed; printing the raw answers")
    elif judge:
        eprint(f"ask {args.trace_id}: only one answer succeeded; skipping the judge")

    judge_ok = verdict is not None and int(verdict.get("exit_code", 1)) == 0 and str(verdict.get("stdout", "")).strip()
    answers_dir: Path | None = None
    if getattr(args, "judge_only", False) and judge_ok:
        # Spill after the judge has read the raw answers; a failed or skipped
        # judge keeps the raw answers inline (the caller still needs them).
        answers_dir = spill_fanout_answers(args.trace_id, successful)
        for result in successful:
            result["stdout"] = ""

    if args.json:
        envelope: dict[str, Any] = {
            "trace_id": args.trace_id,
            "agents": names,
            "results": results,
            "judge": verdict,
            "exit_code": 0,
        }
        if answers_dir is not None:
            envelope["answers_dir"] = str(answers_dir)
        print(json.dumps(slim_result_for_emission(envelope), ensure_ascii=False))
    elif answers_dir is not None:
        blocks = [f"=== judge ({judge}) ===\n{str(verdict['stdout']).strip()}"]
        listing = "\n".join(f"{r['agent']}: {r['stdout_file']}" for r in successful)
        blocks.append(f"=== raw answers (spilled to files) ===\n{listing}")
        print("\n\n".join(blocks))
    else:
        blocks = [f"=== {r['agent']} ===\n{str(r['stdout']).strip()}" for r in successful]
        if judge_ok:
            blocks.append(f"=== judge ({judge}) ===\n{str(verdict['stdout']).strip()}")
        print("\n\n".join(blocks))
    return 0


def run_agent(args: argparse.Namespace) -> int:
    fanout_names = [name.strip() for name in args.agent.split(",") if name.strip()]
    if len(fanout_names) > 1:
        return run_fanout(args, fanout_names)
    if fanout_names:
        args.agent = fanout_names[0]  # tolerate a stray comma or whitespace
    if getattr(args, "judge", None) or getattr(args, "judge_prompt", None) or getattr(args, "judge_only", False):
        raise YoyoError("--judge/--judge-prompt/--judge-only need a fan-out: pass several agents, e.g. `yoyo ask codex,claude --judge grok`")
    agents = validate_ask_args(args)
    if getattr(args, "background", False) and not args.dry_run:
        return start_background_run(args)

    prompt = build_prompt(args)
    result = execute_agent_call(args.agent, args, prompt, agents)
    if args.dry_run:
        emit_dry_run_result(result, args.json)
        return 0
    emit_result(result, args.json)
    return int(result["exit_code"])


def _timeout_result(
    agent_name: str,
    cmd: list[str],
    args: argparse.Namespace,
    started: float,
    stdout_path: Path,
    stderr_path: Path,
    suffix: str,
) -> dict[str, Any]:
    elapsed = time.monotonic() - started
    stdout, stdout_truncated = read_limited_text(stdout_path, args.max_output_bytes)
    stderr, stderr_truncated = read_limited_text(stderr_path, args.max_output_bytes)
    if stderr:
        stderr += "\n"
    stderr += suffix
    return {
        "agent": agent_name,
        "command": cmd,
        "exit_code": 124,
        "duration_s": round(elapsed, 3),
        "trace_id": args.trace_id,
        "stdout": stdout,
        "stderr": stderr,
        "stderr_plain": stderr,
        "stdout_truncated": stdout_truncated,
        "stderr_truncated": stderr_truncated,
    }


def execute_agent_call(
    agent_name: str,
    args: argparse.Namespace,
    prompt: str,
    agents: dict[str, AgentSpec],
) -> dict[str, Any]:
    if agent_name not in agents:
        known = ", ".join(sorted(agents))
        raise YoyoError(f"Unknown agent {agent_name!r}. Known agents: {known}")
    cwd = resolve_cwd(args.cwd)
    prepare_session(args, agents[agent_name])
    codex_output_file: str | None = None
    with tempfile.TemporaryDirectory(prefix="yoyo-") as tmp:
        tmpdir = Path(tmp)
        if agents[agent_name].flavor == "codex" and not args.dry_run:
            codex_output_file = str(tmpdir / "codex-last-message.txt")

        cmd = command_for_agent(agents[agent_name], args, codex_output_file)
        feed = prompt
        if AGY_PROMPT_SENTINEL in cmd:
            # agy carries the prompt as the -p value, not on stdin.
            cmd = [prompt if part == AGY_PROMPT_SENTINEL else part for part in cmd]
            feed = ""
        if args.dry_run:
            result = {"agent": agent_name, "command": cmd, "prompt": prompt, "trace_id": args.trace_id, "exit_code": 0}
            session = result_session(args)
            if session is not None:
                result["session"] = session
            return result

        started = time.monotonic()
        stdout_path = tmpdir / "stdout.txt"
        stderr_path = tmpdir / "stderr.txt"
        heartbeat = resolve_heartbeat(args)
        idle_timeout = resolve_idle_timeout(args)
        label = f"{agent_name} {args.trace_id}".strip()
        try:
            proc = run_to_files(
                cmd,
                feed,
                cwd,
                stdout_path,
                stderr_path,
                args.timeout,
                idle_timeout=idle_timeout,
                heartbeat=heartbeat,
                label=label,
            )
        except FileNotFoundError as exc:
            raise YoyoError(f"Agent command not found for {args.agent}: {cmd[0]}") from exc
        except subprocess.TimeoutExpired:
            result = _timeout_result(
                agent_name, cmd, args, started, stdout_path, stderr_path,
                f"Timed out after {args.timeout}s",
            )
            attach_session_result(args, agents[agent_name], result)
            return result
        except AgentIdleTimeout as exc:
            result = _timeout_result(
                agent_name, cmd, args, started, stdout_path, stderr_path,
                f"Idle timeout after {exc.idle_seconds}s with no output "
                f"({exc.captured_bytes} bytes captured before the stall)",
            )
            attach_session_result(args, agents[agent_name], result)
            return result

        stdout, stdout_truncated = read_limited_text(stdout_path, args.max_output_bytes)
        stderr, stderr_truncated = read_limited_text(stderr_path, args.max_output_bytes)
        if codex_output_file:
            path = Path(codex_output_file)
            if path.exists():
                final_message, final_truncated = read_limited_text(path, args.max_output_bytes)
                if final_message.strip():
                    stdout = final_message
                    stdout_truncated = final_truncated
                    if proc.returncode == 0:
                        stderr_plain = ""
                    else:
                        stderr_plain = stderr
                else:
                    stderr_plain = stderr
            else:
                stderr_plain = stderr
        else:
            stderr_plain = stderr

        result = {
            "agent": agent_name,
            "command": cmd,
            "exit_code": proc.returncode,
            "duration_s": round(time.monotonic() - started, 3),
            "trace_id": args.trace_id,
            "stdout": stdout,
            "stderr": stderr,
            "stderr_plain": stderr_plain,
            "stdout_truncated": stdout_truncated,
            "stderr_truncated": stderr_truncated,
        }
        attach_session_result(args, agents[agent_name], result)
        return result


def emit_dry_run_result(result: dict[str, Any], as_json: bool) -> None:
    if as_json:
        print(json.dumps(result, indent=2))
        return
    print(shlex.join(result["command"]) + "\n\n" + result["prompt"])


def workflow_template_roots() -> list[Path]:
    roots: list[Path] = []
    raw = os.environ.get("YOYO_WORKFLOW_PATH")
    if raw:
        roots.extend(Path(part).expanduser() for part in raw.split(os.pathsep) if part.strip())
    roots.append(Path("~/.config/yoyo/workflows").expanduser())
    roots.append(Path(__file__).resolve().parents[1] / "workflows")
    ordered: list[Path] = []
    seen: set[Path] = set()
    for root in roots:
        if root not in seen:
            seen.add(root)
            ordered.append(root)
    return ordered


def discover_workflow_templates() -> list[dict[str, str]]:
    rows: list[dict[str, str]] = []
    seen: set[str] = set()
    for root in workflow_template_roots():
        if not root.is_dir():
            continue
        try:
            children = sorted(root.glob("*.json"))
        except OSError:
            continue
        for child in children:
            if child.stem in seen:
                continue
            seen.add(child.stem)
            rows.append({"name": child.stem, "path": str(child)})
    return rows


def resolve_workflow_spec_path(raw: str) -> Path:
    path = Path(raw).expanduser()
    if path.exists():
        if not path.is_file():
            raise YoyoError(f"Workflow spec is not a file: {path}")
        return path
    looks_like_name = os.sep not in raw and "/" not in raw and not raw.endswith(".json")
    if looks_like_name:
        for root in workflow_template_roots():
            candidate = root / f"{raw}.json"
            if candidate.is_file():
                return candidate
    searched = ", ".join(str(root) for root in workflow_template_roots())
    raise YoyoError(f"Workflow spec not found: {raw}. Pass a JSON path or a template name (searched: {searched})")


def load_workflow_spec(path: str) -> dict[str, Any]:
    workflow_path = resolve_workflow_spec_path(path)
    try:
        data = json.loads(workflow_path.read_text(encoding="utf-8"))
    except OSError as exc:
        raise YoyoError(f"Could not read workflow spec {workflow_path}: {exc}") from exc
    except json.JSONDecodeError as exc:
        raise YoyoError(f"Invalid workflow JSON in {workflow_path}: {exc}") from exc
    if not isinstance(data, dict):
        raise YoyoError("Workflow spec must be a JSON object")
    return data


def workflow_name(spec: dict[str, Any], spec_path: str) -> str:
    name = spec.get("name")
    if name is None:
        return Path(spec_path).stem
    if not isinstance(name, str) or not name.strip():
        raise YoyoError("Workflow field 'name' must be a non-empty string")
    return name.strip()


def workflow_phases(spec: dict[str, Any]) -> list[dict[str, Any]]:
    phases = spec.get("phases")
    if not isinstance(phases, list) or not phases:
        raise YoyoError("Workflow field 'phases' must be a non-empty array")
    normalized: list[dict[str, Any]] = []
    seen_names: set[str] = set()
    for index, raw_phase in enumerate(phases):
        if not isinstance(raw_phase, dict):
            raise YoyoError(f"Workflow phase {index} must be an object")
        name = raw_phase.get("name", f"phase-{index + 1}")
        if not isinstance(name, str) or not name.strip():
            raise YoyoError(f"Workflow phase {index} has an invalid name")
        if name in seen_names:
            raise YoyoError(f"Workflow phase name {name!r} is duplicated")
        seen_names.add(name)
        jobs = raw_phase.get("jobs")
        if not isinstance(jobs, list) or not jobs:
            raise YoyoError(f"Workflow phase {name!r} must have a non-empty jobs array")
        normalized.append(raw_phase)
    return normalized


def template_string(text: str, values: dict[str, Any]) -> str:
    rendered = text
    for key, value in values.items():
        if key == "item" and isinstance(value, dict):
            for item_key, item_value in value.items():
                rendered = rendered.replace("{" + f"item.{item_key}" + "}", str(item_value))
        rendered = rendered.replace("{" + key + "}", str(value))
    return rendered


def template_value(value: Any, values: dict[str, Any]) -> Any:
    if isinstance(value, str):
        return template_string(value, values)
    if isinstance(value, list):
        return [template_value(item, values) for item in value]
    if isinstance(value, dict):
        return {str(key): template_value(item, values) for key, item in value.items()}
    return value


def expand_workflow_jobs(phase: dict[str, Any], workflow_input: str) -> list[dict[str, Any]]:
    expanded: list[dict[str, Any]] = []
    for job_index, raw_job in enumerate(phase["jobs"]):
        if not isinstance(raw_job, dict):
            raise YoyoError(f"Job {job_index} in phase {phase.get('name')!r} must be an object")
        items = raw_job.get("for_each")
        if items is None:
            values = {"input": workflow_input, "index": job_index, "item": ""}
            expanded.append(template_value(raw_job, values))
            continue
        if not isinstance(items, list) or not items:
            raise YoyoError(f"Job {raw_job.get('id', job_index)!r} has invalid for_each; expected a non-empty array")
        for item_index, item in enumerate(items):
            job = {key: value for key, value in raw_job.items() if key != "for_each"}
            values = {"input": workflow_input, "index": item_index, "item": item}
            expanded.append(template_value(job, values))
    return expanded


def coerce_bool(value: Any, *, default: bool, field: str) -> bool:
    if value is None:
        return default
    if isinstance(value, bool):
        return value
    raise YoyoError(f"Workflow field {field!r} must be a boolean")


def coerce_int(value: Any, *, default: int, field: str, minimum: int = 1) -> int:
    if value is None:
        return default
    if isinstance(value, bool) or not isinstance(value, int):
        raise YoyoError(f"Workflow field {field!r} must be an integer")
    if value < minimum:
        raise YoyoError(f"Workflow field {field!r} must be at least {minimum}")
    return value


def coerce_float(value: Any, *, default: float, field: str) -> float:
    if value is None:
        return default
    if isinstance(value, bool) or not isinstance(value, (int, float)):
        raise YoyoError(f"Workflow field {field!r} must be a number")
    if value <= 0:
        raise YoyoError(f"Workflow field {field!r} must be greater than 0")
    return float(value)


def coerce_str_list(value: Any, *, field: str) -> list[str]:
    if value is None:
        return []
    if isinstance(value, str):
        return [value]
    if isinstance(value, list) and all(isinstance(item, str) for item in value):
        return list(value)
    raise YoyoError(f"Workflow field {field!r} must be a string or array of strings")


def workflow_defaults(spec: dict[str, Any]) -> dict[str, Any]:
    defaults = spec.get("defaults", {})
    if defaults is None:
        return {}
    if not isinstance(defaults, dict):
        raise YoyoError("Workflow field 'defaults' must be an object")
    return defaults


def inherited_workflow_value(spec: dict[str, Any], phase: dict[str, Any], job: dict[str, Any], field: str) -> Any:
    defaults = workflow_defaults(spec)
    return job.get(field, phase.get(field, defaults.get(field)))


def workflow_include_previous(spec: dict[str, Any], phase: dict[str, Any], job: dict[str, Any]) -> bool:
    return coerce_bool(inherited_workflow_value(spec, phase, job, "include_previous"), default=False, field="include_previous")


def workflow_include_phases(spec: dict[str, Any], phase: dict[str, Any], job: dict[str, Any]) -> list[str]:
    return coerce_str_list(inherited_workflow_value(spec, phase, job, "include_phases"), field="include_phases")


def workflow_context(
    spec: dict[str, Any],
    phase: dict[str, Any],
    results_by_phase: dict[str, list[dict[str, Any]]],
    job: dict[str, Any],
    limit: int,
) -> str:
    include_previous = workflow_include_previous(spec, phase, job)
    include_phases = workflow_include_phases(spec, phase, job)
    missing = [phase_name for phase_name in include_phases if phase_name not in results_by_phase]
    if missing:
        raise YoyoError(f"Workflow job {job.get('id')!r} requested unknown or future include_phases: {', '.join(missing)}")
    selected: list[tuple[str, dict[str, Any]]] = []
    for phase_name, results in results_by_phase.items():
        if include_previous or phase_name in include_phases:
            for result in results:
                selected.append((phase_name, result))
    if not selected:
        return ""

    blocks: list[str] = ["Previous workflow outputs:"]
    remaining = limit
    for phase_name, result in selected:
        body = result.get("stdout", "")
        if not body and result.get("stderr"):
            body = result["stderr"]
        text = str(body)
        encoded = text.encode("utf-8", errors="replace")
        truncated = False
        if len(encoded) > remaining:
            text = encoded[:remaining].decode("utf-8", errors="replace")
            text += f"\n...[workflow context budget exhausted after {limit} bytes]\n"
            truncated = True
        remaining -= min(len(encoded), remaining)
        blocks.append(
            f"<workflow-result phase=\"{phase_name}\" job=\"{result.get('job_id')}\" "
            f"agent=\"{result.get('agent')}\" exit_code=\"{result.get('exit_code')}\">\n"
            f"{text.rstrip()}\n</workflow-result>"
        )
        if truncated or remaining <= 0:
            break
    return "\n\n".join(blocks)


def build_workflow_agent_args(
    cli_args: argparse.Namespace,
    spec: dict[str, Any],
    phase: dict[str, Any],
    job: dict[str, Any],
    agent: str,
    trace_id: str,
) -> argparse.Namespace:
    defaults = workflow_defaults(spec)
    cwd = str(resolve_cwd(str(job.get("cwd") or phase.get("cwd") or defaults.get("cwd") or cli_args.cwd)))
    role = str(job.get("role") or phase.get("role") or defaults.get("role") or "opinion")
    if role not in ROLE_PROMPTS:
        raise YoyoError(f"Workflow job {job.get('id')!r} has invalid role {role!r}")
    read_only = coerce_bool(
        job.get("read_only", phase.get("read_only", defaults.get("read_only"))),
        default=True,
        field="read_only",
    )
    timeout = coerce_float(
        job.get("timeout", phase.get("timeout", defaults.get("timeout", cli_args.timeout))),
        default=cli_args.timeout,
        field="timeout",
    )
    max_input_bytes = coerce_int(
        job.get("max_input_bytes", phase.get("max_input_bytes", defaults.get("max_input_bytes", cli_args.max_input_bytes))),
        default=cli_args.max_input_bytes,
        field="max_input_bytes",
    )
    max_output_bytes = coerce_int(
        job.get("max_output_bytes", phase.get("max_output_bytes", defaults.get("max_output_bytes", cli_args.max_output_bytes))),
        default=cli_args.max_output_bytes,
        field="max_output_bytes",
    )
    model = job.get("model", phase.get("model", defaults.get("model")))
    if model is not None and not isinstance(model, str):
        raise YoyoError(f"Workflow job {job.get('id')!r} field 'model' must be a string")
    agent_args = coerce_str_list(job.get("agent_args", phase.get("agent_args", defaults.get("agent_args"))), field="agent_args")
    return argparse.Namespace(
        cwd=cwd,
        agent=agent,
        role=role,
        read_only=read_only,
        caller=cli_args.caller,
        trace_id=trace_id,
        timeout=timeout,
        max_input_bytes=max_input_bytes,
        max_output_bytes=max_output_bytes,
        model=model,
        agent_arg=agent_args,
        session=None,
        session_info=None,
        dry_run=cli_args.dry_run,
        json=cli_args.json,
        prompt=[],
        file=[],
    )


def build_workflow_prompt(
    spec: dict[str, Any],
    phase: dict[str, Any],
    agent_args: argparse.Namespace,
    job: dict[str, Any],
    results_by_phase: dict[str, list[dict[str, Any]]],
    workflow_input: str,
    context_limit: int,
) -> str:
    prompt = job.get("prompt")
    if not isinstance(prompt, str) or not prompt.strip():
        raise YoyoError(f"Workflow job {job.get('id')!r} must have a non-empty prompt")
    parts = [prompt.strip()]
    if workflow_input:
        parts.append("Workflow input:\n" + workflow_input.strip())
    previous_context = workflow_context(spec, phase, results_by_phase, job, context_limit)
    if previous_context:
        parts.append(previous_context)

    synthetic = argparse.Namespace(
        cwd=agent_args.cwd,
        role=agent_args.role,
        read_only=agent_args.read_only,
        caller=agent_args.caller,
        trace_id=agent_args.trace_id,
        prompt=["\n\n".join(parts)],
        file=coerce_str_list(job.get("files", job.get("file")), field="files"),
        skill=workflow_job_skills(spec, phase, job),
        session=None,
        session_info=None,
        max_input_bytes=agent_args.max_input_bytes,
        use_stdin_context=False,
    )
    return build_prompt(synthetic)


def workflow_allows_untrusted_context(spec: dict[str, Any], phase: dict[str, Any], job: dict[str, Any]) -> bool:
    defaults = workflow_defaults(spec)
    value = job.get(
        "allow_untrusted_context",
        phase.get("allow_untrusted_context", defaults.get("allow_untrusted_context")),
    )
    return coerce_bool(value, default=False, field="allow_untrusted_context")


def normalize_phase_gates(phase: dict[str, Any]) -> list[dict[str, Any]]:
    raw = phase.get("gates")
    if raw is None:
        return []
    if not isinstance(raw, list):
        raise YoyoError(f"Workflow phase {phase.get('name')!r} field 'gates' must be an array")
    gates: list[dict[str, Any]] = []
    for index, item in enumerate(raw):
        if isinstance(item, str):
            item = {"run": item}
        if not isinstance(item, dict) or not isinstance(item.get("run"), str) or not item["run"].strip():
            raise YoyoError(
                f"Workflow phase {phase.get('name')!r} gate {index} must be a command string or an object with 'run'"
            )
        name = item.get("name", f"gate-{index + 1}")
        if not isinstance(name, str) or not name.strip():
            raise YoyoError(f"Workflow phase {phase.get('name')!r} gate {index} has an invalid name")
        cwd = item.get("cwd")
        if cwd is not None and not isinstance(cwd, str):
            raise YoyoError(f"Workflow gate {name!r} field 'cwd' must be a string")
        timeout = item.get("timeout")
        if timeout is not None:
            coerce_float(timeout, default=1.0, field=f"gate {name!r} timeout")
        gates.append({"name": name, "run": item["run"], "cwd": cwd, "timeout": timeout})
    return gates


def run_shell_gate(name: str, run: str, cwd: Path, timeout: float, dry_run: bool) -> dict[str, Any]:
    """Run a single deterministic shell gate and return its result record.

    Shared by workflow phase gates and loop completion gates so both honor the
    same timeout, process-group cleanup, and output caps.
    """
    if dry_run:
        return {"name": name, "command": run, "cwd": str(cwd), "dry_run": True}
    started = time.monotonic()
    try:
        proc = subprocess.Popen(
            ["/bin/sh", "-c", run],
            cwd=str(cwd),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            start_new_session=os.name == "posix",
        )
    except FileNotFoundError as exc:
        raise YoyoError(f"Gate shell not found: {exc}") from exc
    pgid: int | None = None
    if os.name == "posix":
        try:
            pgid = os.getpgid(proc.pid)
        except OSError:
            pgid = None
    if pgid is not None:
        _register_child(pgid)
    try:
        try:
            stdout, stderr = proc.communicate(timeout=timeout)
            exit_code = proc.returncode
        except subprocess.TimeoutExpired:
            _terminate_child(proc, pgid)
            stdout, stderr = proc.communicate()
            exit_code = 124
            stderr = (stderr or "") + f"\ngate timed out after {timeout}s"
    finally:
        if pgid is not None:
            _unregister_child(pgid)
    return {
        "name": name,
        "command": run,
        "cwd": str(cwd),
        "exit_code": exit_code,
        "duration_s": round(time.monotonic() - started, 3),
        "stdout": stdout[-DEFAULT_GATE_OUTPUT_BYTES:],
        "stderr": stderr[-DEFAULT_GATE_OUTPUT_BYTES:],
    }


def run_phase_gates(
    gates: list[dict[str, Any]],
    cli_args: argparse.Namespace,
    spec: dict[str, Any],
    phase: dict[str, Any],
) -> tuple[list[dict[str, Any]], int]:
    """Run deterministic shell gates after a phase. The first failing gate stops the workflow."""
    defaults = workflow_defaults(spec)
    results: list[dict[str, Any]] = []
    for gate in gates:
        cwd = resolve_cwd(str(gate["cwd"] or phase.get("cwd") or defaults.get("cwd") or cli_args.cwd))
        timeout = coerce_float(gate["timeout"], default=cli_args.timeout, field="gate timeout")
        result = run_shell_gate(gate["name"], gate["run"], cwd, timeout, cli_args.dry_run)
        results.append(result)
        if not result.get("dry_run") and result.get("exit_code", 0) != 0:
            return results, result["exit_code"]
    return results, 0


def workflow_job_retries(spec: dict[str, Any], phase: dict[str, Any], job: dict[str, Any]) -> int:
    return coerce_int(
        inherited_workflow_value(spec, phase, job, "retries"),
        default=0,
        field="retries",
        minimum=0,
    )


def workflow_job_skills(spec: dict[str, Any], phase: dict[str, Any], job: dict[str, Any]) -> list[str]:
    return coerce_str_list(inherited_workflow_value(spec, phase, job, "skill"), field="skill")


def run_workflow_job(
    cli_args: argparse.Namespace,
    spec: dict[str, Any],
    phase: dict[str, Any],
    job: dict[str, Any],
    results_by_phase: dict[str, list[dict[str, Any]]],
    agents: dict[str, AgentSpec],
    workflow_input: str,
    trace_id: str,
    context_limit: int,
) -> dict[str, Any]:
    defaults = workflow_defaults(spec)
    agent = job.get("agent", phase.get("agent", defaults.get("agent", "claude")))
    if not isinstance(agent, str) or not agent:
        raise YoyoError(f"Workflow job {job.get('id')!r} has invalid agent")
    agent_args = build_workflow_agent_args(cli_args, spec, phase, job, agent, trace_id)
    uses_previous = bool(workflow_include_previous(spec, phase, job) or workflow_include_phases(spec, phase, job))
    has_raw_agent_args = bool(agent_args.agent_arg)
    if uses_previous and (not agent_args.read_only or has_raw_agent_args) and not workflow_allows_untrusted_context(spec, phase, job):
        raise YoyoError(
            f"Workflow job {job.get('id')!r} feeds previous agent output into a write-capable or raw-arg agent. "
            "Set allow_untrusted_context=true to acknowledge that risk."
        )

    prompt = build_workflow_prompt(spec, phase, agent_args, job, results_by_phase, workflow_input, context_limit)
    retries = workflow_job_retries(spec, phase, job)

    attempts = 0
    while True:
        attempts += 1
        result = execute_agent_call(agent, agent_args, prompt, agents)
        if cli_args.dry_run:
            break
        if int(result.get("exit_code", 1)) == 0:
            break
        if attempts > retries:
            break

    result.update(
        {
            "job_id": str(job.get("id") or uuid.uuid4().hex[:8]),
            "role": agent_args.role,
            "model": agent_args.model,
            "read_only": agent_args.read_only,
            "attempts": attempts,
        }
    )
    if cli_args.dry_run:
        result["prompt"] = prompt
    return result


def validate_unique_job_ids(phase_name: str, jobs: list[dict[str, Any]]) -> None:
    seen: set[str] = set()
    for index, job in enumerate(jobs):
        job_id = str(job.get("id") or f"{phase_name}-{index + 1}")
        if job_id in seen:
            raise YoyoError(f"Workflow phase {phase_name!r} has duplicate job id {job_id!r}")
        seen.add(job_id)


def list_workflow_templates(as_json: bool) -> int:
    rows = discover_workflow_templates()
    if as_json:
        print(json.dumps(rows, indent=2))
        return 0
    if not rows:
        print("no workflow templates found")
        return 0
    width = max(len(row["name"]) for row in rows)
    for row in rows:
        print(f"{row['name']:<{width}}  {row['path']}")
    return 0


def run_workflow(args: argparse.Namespace) -> int:
    if getattr(args, "list_templates", False):
        return list_workflow_templates(args.json)
    if not args.spec:
        raise YoyoError("Pass a workflow spec path or template name, or use --list")
    if args.timeout <= 0:
        raise YoyoError("--timeout must be greater than 0")
    if args.max_output_bytes < 1:
        raise YoyoError("--max-output-bytes must be at least 1")
    if args.max_input_bytes < 1:
        raise YoyoError("--max-input-bytes must be at least 1")
    spec = load_workflow_spec(args.spec)
    name = workflow_name(spec, args.spec)
    phases = workflow_phases(spec)
    agents = load_agents()
    env_context_bytes = positive_env_int("YOYO_WORKFLOW_CONTEXT_BYTES", DEFAULT_WORKFLOW_CONTEXT_BYTES)
    max_jobs = coerce_int(
        args.max_jobs if args.max_jobs is not None else spec.get("max_jobs"),
        default=DEFAULT_WORKFLOW_MAX_JOBS,
        field="max_jobs",
    )
    max_concurrency = coerce_int(
        args.max_concurrency if args.max_concurrency is not None else spec.get("max_concurrency"),
        default=DEFAULT_WORKFLOW_MAX_CONCURRENCY,
        field="max_concurrency",
    )
    context_limit = coerce_int(
        args.context_bytes if args.context_bytes is not None else spec.get("context_bytes"),
        default=env_context_bytes,
        field="context_bytes",
    )
    workflow_input = args.input or ""
    expanded_phases = [(phase, expand_workflow_jobs(phase, workflow_input)) for phase in phases]
    phase_gates: dict[str, list[dict[str, Any]]] = {}
    for phase_index, (phase, jobs) in enumerate(expanded_phases):
        phase_name = str(phase.get("name", f"phase-{phase_index + 1}"))
        validate_unique_job_ids(phase_name, jobs)
        phase_gates[phase_name] = normalize_phase_gates(phase)
        # Fail loudly on misconfigured jobs before any tokens are spent.
        for job in jobs:
            workflow_job_retries(spec, phase, job)
            if inherited_workflow_value(spec, phase, job, "expect") is not None:
                raise YoyoError(
                    f"Workflow job {job.get('id')!r} uses 'expect', which was removed in 0.15.0 "
                    "(deterministic output-grading produced false failures). State the required "
                    "output in the prompt, or use a phase gate for closed-form checks."
                )
            for skill_name in workflow_job_skills(spec, phase, job):
                skill_path = resolve_skill(skill_name)
                positive_env_int("YOYO_SKILL_MAX_BYTES", DEFAULT_SKILL_MAX_BYTES)
                try:
                    read_limited_text(skill_path, 1)
                except OSError as exc:
                    raise YoyoError(f"Skill {skill_name!r} is not readable: {exc}") from exc
    total_jobs = sum(len(jobs) for _, jobs in expanded_phases)
    if total_jobs > max_jobs:
        raise YoyoError(f"Workflow expands to {total_jobs} jobs, above max_jobs={max_jobs}")

    run_trace_id = args.trace_id or uuid.uuid4().hex
    results_by_phase: dict[str, list[dict[str, Any]]] = {}
    output: dict[str, Any] = {
        "workflow": name,
        "trace_id": run_trace_id,
        "spec": str(resolve_workflow_spec_path(args.spec)),
        "max_concurrency": max_concurrency,
        "job_count": total_jobs,
        "phases": [],
    }
    exit_code = 0

    for phase_index, (phase, jobs) in enumerate(expanded_phases):
        phase_name = str(phase.get("name", f"phase-{phase_index + 1}"))
        phase_concurrency = coerce_int(
            phase.get("max_concurrency"),
            default=max_concurrency,
            field="max_concurrency",
        )
        phase_concurrency = min(phase_concurrency, max_concurrency, len(jobs))
        eprint(f"workflow {name}: phase {phase_name} ({len(jobs)} jobs, concurrency {phase_concurrency})")

        phase_results: list[dict[str, Any]] = []
        with ThreadPoolExecutor(max_workers=phase_concurrency) as pool:
            future_to_index = {}
            for job_index, job in enumerate(jobs):
                job_id = str(job.get("id") or f"{phase_name}-{job_index + 1}")
                job["id"] = job_id
                job_trace_id = f"{run_trace_id}:{phase_name}:{job_id}"
                future = pool.submit(
                    run_workflow_job,
                    args,
                    spec,
                    phase,
                    job,
                    results_by_phase,
                    agents,
                    workflow_input,
                    job_trace_id,
                    context_limit,
                )
                future_to_index[future] = job_index
            indexed_results: dict[int, dict[str, Any]] = {}
            for future in as_completed(future_to_index):
                job_index = future_to_index[future]
                try:
                    result = future.result()
                except Exception as exc:
                    result = {
                        "job_id": str(jobs[job_index].get("id") or f"{phase_name}-{job_index + 1}"),
                        "agent": str(jobs[job_index].get("agent", workflow_defaults(spec).get("agent", "claude"))),
                        "exit_code": 2,
                        "trace_id": f"{run_trace_id}:{phase_name}:{jobs[job_index].get('id')}",
                        "stdout": "",
                        "stderr": str(exc),
                        "stderr_plain": str(exc),
                        "stdout_truncated": False,
                        "stderr_truncated": False,
                    }
                indexed_results[job_index] = result
                status = "ok" if int(result.get("exit_code", 1)) == 0 else f"exit {result.get('exit_code')}"
                eprint(f"workflow {name}: {phase_name}/{result.get('job_id')} {status}")
            for job_index in range(len(jobs)):
                phase_results.append(indexed_results[job_index])

        if exit_code == 0:
            for result in phase_results:
                if int(result.get("exit_code", 1)) != 0:
                    exit_code = int(result.get("exit_code", 1))
                    break
        results_by_phase[phase_name] = phase_results
        phase_entry: dict[str, Any] = {"name": phase_name, "jobs": phase_results}
        output["phases"].append(phase_entry)

        gates = phase_gates.get(phase_name, [])
        if gates:
            jobs_ok = all(int(result.get("exit_code", 1)) == 0 for result in phase_results)
            if jobs_ok or args.dry_run:
                gate_results, gate_exit = run_phase_gates(gates, args, spec, phase)
                phase_entry["gates"] = gate_results
                for gate_result in gate_results:
                    if "exit_code" in gate_result:
                        status = "ok" if gate_result["exit_code"] == 0 else f"exit {gate_result['exit_code']}"
                        eprint(f"workflow {name}: {phase_name}/gate {gate_result['name']} {status}")
                if gate_exit != 0:
                    if exit_code == 0:
                        exit_code = gate_exit
                    eprint(f"workflow {name}: stopping, gate failed in phase {phase_name}")
                    break
            else:
                phase_entry["gates"] = [
                    {"name": gate["name"], "command": gate["run"], "skipped": "phase jobs failed"} for gate in gates
                ]

        if args.fail_fast and any(int(result.get("exit_code", 1)) != 0 for result in phase_results):
            break

    output["exit_code"] = exit_code
    if args.json:
        print(json.dumps(slim_result_for_emission(output), ensure_ascii=False))
    else:
        print(json.dumps(slim_result_for_emission(output), indent=2, ensure_ascii=False))
    return exit_code


def chat_agent(args: argparse.Namespace) -> int:
    agents = load_agents()
    if args.agent not in agents:
        known = ", ".join(sorted(agents))
        raise YoyoError(f"Unknown agent {args.agent!r}. Known agents: {known}")
    validate_session_request(args, agents[args.agent])
    prepare_session(args, agents[args.agent], interactive=True)

    cwd = resolve_cwd(args.cwd)
    cmd = command_for_agent(agents[args.agent], args, interactive=True)
    if args.dry_run:
        print(shlex.join(cmd))
        return 0

    try:
        return subprocess.call(cmd, cwd=str(cwd))
    except FileNotFoundError as exc:
        raise YoyoError(f"Agent command not found for {args.agent}: {cmd[0]}") from exc


def slim_result_for_emission(result: dict[str, Any]) -> dict[str, Any]:
    """Caller-facing copy of a result envelope with one informative stderr.

    In memory and in the runs ledger a result keeps both the raw stderr
    capture and stderr_plain — the version worth reading (for codex, the raw
    capture is the agent's whole reasoning transcript: megabytes of noise on
    success). A printed envelope lands in the calling agent's context, so it
    carries a single stderr field, the informative one, never both.
    """
    slim = {key: value for key, value in result.items() if key != "stderr_plain"}
    if "stderr_plain" in result:
        slim["stderr"] = result["stderr_plain"]
    for key in ("results", "perspectives", "reviews", "phases", "jobs"):
        if isinstance(slim.get(key), list):
            slim[key] = [
                slim_result_for_emission(item) if isinstance(item, dict) else item for item in slim[key]
            ]
    for key in ("judge", "synthesis"):
        if isinstance(slim.get(key), dict):
            slim[key] = slim_result_for_emission(slim[key])
    return slim


def emit_result(result: dict[str, Any], as_json: bool) -> None:
    if as_json:
        print(json.dumps(slim_result_for_emission(result), ensure_ascii=False))
        return
    stdout = result.get("stdout") or ""
    if not stdout and result.get("loop_id") and result.get("end_reason"):
        # A background loop's parent result is a loop summary, not an ask envelope.
        stdout = loop_summary_line(result) + "\n"
    if not stdout and isinstance(result.get("results"), list):
        # A background fan-out's result is a fan-out envelope, not an ask
        # envelope; render it the way a foreground fan-out prints.
        blocks = []
        for item in result["results"]:
            if isinstance(item, dict) and int(item.get("exit_code", 1)) == 0 and str(item.get("stdout", "")).strip():
                blocks.append(f"=== {item.get('agent')} ===\n{str(item['stdout']).strip()}")
            elif isinstance(item, dict) and item.get("stdout_file"):
                blocks.append(f"=== {item.get('agent')} ===\n(answer spilled to {item['stdout_file']})")
        judge = result.get("judge")
        if isinstance(judge, dict) and int(judge.get("exit_code", 1)) == 0 and str(judge.get("stdout", "")).strip():
            blocks.append(f"=== judge ({judge.get('agent')}) ===\n{str(judge['stdout']).strip()}")
        if blocks:
            stdout = "\n\n".join(blocks) + "\n"
    if stdout:
        print(stdout, end="" if stdout.endswith("\n") else "\n")
    stderr = result.get("stderr_plain", result.get("stderr") or "")
    if stderr:
        eprint(stderr, end="" if stderr.endswith("\n") else "\n")
    if result.get("trace_id"):
        eprint(f"trace_id={result['trace_id']}")


def show_run(run_id: str, as_json: bool, *, exit_with_result: bool = False) -> int:
    run_dir = run_dir_for(run_id)
    meta = run_meta(run_dir)
    result = run_result(run_dir)
    status = run_status(run_dir)
    if status == "done" and result is not None:
        payload = dict(result)
        payload.update({"run_id": run_id, "status": status})
        emit_result(payload, as_json)
        if not exit_with_result:
            return 0
        try:
            return int(payload.get("exit_code", 0))
        except (TypeError, ValueError):
            return 0

    if as_json:
        print(json.dumps({"run_id": run_id, "status": status, "meta": meta}, ensure_ascii=False))
    else:
        eprint(f"run {run_id} status: {status}")
    return 3 if status == "running" else 4


def cmd_runs(args: argparse.Namespace) -> int:
    action = args.runs_action
    if action == "show":
        if not args.run_id:
            raise YoyoError("runs show requires a run_id")
        return show_run(args.run_id, args.json)
    if action == "prune":
        if args.run_id:
            raise YoyoError("runs prune does not accept a run_id")
        return prune_runs(args)
    if action != "list":
        raise YoyoError(f"Unknown runs action: {action}")
    if args.run_id:
        raise YoyoError("runs list does not accept a run_id")
    return list_runs(args)


def list_runs(args: argparse.Namespace) -> int:
    if args.limit < 1:
        raise YoyoError("--limit must be at least 1")
    root = runs_root()
    dirs = sorted([path for path in root.iterdir() if path.is_dir()], key=lambda path: path.name, reverse=True) if root.is_dir() else []
    rows = [run_summary(path) for path in dirs[:args.limit]]
    if args.json:
        print(json.dumps(rows, ensure_ascii=False))
        return 0
    if not rows:
        print("no runs found")
        return 0
    print(f"{'run_id':<24}  {'agent':<12}  {'status':<8}  {'started_at':<20}  {'duration':<9}  loop")
    for row in rows:
        duration = "" if row["duration"] is None else f"{float(row['duration']):.1f}s"
        loop_label = f"{row['loop_id']}:{row['iteration']}" if row.get("loop_id") else ""
        line = (
            f"{row['run_id']:<24}  {str(row['agent'] or ''):<12}  {row['status']:<8}  "
            f"{str(row['started_at'] or ''):<20}  {duration:<9}  {loop_label}"
        )
        print(line.rstrip())
    return 0


def prune_runs(args: argparse.Namespace) -> int:
    if args.days < 0:
        raise YoyoError("--days must be at least 0")
    cutoff = utc_now().timestamp() - (args.days * 86400)
    root = runs_root()
    selected: list[Path] = []
    if root.is_dir():
        for path in sorted([item for item in root.iterdir() if item.is_dir()], key=lambda item: item.name):
            if run_status(path) in ("running", "unknown"):
                continue
            meta = run_meta(path)
            started = run_started_at(meta, path)
            if started is not None:
                timestamp = started.timestamp()
            else:
                try:
                    timestamp = path.stat().st_mtime
                except OSError:
                    continue
            if timestamp < cutoff:
                selected.append(path)

    for path in selected:
        if args.dry_run:
            print(path.name)
        else:
            shutil.rmtree(path)
    action = "would delete" if args.dry_run else "deleted"
    print(f"{len(selected)} run dirs {action}")
    return 0


IMAGE_MAGIC: dict[str, bytes] = {
    ".png": b"\x89PNG\r\n\x1a\n",
    ".jpg": b"\xff\xd8\xff",
    ".jpeg": b"\xff\xd8\xff",
    ".webp": b"RIFF",
}
IMAGE_SIZE_RE = re.compile(r"^\d{2,4}x\d{2,4}$")
MIN_IMAGE_BYTES = 1024


# --- cron: schedule yoyo commands through the user's crontab. No daemon, no
# new runtime — the system cron fires a plain yoyo invocation and the output
# lands in a log file. Paired with `yoyo loop` (whose state file carries
# continuity and whose flock prevents overlap), a scheduled loop keeps making
# progress across runs and goes quiet once its task is verified DONE.

CRON_TAG_PREFIX = "# yoyo-cron:"
CRON_MACROS = {"@reboot", "@yearly", "@annually", "@monthly", "@weekly", "@daily", "@midnight", "@hourly"}


def cron_registry_path() -> Path:
    return state_dir() / "cron.json"


def read_cron_registry() -> dict[str, Any]:
    data = load_json_file(cron_registry_path())
    if data is None:
        return {}
    entries = data.get("entries")
    if not isinstance(entries, dict):
        raise YoyoError(f"Invalid cron registry in {cron_registry_path()}; expected an entries object")
    return entries


def write_cron_registry(entries: dict[str, Any]) -> None:
    path = cron_registry_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(path.name + ".tmp")
    tmp.write_text(json.dumps({"entries": entries}, ensure_ascii=False, indent=2), encoding="utf-8")
    tmp.replace(path)


def validate_cron_name(name: str | None) -> str:
    if not name or not SESSION_NAME_RE.match(name):
        raise YoyoError("cron entry name must be non-empty and match [A-Za-z0-9._-]+")
    return name


def validate_cron_schedule(raw: str) -> str:
    schedule = raw.strip()
    if not schedule:
        raise YoyoError("--schedule must not be empty")
    if schedule.startswith("@"):
        if schedule not in CRON_MACROS:
            raise YoyoError(f"Unknown cron macro {schedule!r}; known: {', '.join(sorted(CRON_MACROS))}")
        return schedule
    fields = schedule.split()
    if len(fields) != 5:
        raise YoyoError("--schedule must be five cron fields (min hour day month weekday) or a macro like @hourly")
    return " ".join(fields)


def crontab_read() -> list[str]:
    try:
        proc = subprocess.run(["crontab", "-l"], capture_output=True, text=True, errors="replace")
    except FileNotFoundError as exc:
        raise YoyoError("crontab command not found; yoyo cron needs cron (standard on macOS and Linux)") from exc
    if proc.returncode != 0:
        stderr = (proc.stderr or "").strip()
        if "no crontab" in stderr.lower():
            return []
        raise YoyoError(f"crontab -l failed: {stderr or proc.returncode}")
    return proc.stdout.splitlines()


def crontab_write(lines: list[str]) -> None:
    text = "\n".join(lines)
    if text and not text.endswith("\n"):
        text += "\n"
    proc = subprocess.run(["crontab", "-"], input=text, capture_output=True, text=True)
    if proc.returncode != 0:
        raise YoyoError(f"crontab update failed: {(proc.stderr or '').strip() or proc.returncode}")


def cron_line_name(line: str) -> str | None:
    """The yoyo entry name a crontab line is tagged with, or None."""
    idx = line.rfind(CRON_TAG_PREFIX)
    if idx == -1:
        return None
    return line[idx + len(CRON_TAG_PREFIX):].strip() or None


def build_cron_line(entry: dict[str, Any]) -> str:
    # PATH is captured at add time because cron's own environment is minimal
    # and the target agent CLIs (claude, codex, ...) must still resolve. The
    # trailing tag is a shell comment at execution time but survives in
    # `crontab -l`, which is how list/rm find yoyo-managed lines.
    command = (
        f"cd {shlex.quote(entry['cwd'])} && "
        f"PATH={shlex.quote(entry['path_env'])} YOYO_CALLER=cron "
        f"{shlex.quote(entry['yoyo'])} {shlex.join(entry['argv'])} "
        f">> {shlex.quote(entry['log'])} 2>&1"
    )
    # % is special inside a crontab command (line separator); escape it.
    command = command.replace("%", r"\%")
    line = f"{entry['schedule']} {command} {CRON_TAG_PREFIX}{entry['name']}"
    if "\n" in line or "\r" in line:
        raise YoyoError(
            "cron entries must be a single line; remove newlines from the scheduled command, cwd, or log path"
        )
    return line


def yoyo_subcommands() -> set[str]:
    for action in build_parser()._actions:
        if isinstance(action, argparse._SubParsersAction):
            return set(action.choices)
    return set()


def cron_add(args: argparse.Namespace) -> int:
    name = validate_cron_name(args.name)
    if not args.schedule:
        raise YoyoError("cron add requires --schedule ('0 2 * * *' or a macro like @daily)")
    schedule = validate_cron_schedule(args.schedule)
    command = list(getattr(args, "cron_command", None) or [])
    if command and command[0] == "yoyo":
        command = command[1:]
    if not command:
        raise YoyoError(
            "cron add needs the yoyo command to schedule after '--', e.g. "
            "yoyo cron add nightly --schedule '@daily' -- loop claude \"Work through TODO.md\""
        )
    if command[0] not in yoyo_subcommands():
        raise YoyoError(f"scheduled command must start with a yoyo subcommand, got {command[0]!r}")
    if command[0] == "cron":
        raise YoyoError("scheduling `yoyo cron` itself is not supported")
    entries = read_cron_registry()
    if name in entries and not args.force:
        raise YoyoError(f"cron entry {name!r} already exists; pass --force to replace it")
    log_path = Path(args.log).expanduser() if args.log else state_dir() / "cron" / f"{name}.log"
    if not log_path.is_absolute():
        log_path = resolve_cwd(args.cwd) / log_path
    log_path.parent.mkdir(parents=True, exist_ok=True)
    entry = {
        "name": name,
        "schedule": schedule,
        "cwd": str(resolve_cwd(args.cwd)),
        "argv": command,
        "log": str(log_path),
        "yoyo": str(Path(__file__).resolve()),
        "path_env": os.environ.get("PATH", ""),
        "created_at": iso_utc(utc_now()),
    }
    lines = [line for line in crontab_read() if cron_line_name(line) != name]
    lines.append(build_cron_line(entry))
    crontab_write(lines)
    entries[name] = entry
    write_cron_registry(entries)
    if args.json:
        print(json.dumps({"name": name, "schedule": schedule, "argv": command, "log": str(log_path)}, ensure_ascii=False))
    else:
        print(f"scheduled {name}: {schedule} -> yoyo {shlex.join(command)}")
        eprint(f"log: {log_path}")
        eprint(f"remove with: yoyo cron rm {name}")
    return 0


def cron_list(args: argparse.Namespace) -> int:
    entries = read_cron_registry()
    installed = {cron_line_name(line) for line in crontab_read()} - {None}
    rows = []
    for name in sorted(entries):
        entry = entries[name]
        rows.append(
            {
                "name": name,
                "schedule": entry.get("schedule"),
                "argv": entry.get("argv"),
                "cwd": entry.get("cwd"),
                "log": entry.get("log"),
                "installed": name in installed,
            }
        )
    untracked = sorted(installed - set(entries))
    if args.json:
        print(json.dumps({"entries": rows, "untracked_crontab_names": untracked}, ensure_ascii=False, indent=2))
        return 0
    if not rows:
        print("no yoyo cron entries")
    for row in rows:
        marker = "" if row["installed"] else "  [missing from crontab — re-add with --force]"
        print(f"{row['name']}  {row['schedule']}  yoyo {shlex.join(row['argv'] or [])}{marker}")
    for name in untracked:
        eprint(f"warning: crontab line tagged yoyo-cron:{name} has no registry entry; remove with: yoyo cron rm {name}")
    return 0


def cron_rm(args: argparse.Namespace) -> int:
    name = validate_cron_name(args.name)
    entries = read_cron_registry()
    lines = crontab_read()
    kept = [line for line in lines if cron_line_name(line) != name]
    removed_cron = len(kept) != len(lines)
    removed_registry = entries.pop(name, None) is not None
    if not removed_cron and not removed_registry:
        raise YoyoError(f"no cron entry named {name!r}")
    if removed_cron:
        crontab_write(kept)
    if removed_registry:
        write_cron_registry(entries)
    print(f"removed {name}")
    return 0


def cron_run(args: argparse.Namespace) -> int:
    name = validate_cron_name(args.name)
    entry = read_cron_registry().get(name)
    if entry is None:
        raise YoyoError(f"no cron entry named {name!r}; see yoyo cron list")
    argv = [str(entry["yoyo"]), *[str(part) for part in entry.get("argv", [])]]
    eprint(f"cron {name}: running yoyo {shlex.join(argv[1:])}")
    env = os.environ.copy()
    env.setdefault("YOYO_CALLER", "cron")
    try:
        proc = subprocess.run(argv, cwd=str(entry.get("cwd") or os.getcwd()), env=env)
    except FileNotFoundError as exc:
        raise YoyoError(f"recorded yoyo executable not found: {argv[0]}") from exc
    return proc.returncode


def cmd_cron(args: argparse.Namespace) -> int:
    action = args.cron_action
    if action == "add":
        return cron_add(args)
    if action == "rm":
        return cron_rm(args)
    if action == "run":
        return cron_run(args)
    return cron_list(args)


def image_fingerprint(path: Path) -> tuple[bool, int, int]:
    try:
        stat = path.stat()
    except OSError:
        return (False, 0, 0)
    return (True, stat.st_size, stat.st_mtime_ns)


def resolve_imagegen_out(args: argparse.Namespace) -> Path:
    out = Path(args.out).expanduser()
    if not out.is_absolute():
        out = resolve_cwd(args.cwd) / out
    suffix = out.suffix.lower()
    if suffix not in IMAGE_MAGIC:
        supported = ", ".join(sorted(set(IMAGE_MAGIC)))
        raise YoyoError(f"Unsupported image extension {suffix!r} for --out; use one of: {supported}")
    if not out.parent.is_dir():
        raise YoyoError(f"Output directory does not exist: {out.parent}")
    return out


def build_imagegen_prompt(args: argparse.Namespace, out: Path, edit_path: Path | None) -> str:
    parts = [
        "You are being called as an image-generation worker.",
        "Generate the requested image with your image-generation skill (for codex: the imagegen skill backed by the built-in image_gen tool).",
        "Hard constraints:",
        "- Do NOT draw or render the image with code. No PIL/Pillow, no matplotlib, no SVG, no HTML/canvas, no ASCII art. "
        "A programmatically drawn image is a failure.",
        "- If no real image-generation tool is available, create nothing, state that clearly, and exit non-zero.",
        f"- Save the single final image to exactly this path: {out}",
        "- After saving, verify the file exists at that path and report its byte size and dimensions.",
    ]
    if edit_path is not None:
        parts.append(f"Edit the existing image at {edit_path} (use your tool's edit mode with it as the reference input).")
    spec = [f"Image prompt:\n{args.prompt_text}"]
    if args.size:
        spec.append(f"Size: {args.size}.")
    if args.quality:
        spec.append(f"Quality: {args.quality}.")
    return "\n".join(parts) + "\n\n" + "\n".join(spec) + "\n"


def verify_image_output(out: Path, before: tuple[bool, int, int]) -> int:
    exists, _, _ = image_fingerprint(out)
    if not exists:
        raise YoyoError(f"Image not created: {out}")
    after = image_fingerprint(out)
    if before[0] and after == before:
        raise YoyoError(f"Image at {out} is unchanged from before the call; treating the run as failed")
    size = after[1]
    if size < MIN_IMAGE_BYTES:
        raise YoyoError(f"Image at {out} is implausibly small ({size} bytes)")
    magic = IMAGE_MAGIC[out.suffix.lower()]
    try:
        with out.open("rb") as handle:
            header = handle.read(16)
    except OSError as exc:
        raise YoyoError(f"Could not read generated image {out}: {exc}") from exc
    if not header.startswith(magic):
        raise YoyoError(f"File at {out} is not a valid {out.suffix.lower()} image (wrong magic bytes); was it drawn with code?")
    if out.suffix.lower() == ".webp" and header[8:12] != b"WEBP":
        raise YoyoError(f"File at {out} is not a valid .webp image")
    return size


def imagegen_exec_args(args: argparse.Namespace, out: Path) -> argparse.Namespace:
    return argparse.Namespace(
        cwd=str(out.parent),
        agent=args.agent,
        role=None,
        read_only=False,
        caller=args.caller,
        trace_id=args.trace_id,
        timeout=args.timeout,
        max_input_bytes=DEFAULT_MAX_INPUT_BYTES,
        max_output_bytes=args.max_output_bytes,
        model=args.model,
        agent_arg=args.agent_arg or [],
        session=None,
        session_info=None,
        dry_run=args.dry_run,
        json=args.json,
        quiet=args.quiet,
        idle_timeout=None,
        prompt=[],
        file=[],
        skill=[],
    )


def codex_image_cli_script() -> Path | None:
    """Locate codex's bundled deterministic image CLI (image_gen.py), or None."""
    codex_home = os.environ.get("CODEX_HOME")
    base = Path(codex_home).expanduser() if codex_home else Path.home() / ".codex"
    script = base / "skills" / ".system" / "imagegen" / "scripts" / "image_gen.py"
    return script if script.is_file() else None


def image_cli_output_format(out: Path) -> str:
    suffix = out.suffix.lower()
    return "jpeg" if suffix in (".jpg", ".jpeg") else suffix.lstrip(".")


def build_image_cli_command(
    args: argparse.Namespace, out: Path, edit_path: Path | None, script: Path
) -> list[str]:
    # codex's image_gen.py needs the `openai` package; `uv run --with openai` supplies
    # it in an ephemeral env without a global install. Fall back to the current
    # interpreter when uv is absent (then `openai` must already be importable).
    if shutil.which("uv"):
        runner = ["uv", "run", "--quiet", "--with", "openai", "python"]
    else:
        runner = [sys.executable]
    cmd = [*runner, str(script)]
    if edit_path is not None:
        cmd += ["edit", "--image", str(edit_path)]
    else:
        cmd += ["generate"]
    # --no-augment keeps the caller's prompt verbatim (the default prepends
    # "Primary request:"); --force writes exactly to --out instead of versioning it.
    cmd += [
        "--prompt", args.prompt_text,
        "--out", str(out),
        "--output-format", image_cli_output_format(out),
        "--no-augment",
        "--force",
    ]
    if args.size:
        cmd += ["--size", args.size]
    if args.quality:
        cmd += ["--quality", args.quality]
    if args.model:
        cmd += ["--model", args.model]
    cmd += args.agent_arg or []
    return cmd


def run_image_cli(
    args: argparse.Namespace, out: Path, edit_path: Path | None, script: Path
) -> dict[str, Any]:
    """Generate an image deterministically via codex's bundled gpt-image CLI.

    Unlike agent delegation, this is a single subprocess that writes the file
    directly to --out: no LLM reasoning loop, no copy step, and it works headless
    (the built-in image_gen tool is unavailable in `codex exec`).
    """
    cmd = build_image_cli_command(args, out, edit_path, script)
    if args.dry_run:
        spec_lines = [f"Image prompt:\n{args.prompt_text}"]
        if edit_path is not None:
            spec_lines.append(f"Edit reference: {edit_path}")
        if args.size:
            spec_lines.append(f"Size: {args.size}.")
        if args.quality:
            spec_lines.append(f"Quality: {args.quality}.")
        return {
            "agent": args.agent,
            "command": cmd,
            "prompt": "\n".join(spec_lines) + "\n",
            "trace_id": args.trace_id,
            "exit_code": 0,
        }
    cwd = resolve_cwd(args.cwd)
    started = time.monotonic()
    with tempfile.TemporaryDirectory(prefix="yoyo-img-") as tmp:
        tmpdir = Path(tmp)
        stdout_path = tmpdir / "stdout.txt"
        stderr_path = tmpdir / "stderr.txt"
        label = f"imagegen {args.trace_id}".strip()
        try:
            proc = run_to_files(
                cmd, "", cwd, stdout_path, stderr_path, args.timeout,
                idle_timeout=resolve_idle_timeout(args),
                heartbeat=resolve_heartbeat(args),
                label=label,
            )
        except FileNotFoundError as exc:
            raise YoyoError(
                f"Image CLI runner not found: {cmd[0]!r}. Install `uv` (recommended) "
                "or make the `openai` package importable by the current Python."
            ) from exc
        except subprocess.TimeoutExpired:
            return _timeout_result(
                args.agent, cmd, args, started, stdout_path, stderr_path,
                f"Timed out after {args.timeout}s",
            )
        except AgentIdleTimeout as exc:
            return _timeout_result(
                args.agent, cmd, args, started, stdout_path, stderr_path,
                f"Idle timeout after {exc.idle_seconds}s with no output "
                f"({exc.captured_bytes} bytes captured before the stall)",
            )
        stdout, stdout_truncated = read_limited_text(stdout_path, args.max_output_bytes)
        stderr, stderr_truncated = read_limited_text(stderr_path, args.max_output_bytes)
        return {
            "agent": args.agent,
            "command": cmd,
            "exit_code": proc.returncode,
            "duration_s": round(time.monotonic() - started, 3),
            "trace_id": args.trace_id,
            "stdout": stdout,
            "stderr": stderr,
            "stderr_plain": stderr,
            "stdout_truncated": stdout_truncated,
            "stderr_truncated": stderr_truncated,
        }


def cmd_imagegen(args: argparse.Namespace) -> int:
    agents = load_agents()
    if args.agent not in agents:
        known = ", ".join(sorted(agents))
        raise YoyoError(f"Unknown agent {args.agent!r}. Known agents: {known}")
    if args.timeout <= 0:
        raise YoyoError("--timeout must be greater than 0")
    if args.max_output_bytes < 1:
        raise YoyoError("--max-output-bytes must be at least 1")
    if not args.prompt_text or not args.prompt_text.strip():
        raise YoyoError("imagegen requires a non-empty image prompt")
    if args.size and not IMAGE_SIZE_RE.fullmatch(args.size):
        raise YoyoError(f"Invalid --size {args.size!r}; use WIDTHxHEIGHT, e.g. 1536x1024")

    out = resolve_imagegen_out(args)
    edit_path: Path | None = None
    if args.edit:
        edit_path = Path(args.edit).expanduser()
        if not edit_path.is_absolute():
            edit_path = resolve_cwd(args.cwd) / edit_path
        if not edit_path.is_file():
            raise YoyoError(f"Edit reference image not found: {edit_path}")

    before = image_fingerprint(out)

    # codex ships a deterministic image CLI (image_gen.py, backed by gpt-image-2)
    # that writes the file directly. Its built-in image_gen tool is NOT exposed in
    # headless `codex exec`, so delegating to a codex agent burns minutes and persists
    # nothing. Use the CLI for codex; keep agent delegation for any other --agent that
    # has its own image-generation capability.
    spec = agents[args.agent]
    script = codex_image_cli_script() if spec.flavor == "codex" else None
    if spec.flavor == "codex" and script is None:
        raise YoyoError(
            "codex image CLI not found at "
            "$CODEX_HOME/skills/.system/imagegen/scripts/image_gen.py. "
            "Reinstall codex (it ships the imagegen skill), or pass --agent <other>."
        )

    if script is not None:
        if not args.dry_run and not os.environ.get("OPENAI_API_KEY"):
            raise YoyoError(
                "OPENAI_API_KEY is not set. The codex imagegen path renders via the "
                "OpenAI Images API (billed to that account), which is separate from your "
                "codex ChatGPT-subscription login. Codex's built-in image tool can render "
                "interactively but cannot persist a file in headless `codex exec`, so yoyo "
                "needs an API key here. Export OPENAI_API_KEY, or pass --agent <other> with "
                "its own real image-generation capability."
            )
        result = run_image_cli(args, out, edit_path, script)
    else:
        prompt = build_imagegen_prompt(args, out, edit_path)
        exec_args = imagegen_exec_args(args, out)
        result = execute_agent_call(args.agent, exec_args, prompt, agents)

    if args.dry_run:
        emit_dry_run_result(result, args.json)
        return 0

    exit_code = int(result.get("exit_code", 1))
    if exit_code != 0:
        emit_result(result, args.json)
        return exit_code

    size = verify_image_output(out, before)
    if args.json:
        payload = dict(result)
        payload.update({"out": str(out), "bytes": size, "verified": True})
        print(json.dumps(payload, ensure_ascii=False))
    else:
        stdout = str(result.get("stdout", ""))
        if stdout.strip():
            print(stdout.rstrip())
        print(f"image: {out} ({size} bytes)")
        eprint(f"trace_id={result.get('trace_id')}")
    return 0


def loop_reports_cost(spec: AgentSpec) -> bool:
    return spec.flavor == "claude"


def loop_agent_args(spec: AgentSpec, base: list[str] | None) -> list[str]:
    extra = list(base or [])
    if spec.flavor == "claude" and "--output-format" not in extra:
        # The JSON envelope carries per-iteration cost/usage; the agent's text
        # lives in its "result" field and is unwrapped by extract_loop_usage.
        extra.extend(["--output-format", "json"])
    return extra


def extract_loop_usage(spec: AgentSpec, stdout: str) -> tuple[str, float | None, dict[str, Any]] | None:
    """Per-flavor usage extraction hook: (logical_stdout, cost_usd, usage) or None.

    Returns None for flavors that report nothing and for unparseable output, so
    a crashed or truncated envelope degrades to raw text with unknown cost
    instead of killing the loop.
    """
    if spec.flavor != "claude":
        return None
    try:
        data = json.loads(stdout)
    except (json.JSONDecodeError, UnicodeDecodeError):
        return None
    if not isinstance(data, dict):
        return None
    raw_text = data.get("result")
    text = raw_text if isinstance(raw_text, str) else stdout
    raw_cost = data.get("total_cost_usd")
    cost = float(raw_cost) if isinstance(raw_cost, (int, float)) and not isinstance(raw_cost, bool) else None
    usage = data.get("usage")
    return text, cost, dict(usage) if isinstance(usage, dict) else {}


def loop_task_text(args: argparse.Namespace) -> str:
    if args.input and args.prompt:
        raise YoyoError("Pass the loop task as positional text or --input, not both")
    if args.input:
        path = Path(args.input).expanduser()
        if not path.is_absolute():
            path = resolve_cwd(args.cwd) / path
        if not path.is_file():
            raise YoyoError(f"Loop task file not found: {path}")
        task, _, _ = read_input_file(path, args.max_input_bytes)
    else:
        task = " ".join(args.prompt)
    if not task.strip():
        raise YoyoError("yoyo loop requires a task; pass text or --input FILE")
    return task.strip()


def resolve_loop_state_path(args: argparse.Namespace) -> Path:
    state = Path(args.state).expanduser()
    if not state.is_absolute():
        state = resolve_cwd(args.cwd) / state
    if state.exists() and not state.is_file():
        raise YoyoError(f"Loop state path is not a file: {state}")
    return state


def loop_task_sidecar(state_path: Path) -> Path:
    return state_path.with_name(state_path.name + ".task")


def guard_loop_state_task(state_path: Path, task: str) -> None:
    """Refuse to reuse a state file recorded for a different task.

    The sidecar holds the task verbatim because the agent rewrites the state
    file itself, so the GOAL section in the state body cannot be trusted to
    stay literal. A state file without a sidecar (hand-crafted) is accepted
    and adopted when the loop seeds its metadata.
    """
    if not state_path.exists():
        return
    try:
        recorded = loop_task_sidecar(state_path).read_text(encoding="utf-8", errors="replace").strip()
    except OSError:
        return
    if recorded and recorded != task:
        raise YoyoError(
            f"State file {state_path} belongs to a different loop task ({recorded[:80]!r}). "
            "Pass --state with a new path, or delete the state file and its .task sidecar to start over."
        )


def acquire_loop_lock(state_path: Path) -> int:
    """flock an adjacent lockfile so two loops cannot interleave one state file.

    flock rather than a pid file: the kernel drops the lock when the holding
    process dies, so stale locks cannot exist and there is no reclaim step to
    race on. The lockfile itself is left in place by design — unlinking it
    would reintroduce an inode-swap race between a finishing and a starting
    loop. The pid inside is informational, for the lockout error message only.
    """
    lock_path = state_path.with_name(state_path.name + ".lock")
    fd = os.open(lock_path, os.O_CREAT | os.O_RDWR, 0o600)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        try:
            holder = lock_path.read_text(encoding="utf-8", errors="replace").strip()
        except OSError:
            holder = ""
        os.close(fd)
        suffix = f" (pid {holder})" if holder else ""
        raise YoyoError(
            f"Another loop{suffix} is already running against {state_path}; "
            "stop it or pass a different --state path"
        )
    os.ftruncate(fd, 0)
    os.write(fd, str(os.getpid()).encode("ascii"))
    return fd


def loop_state_done(state_path: Path) -> bool:
    try:
        text = state_path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return False
    # Exact-line match: the seeded GOAL embeds the task verbatim, so a task
    # that merely mentions STATUS: DONE must not stop the loop at iteration 1.
    return any(line.strip() == "STATUS: DONE" for line in text.splitlines())


def resolve_done_policy(args: argparse.Namespace) -> str:
    """Resolve and validate --done-policy against the verifiers actually supplied.

    Passing --gate or --checker while the policy is still the default 'worker'
    derives the obvious policy; a policy naming a verifier that was not supplied
    (or a verifier supplied that the policy ignores) is a loud usage error.
    Gate commands and the checker come only from these CLI flags, never from the
    agent-rewritable state file or an injected skill — the state file must not
    be a shell-command-injection surface in an unattended loop.
    """
    policy = getattr(args, "done_policy", None)
    gates = list(getattr(args, "gate", None) or [])
    checker = getattr(args, "checker", None)
    if policy is None:
        # No explicit policy: derive it from whichever verifiers were supplied.
        derived = []
        if gates:
            derived.append("gate")
        if checker:
            derived.append("checker")
        policy = "+".join(derived) if derived else "worker"
    uses_gate = "gate" in policy
    uses_checker = "checker" in policy
    if uses_gate and not gates:
        raise YoyoError("--done-policy includes 'gate' but no --gate command was given")
    if uses_checker and not checker:
        raise YoyoError("--done-policy includes 'checker' but no --checker agent was given")
    if gates and not uses_gate:
        raise YoyoError(f"--gate was given but --done-policy {policy!r} ignores gates; use --done-policy gate or gate+checker")
    if checker and not uses_checker:
        raise YoyoError(f"--checker was given but --done-policy {policy!r} ignores the checker; use --done-policy checker or gate+checker")
    return policy


def loop_verifiers_label(
    policy: str, gate_cmds: list[str], checker_name: str | None, queue_path: Path | None = None
) -> str | None:
    parts: list[str] = []
    if queue_path is not None:
        parts.append(f"the work queue ({queue_path}) having every item checked off")
    if "gate" in policy:
        parts.append("the gate command(s) " + "; ".join(f"`{cmd}`" for cmd in gate_cmds))
    if "checker" in policy:
        parts.append(f"an independent checker agent ({checker_name})")
    return " and ".join(parts) if parts else None


def resolve_loop_spec_path(args: argparse.Namespace) -> Path | None:
    if not getattr(args, "spec", None):
        return None
    path = Path(args.spec).expanduser()
    if not path.is_absolute():
        path = resolve_cwd(args.cwd) / path
    if not path.is_file():
        raise YoyoError(f"--spec file not found: {path}")
    return path


def read_loop_spec(spec_path: Path | None, max_bytes: int) -> str | None:
    """Read the standing spec fresh (so edits are picked up) under the byte cap."""
    if spec_path is None:
        return None
    text, _, _ = read_input_file(spec_path, max_bytes)
    return text.strip()


def resolve_loop_brief_path(args: argparse.Namespace) -> Path | None:
    if not getattr(args, "brief", None):
        return None
    path = Path(args.brief).expanduser()
    if not path.is_absolute():
        path = resolve_cwd(args.cwd) / path
    if not path.is_file():
        raise YoyoError(f"--brief file not found: {path}")
    return path


def read_loop_brief(brief_path: Path | None, max_bytes: int) -> str | None:
    """Read the shared brief fresh (so a caller-side regeneration is picked up).

    A transient read failure skips the block for this iteration instead of
    killing a possibly long-running loop.
    """
    if brief_path is None:
        return None
    try:
        text, _, _ = read_input_file(brief_path, max_bytes)
    except OSError as exc:
        eprint(f"warning: brief file unreadable this iteration ({exc}); omitting the brief block")
        return None
    return text.strip()


QUEUE_ITEM_RE = re.compile(r"^\s*[-*+]\s+\[([ xX])\]\s+(\S.*)$")


def parse_queue_items(text: str) -> list[tuple[bool, str]]:
    """Checklist items as (checked, text) pairs; every other line is free text.

    Fenced code blocks are skipped so example checklists in the queue's prose
    can neither block DONE forever nor count as real work.
    """
    items: list[tuple[bool, str]] = []
    in_fence = False
    for line in text.splitlines():
        stripped = line.lstrip()
        if stripped.startswith("```") or stripped.startswith("~~~"):
            in_fence = not in_fence
            continue
        if in_fence:
            continue
        match = QUEUE_ITEM_RE.match(line)
        if match:
            items.append((match.group(1).lower() == "x", match.group(2).strip()))
    return items


def unchecked_queue_or_error(queue_path: Path) -> tuple[list[str] | None, str | None]:
    """Full, uncapped queue read for DONE verification — fails closed.

    The prompt-injection read is capped by --max-input-bytes, but verification
    must see the whole file: a truncated or unreadable queue, or one the
    worker rewrote without any checklist items, must reject DONE rather than
    silently pass it.
    """
    try:
        text = queue_path.read_text(encoding="utf-8", errors="replace")
    except OSError as exc:
        return None, f"the queue file could not be read ({exc})"
    items = parse_queue_items(text)
    if not items:
        return None, "the queue file no longer contains any checklist items"
    return [item for checked, item in items if not checked], None


def resolve_loop_queue_path(args: argparse.Namespace) -> Path | None:
    if not getattr(args, "queue", None):
        return None
    path = Path(args.queue).expanduser()
    if not path.is_absolute():
        path = resolve_cwd(args.cwd) / path
    if not path.is_file():
        raise YoyoError(f"--queue file not found: {path}")
    text, _, _ = read_input_file(path, DEFAULT_MAX_INPUT_BYTES)
    if not parse_queue_items(text):
        raise YoyoError(f"--queue file has no checklist items (lines like '- [ ] task'): {path}")
    return path


def read_loop_queue(queue_path: Path | None, max_bytes: int) -> str | None:
    """Read the queue fresh each iteration — the worker checks items off in it.

    A transient read failure (worker renaming the file mid-write, non-atomic
    regeneration) skips the block for this iteration instead of killing the
    loop; DONE verification still fails closed on its own uncapped read.
    """
    if queue_path is None:
        return None
    try:
        text, _, _ = read_input_file(queue_path, max_bytes)
    except OSError as exc:
        eprint(f"warning: queue file unreadable this iteration ({exc}); omitting the queue block")
        return None
    return text.strip()


def loop_git_diff(cwd: Path) -> str:
    code, _ = git_capture(["git", "rev-parse", "--git-dir"], cwd)
    if code != 0:
        return ""
    code, diff = git_capture(["git", "diff", "HEAD"], cwd)
    return diff if code == 0 else ""


def parse_checker_verdict(text: str) -> str | None:
    """Return the last explicit VERDICT marker (PASS/FAIL) or None.

    Only the marker the checker prompt explicitly demanded is parsed — never the
    surrounding prose. This is the one blessed marker-check, not prose grading.
    """
    verdict: str | None = None
    for line in text.splitlines():
        stripped = line.strip().upper()
        if stripped.startswith("VERDICT:"):
            value = stripped.split(":", 1)[1].strip()
            if value.startswith("PASS"):
                verdict = "PASS"
            elif value.startswith("FAIL"):
                verdict = "FAIL"
    return verdict


def checker_call_args(
    args: argparse.Namespace,
    checker_name: str,
    checker_model: str | None,
    checker_spec: AgentSpec,
    prompt_text: str,
    trace_suffix: str,
) -> argparse.Namespace:
    return argparse.Namespace(
        cwd=str(resolve_cwd(args.cwd)),
        agent=checker_name,
        role="review",
        read_only=True,
        caller=args.caller,
        trace_id=f"{args.trace_id}:{trace_suffix}",
        timeout=args.timeout,
        max_input_bytes=args.max_input_bytes,
        max_output_bytes=args.max_output_bytes,
        model=checker_model,
        agent_arg=loop_agent_args(checker_spec, None),
        session=None,
        session_info=None,
        dry_run=False,
        quiet=args.quiet,
        idle_timeout=args.idle_timeout,
        prompt=[prompt_text],
        file=[],
        skill=[],
        use_stdin_context=False,
    )


def run_loop_checker(
    args: argparse.Namespace,
    checker_name: str,
    checker_model: str | None,
    agents: dict[str, AgentSpec],
    task: str,
    spec_text: str | None,
    trace_suffix: str,
) -> dict[str, Any]:
    """Independent, read-only completion check, blind to the worker's state prose."""
    cwd = resolve_cwd(args.cwd)
    diff = loop_git_diff(cwd)
    if not diff.strip():
        diff = "(no uncommitted diff; inspect the repository directly)"
    encoded = diff.encode("utf-8")
    if len(encoded) > args.max_input_bytes:
        diff = encoded[: args.max_input_bytes].decode("utf-8", errors="replace") + "\n[diff truncated by yoyo loop]"
    spec_block = ("\n" + LOOP_SPEC_BLOCK.format(spec=spec_text) + "\n") if spec_text else ""
    prompt_text = LOOP_CHECKER_PROMPT.format(cwd=cwd, task=task, spec_block=spec_block, diff=diff)
    checker_spec = agents[checker_name]
    call_args = checker_call_args(args, checker_name, checker_model, checker_spec, prompt_text, trace_suffix)
    result = execute_agent_call(checker_name, call_args, build_prompt(call_args), agents)
    text = str(result.get("stdout", ""))
    cost: float | None = None
    extracted = extract_loop_usage(checker_spec, text)
    if extracted is not None:
        text, cost, _ = extracted
    exit_code = int(result.get("exit_code", 1))
    verdict = parse_checker_verdict(text)
    # Fail closed: a checker that errors or omits the verdict must not let a
    # possibly-incomplete task exit as done.
    passed = exit_code == 0 and verdict == "PASS"
    return {"pass": passed, "verdict": verdict, "exit_code": exit_code, "cost_usd": cost, "tail": text.strip()[-800:]}


def loop_gate_records(gate_cmds: list[str], cwd: Path, timeout: float) -> tuple[list[dict[str, Any]], int]:
    results: list[dict[str, Any]] = []
    for index, run in enumerate(gate_cmds):
        result = run_shell_gate(f"gate-{index + 1}", run, cwd, timeout, dry_run=False)
        results.append(result)
        if result.get("exit_code", 0) != 0:
            return results, result["exit_code"]
    return results, 0


def format_gate_rejection(failed: dict[str, Any]) -> str:
    tail = (str(failed.get("stderr") or "") + str(failed.get("stdout") or "")).strip()[-1500:]
    return (
        "## VERIFICATION REJECTED — your STATUS: DONE was not accepted\n"
        f"The completion gate `{failed.get('command')}` failed (exit {failed.get('exit_code')}).\n"
        "Fix the underlying problem; only declare done once it passes. Last output:\n"
        f"```\n{tail}\n```"
    )


def format_queue_rejection(queue_path: Path, remaining: list[str]) -> str:
    preview = "\n".join(f"- [ ] {item}" for item in remaining[:10])
    extra = f"\n(+{len(remaining) - 10} more)" if len(remaining) > 10 else ""
    return (
        "## VERIFICATION REJECTED — your STATUS: DONE was not accepted\n"
        f"The work queue {queue_path} still has {len(remaining)} unchecked item(s):\n"
        f"{preview}{extra}\n"
        "Complete every queue item (checking each off as you go) before declaring done."
    )


def format_checker_rejection(verdict: dict[str, Any]) -> str:
    if verdict.get("verdict") is None:
        reason = f"the checker emitted no VERDICT line (treated as FAIL; checker exit {verdict.get('exit_code')})"
    else:
        reason = f"an independent checker returned VERDICT: {verdict.get('verdict')}"
    tail = str(verdict.get("tail") or "").strip()[-1500:]
    return (
        "## VERIFICATION REJECTED — your STATUS: DONE was not accepted\n"
        f"Completion check failed: {reason}.\n"
        "Address the gaps it raised before declaring done again. Checker notes:\n"
        f"```\n{tail}\n```"
    )


def reject_loop_done(state_path: Path, feedback: str) -> None:
    """Strip the worker's false STATUS: DONE and append why it was rejected."""
    try:
        text = state_path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        text = ""
    kept = [line for line in text.splitlines() if line.strip() != "STATUS: DONE"]
    body = "\n".join(kept).rstrip()
    state_path.write_text(body + "\n\n" + feedback + "\n", encoding="utf-8")


def verify_loop_done(
    args: argparse.Namespace,
    policy: str,
    gate_cmds: list[str],
    checker_name: str | None,
    checker_model: str | None,
    agents: dict[str, AgentSpec],
    task: str,
    spec_text: str | None,
    trace_suffix: str,
) -> dict[str, Any]:
    """Decide whether a worker-written STATUS: DONE is accepted.

    Gates run first (cheap, deterministic) before spending checker tokens. On
    rejection, returns the feedback to append to the state file so the next
    fresh iteration sees exactly why its claim was rejected.
    """
    cwd = resolve_cwd(args.cwd)
    info: dict[str, Any] = {"accepted": True, "feedback": None, "gate": None, "checker": None, "cost_usd": None}
    if "gate" in policy:
        results, code = loop_gate_records(gate_cmds, cwd, args.timeout)
        info["gate"] = results
        if code != 0:
            info["accepted"] = False
            info["feedback"] = format_gate_rejection(results[-1])
            return info
    if "checker" in policy:
        verdict = run_loop_checker(args, str(checker_name), checker_model, agents, task, spec_text, trace_suffix)
        info["checker"] = verdict
        info["cost_usd"] = verdict.get("cost_usd")
        if not verdict["pass"]:
            info["accepted"] = False
            info["feedback"] = format_checker_rejection(verdict)
            return info
    return info


def loop_iteration_args(
    args: argparse.Namespace,
    iteration: int,
    spec: AgentSpec,
    task: str,
    state_path: Path,
    spec_text: str | None = None,
    verifiers: str | None = None,
    agent_name: str | None = None,
    queue_path: Path | None = None,
    queue_text: str | None = None,
    brief_text: str | None = None,
) -> argparse.Namespace:
    # Stable blocks first, per-iteration content last: everything before the
    # queue block is byte-identical across iterations, so it can prefix-cache.
    parts: list[str] = []
    if spec_text:
        parts.append(LOOP_SPEC_BLOCK.format(spec=spec_text))
    if brief_text:
        parts.append(LOOP_BRIEF_BLOCK.format(brief=brief_text))
    parts.append(LOOP_PROTOCOL.format(state_path=state_path, task=task))
    if verifiers:
        parts.append(LOOP_COMPLETION_CHECK.format(verifiers=verifiers))
    if queue_path is not None and queue_text:
        parts.append(LOOP_QUEUE_BLOCK.format(queue_path=queue_path, queue=queue_text))
    parts.append(LOOP_POSITION.format(iteration=iteration, max_iter=args.max_iter))
    body = "\n\n".join(parts)
    return argparse.Namespace(
        cwd=str(resolve_cwd(args.cwd)),
        agent=agent_name or args.agent,
        role=args.role,
        read_only=args.read_only,
        caller=args.caller,
        trace_id=f"{args.trace_id}:{iteration}",
        timeout=args.timeout,
        max_input_bytes=args.max_input_bytes,
        max_output_bytes=args.max_output_bytes,
        model=args.model,
        agent_arg=loop_agent_args(spec, args.agent_arg),
        session=None,
        session_info=None,
        dry_run=args.dry_run,
        quiet=args.quiet,
        idle_timeout=args.idle_timeout,
        prompt=[body],
        file=[],
        skill=list(args.skill or []),
        use_stdin_context=False,
    )


def record_loop_iteration_run(
    args: argparse.Namespace,
    trace_id: str,
    iteration: int,
    started: datetime,
    result: dict[str, Any],
    agent_name: str | None = None,
) -> str | None:
    try:
        root = runs_root()
        root.mkdir(parents=True, exist_ok=True)
        run_id = generate_run_id()
        run_dir = root / run_id
        run_dir.mkdir(mode=0o700)
        meta = {
            "run_id": run_id,
            "agent": agent_name or args.agent,
            "role": args.role,
            "cwd": str(resolve_cwd(args.cwd)),
            "trace_id": trace_id,
            "caller": args.caller,
            "loop_id": args.trace_id,
            "iteration": iteration,
            "pid": None,
            "started_at": iso_utc(started),
        }
        (run_dir / "meta.json").write_text(json.dumps(meta, ensure_ascii=False, indent=2), encoding="utf-8")
        (run_dir / "result.json").write_text(json.dumps(result, ensure_ascii=False, indent=2), encoding="utf-8")
        return run_id
    except OSError as exc:
        eprint(f"yoyo: failed to record loop iteration {iteration} in the run ledger: {exc}")
        return None


def loop_summary_line(summary: dict[str, Any]) -> str:
    cost = summary.get("total_cost_usd")
    cost_note = ""
    if isinstance(cost, (int, float)) and not isinstance(cost, bool):
        cost_note = f", total cost ${float(cost):.2f}"
    verify_note = ""
    if summary.get("end_reason") == "done":
        verify_note = " (verified)" if summary.get("verified") else " (self-declared; no --done-policy gate)"
    gate_failures = summary.get("gate_failures") or 0
    checker_rejections = summary.get("checker_rejections") or 0
    reject_note = ""
    if gate_failures or checker_rejections:
        reject_note = f", rejected done: {gate_failures} gate / {checker_rejections} checker"
    return (
        f"loop {summary.get('loop_id')}: {summary.get('end_reason')}{verify_note} after "
        f"{summary.get('iterations')} iterations{cost_note}{reject_note}, state {summary.get('state')}"
    )


def loop_usage_fields(usage: dict[str, Any]) -> str:
    parts: list[str] = []
    for label, key in (
        ("out", "output_tokens"),
        ("cache_r", "cache_read_input_tokens"),
        ("cache_w", "cache_creation_input_tokens"),
    ):
        value = usage.get(key)
        if isinstance(value, int) and not isinstance(value, bool):
            parts.append(f"{label}={value:,}")
    return " ".join(parts)


def print_loop_iteration_line(
    as_json: bool,
    iteration: int,
    ok: bool,
    duration: float,
    cost: float | None,
    total_cost: float,
    usage: dict[str, Any],
    tail: str,
) -> None:
    stamp = datetime.now().strftime("%H:%M:%S")
    line = f"[{stamp}] iter {iteration:>3}  {'ok  ' if ok else 'FAIL'}  {duration:6.0f}s"
    if cost is not None:
        line += f"  ${cost:.2f}  (total ${total_cost:.2f})"
    fields = loop_usage_fields(usage)
    if fields:
        line += f"  {fields}"
    if tail:
        line += f"  {tail}"
    # In --json mode stdout is reserved for the final summary envelope.
    if as_json:
        eprint(line)
    else:
        print(line, flush=True)


def cmd_loop(args: argparse.Namespace) -> int:
    agents = load_agents()
    # A comma-separated agent list rotates vendors across iterations: each
    # fresh context gets a different model's eyes on the same state file, so
    # one vendor's blind spots don't compound over a long loop.
    loop_agents = [name.strip() for name in args.agent.split(",") if name.strip()]
    if not loop_agents:
        raise YoyoError("loop requires at least one agent")
    for name in loop_agents:
        if name not in agents:
            known = ", ".join(sorted(agents))
            raise YoyoError(f"Unknown agent {name!r}. Known agents: {known}")
    if getattr(args, "session", None):
        raise YoyoError(
            "loop does not support --session; every iteration is intentionally a fresh-context session "
            "(the state file is the only continuity)"
        )
    if args.max_iter < 1:
        raise YoyoError("--max-iter must be at least 1")
    if args.max_fail < 1:
        raise YoyoError("--max-fail must be at least 1")
    if args.interval < 0:
        raise YoyoError("--interval must be at least 0")
    if args.budget_usd is not None and args.budget_usd <= 0:
        raise YoyoError("--budget-usd must be greater than 0")
    if args.timeout <= 0:
        raise YoyoError("--timeout must be greater than 0")
    if args.max_output_bytes < 1:
        raise YoyoError("--max-output-bytes must be at least 1")
    if args.max_input_bytes < 1:
        raise YoyoError("--max-input-bytes must be at least 1")
    for skill_name in args.skill or []:
        resolve_skill(skill_name)

    task = loop_task_text(args)
    state_path = resolve_loop_state_path(args)
    policy = resolve_done_policy(args)
    gate_cmds = list(getattr(args, "gate", None) or [])
    for cmd in gate_cmds:
        if not cmd.strip():
            raise YoyoError("--gate command must not be empty")
    spec_path = resolve_loop_spec_path(args)
    spec_text = read_loop_spec(spec_path, args.max_input_bytes)
    queue_path = resolve_loop_queue_path(args)
    brief_path = resolve_loop_brief_path(args)
    verifiers = loop_verifiers_label(policy, gate_cmds, args.checker, queue_path)
    # Fail loudly on flag problems (e.g. --read-only on a custom agent without
    # read_only_args) before seeding state or detaching — for every rotation agent.
    for name in dict.fromkeys(loop_agents):
        rotation_spec = agents[name]
        command_for_agent(
            rotation_spec,
            loop_iteration_args(args, 1, rotation_spec, task, state_path, spec_text, verifiers, agent_name=name),
        )
    if args.checker:
        if args.checker not in agents:
            known = ", ".join(sorted(agents))
            raise YoyoError(f"Unknown checker agent {args.checker!r}. Known agents: {known}")
        # The checker always runs read-only; fail loudly now if that can't be enforced.
        command_for_agent(
            agents[args.checker],
            checker_call_args(args, args.checker, args.checker_model, agents[args.checker], "probe", "probe"),
        )
    guard_loop_state_task(state_path, task)

    if args.dry_run:
        first_agent = loop_agents[0]
        iter_args = loop_iteration_args(
            args, 1, agents[first_agent], task, state_path, spec_text, verifiers, agent_name=first_agent,
            queue_path=queue_path, queue_text=read_loop_queue(queue_path, args.max_input_bytes),
            brief_text=read_loop_brief(brief_path, args.max_input_bytes),
        )
        prompt = build_prompt(iter_args)
        result = execute_agent_call(first_agent, iter_args, prompt, agents)
        emit_dry_run_result(result, args.json)
        return 0

    if getattr(args, "background", False):
        return start_background_run(args)

    if args.budget_usd is not None:
        costless = [name for name in dict.fromkeys(loop_agents) if not loop_reports_cost(agents[name])]
        if costless:
            scope = "will not be enforced" if len(costless) == len(set(loop_agents)) else "is only partially enforced"
            eprint(
                f"warning: agent(s) {', '.join(costless)} do not report cost; --budget-usd {scope}"
            )
    if args.read_only:
        eprint(
            "warning: a read-only loop cannot rewrite its own state file; "
            "maintain it manually or the loop will never see STATUS: DONE"
        )

    state_path.parent.mkdir(parents=True, exist_ok=True)
    lock_fd = acquire_loop_lock(state_path)
    try:
        stop_path = state_path.parent / "STOP"
        if stop_path.exists():
            # STOP is a runtime kill switch for a running loop, not configuration;
            # a leftover from an earlier loop must not end this one at 0 iterations.
            stop_path.unlink()
            eprint(f"loop {args.trace_id}: removed stale STOP file {stop_path}")
        if not state_path.exists():
            state_path.write_text(LOOP_STATE_SEED.format(task=task), encoding="utf-8")
        sidecar = loop_task_sidecar(state_path)
        if not sidecar.exists():
            sidecar.write_text(task + "\n", encoding="utf-8")

        eprint(f"loop {args.trace_id}: agent={args.agent} state={state_path} max_iter={args.max_iter} (touch {stop_path} to stop)")

        total_cost = 0.0
        cost_known = False
        consecutive_failures = 0
        gate_failures = 0
        checker_rejections = 0
        queue_rejections = 0
        iterations_run = 0
        end_reason = "max-iter"
        rows: list[dict[str, Any]] = []

        def accept_done(trace_suffix: str, current_spec: str | None) -> bool:
            """A worker STATUS: DONE is a candidate; verify it under the policy.

            On rejection, strip the false DONE, append the reason to the state
            file so the next fresh iteration sees it, count it, and keep going.
            """
            nonlocal total_cost, cost_known, gate_failures, checker_rejections, queue_rejections
            if not loop_state_done(state_path):
                return False
            if queue_path is not None:
                # Cheapest check first, and it applies under every done-policy:
                # counting unchecked boxes is mechanical file inspection.
                remaining, queue_error = unchecked_queue_or_error(queue_path)
                if queue_error is not None:
                    queue_rejections += 1
                    reject_loop_done(
                        state_path,
                        "## VERIFICATION REJECTED — your STATUS: DONE was not accepted\n"
                        f"Queue verification failed closed: {queue_error}.\n"
                        f"Restore {queue_path} to a checklist that reflects the real work state.",
                    )
                    eprint(f"loop {args.trace_id}: STATUS: DONE rejected — {queue_error}; continuing")
                    return False
                if remaining:
                    queue_rejections += 1
                    reject_loop_done(state_path, format_queue_rejection(queue_path, remaining))
                    eprint(
                        f"loop {args.trace_id}: STATUS: DONE rejected — "
                        f"{len(remaining)} unchecked queue item(s) remain; continuing"
                    )
                    return False
            if policy == "worker":
                return True
            info = verify_loop_done(
                args, policy, gate_cmds, args.checker, args.checker_model, agents, task, current_spec, trace_suffix
            )
            check_cost = info.get("cost_usd")
            if isinstance(check_cost, (int, float)) and not isinstance(check_cost, bool):
                total_cost += float(check_cost)
                cost_known = True
            if info["accepted"]:
                return True
            if info.get("checker") is not None and not info["checker"].get("pass"):
                checker_rejections += 1
            else:
                gate_failures += 1
            reject_loop_done(state_path, str(info["feedback"]))
            eprint(f"loop {args.trace_id}: iteration's STATUS: DONE rejected by verification; continuing")
            return False

        for iteration in range(1, args.max_iter + 1):
            current_spec_text = read_loop_spec(spec_path, args.max_input_bytes)
            if stop_path.exists():
                end_reason = "stop"
                break
            if accept_done(f"{iteration}:precheck", current_spec_text):
                end_reason = "done"
                break

            iter_agent = loop_agents[(iteration - 1) % len(loop_agents)]
            iter_spec = agents[iter_agent]
            iter_args = loop_iteration_args(
                args, iteration, iter_spec, task, state_path, current_spec_text, verifiers, agent_name=iter_agent,
                queue_path=queue_path, queue_text=read_loop_queue(queue_path, args.max_input_bytes),
                brief_text=read_loop_brief(brief_path, args.max_input_bytes),
            )
            prompt = build_prompt(iter_args)
            started = utc_now()
            result = execute_agent_call(iter_agent, iter_args, prompt, agents)
            iterations_run = iteration

            cost: float | None = None
            usage: dict[str, Any] = {}
            extracted = extract_loop_usage(iter_spec, str(result.get("stdout", "")))
            if extracted is not None:
                text, cost, usage = extracted
                result["stdout"] = text
                if cost is not None:
                    result["cost_usd"] = cost
                    total_cost += cost
                    cost_known = True
                if usage:
                    result["usage"] = usage

            if extracted is None and args.budget_usd is not None and loop_reports_cost(iter_spec):
                eprint(
                    f"warning: iteration {iteration} output was not a parseable cost envelope; "
                    "its cost is unknown and not counted toward --budget-usd"
                )

            run_id = record_loop_iteration_run(args, iter_args.trace_id, iteration, started, result, agent_name=iter_agent)
            ok = int(result.get("exit_code", 1)) == 0
            consecutive_failures = 0 if ok else consecutive_failures + 1

            tail_lines = [line for line in str(result.get("stdout", "")).splitlines() if line.strip()]
            tail = tail_lines[-1].strip()[:120] if tail_lines else ""
            duration = float(result.get("duration_s") or 0.0)
            print_loop_iteration_line(args.json, iteration, ok, duration, cost, total_cost, usage, tail)
            rows.append(
                {
                    "iteration": iteration,
                    "run_id": run_id,
                    "exit_code": int(result.get("exit_code", 1)),
                    "duration_s": duration,
                    "cost_usd": cost,
                }
            )

            # Post-iteration checks in the brief's priority order: an iteration that
            # finishes the goal must report done even if it also crossed the budget
            # or was itself a failure. A verified done outranks a self-declared one.
            if stop_path.exists():
                end_reason = "stop"
                break
            if accept_done(f"{iteration}:check", current_spec_text):
                end_reason = "done"
                break
            if args.budget_usd is not None and cost_known and total_cost >= args.budget_usd:
                end_reason = "budget"
                break
            if consecutive_failures >= args.max_fail:
                end_reason = "max-fail"
                break
            if args.interval and iteration < args.max_iter:
                time.sleep(args.interval)
    finally:
        os.close(lock_fd)

    exit_code = 1 if end_reason == "max-fail" else 0
    summary = {
        "loop_id": args.trace_id,
        "agent": args.agent,
        "state": str(state_path),
        "iterations": iterations_run,
        "end_reason": end_reason,
        "done_policy": policy,
        # A queue rejection is mechanical, but the worker owns the queue file
        # (it can check boxes falsely) — so a queue alone never sets verified.
        "verified": end_reason == "done" and policy != "worker",
        "gate_failures": gate_failures,
        "checker_rejections": checker_rejections,
        "queue_rejections": queue_rejections,
        "queue": str(queue_path) if queue_path is not None else None,
        "total_cost_usd": round(total_cost, 4) if cost_known else None,
        "exit_code": exit_code,
        "runs": rows,
    }
    if args.json:
        print(json.dumps(summary, ensure_ascii=False))
    else:
        print(loop_summary_line(summary))
    return exit_code


REVIEW_DIFF_PROMPT = """Review scope: {scope}.

The unified diff below is the focus of this review. The repository at {cwd} is
the source of truth: read surrounding code when the diff alone is ambiguous.
Report findings ordered by severity with file/line references. If you find no
issues, say so explicitly.

<diff>
{diff}
</diff>"""


REVIEW_SYNTHESIS_PROMPT = """You are consolidating {count} independent code reviews of the same diff, each
produced by a different AI agent. Merge them into one review with two sections:

1. CONSENSUS — findings raised by two or more reviewers (name the reviewers).
2. SINGLE-REVIEWER — findings raised by exactly one reviewer; worth attention but unconfirmed.

Drop pure style nits. If reviewers contradict each other, resolve the conflict
from the diff when possible, otherwise flag the disagreement explicitly.
Order findings by severity and keep file/line references.

<diff>
{diff}
</diff>

{reviews}"""


def git_capture(cmd: list[str], cwd: Path) -> tuple[int, str]:
    try:
        proc = subprocess.run(cmd, cwd=str(cwd), capture_output=True, text=True, errors="replace")
    except FileNotFoundError as exc:
        raise YoyoError("git is required for yoyo review") from exc
    return proc.returncode, proc.stdout


def detect_review_base(cwd: Path) -> str:
    code, out = git_capture(["git", "symbolic-ref", "--short", "refs/remotes/origin/HEAD"], cwd)
    if code == 0 and out.strip():
        return out.strip()
    for candidate in ("main", "master"):
        code, _ = git_capture(["git", "rev-parse", "--verify", "--quiet", candidate], cwd)
        if code == 0:
            return candidate
    raise YoyoError("Could not detect a base branch; pass --base REF")


def collect_review_diff(cwd: Path, base: str | None) -> tuple[str, str, list[str]]:
    code, _ = git_capture(["git", "rev-parse", "--git-dir"], cwd)
    if code != 0:
        raise YoyoError(f"yoyo review requires a git repository at {cwd}")
    code, listed = git_capture(["git", "ls-files", "--others", "--exclude-standard"], cwd)
    untracked = [line for line in listed.splitlines() if line.strip()] if code == 0 else []
    code, diff = git_capture(["git", "diff", "HEAD"], cwd)
    if code == 0 and diff.strip():
        return diff, "uncommitted changes (git diff HEAD)", untracked
    resolved = base or detect_review_base(cwd)
    code, diff = git_capture(["git", "diff", f"{resolved}...HEAD"], cwd)
    if code != 0:
        raise YoyoError(f"git diff {resolved}...HEAD failed; pass a valid --base")
    if not diff.strip():
        hint = f" ({len(untracked)} untracked files exist; git add them to make them reviewable)" if untracked else ""
        raise YoyoError(f"Nothing to review: the working tree is clean and {resolved}...HEAD is empty{hint}")
    return diff, f"committed changes ({resolved}...HEAD)", untracked


def review_call_args(args: argparse.Namespace, agent_name: str, role: str | None, prompt_text: str, trace_suffix: str) -> argparse.Namespace:
    return argparse.Namespace(
        cwd=str(resolve_cwd(args.cwd)),
        agent=agent_name,
        role=role,
        read_only=True,
        caller=args.caller,
        trace_id=f"{args.trace_id}:{trace_suffix}",
        timeout=args.timeout,
        max_input_bytes=args.max_input_bytes,
        max_output_bytes=args.max_output_bytes,
        model=args.model,
        agent_arg=None,
        session=None,
        session_info=None,
        dry_run=args.dry_run,
        quiet=args.quiet,
        idle_timeout=None,
        prompt=[prompt_text],
        file=[],
        skill=[],
        use_stdin_context=False,
    )


def post_pr_comment(cwd: Path, body: str) -> None:
    try:
        proc = subprocess.run(["gh", "pr", "comment", "--body-file", "-"], cwd=str(cwd), input=body, text=True)
    except FileNotFoundError as exc:
        raise YoyoError("--pr requires the gh CLI on PATH") from exc
    if proc.returncode != 0:
        raise YoyoError(f"gh pr comment failed with exit code {proc.returncode}")


def cmd_review(args: argparse.Namespace) -> int:
    agents = load_agents()
    names = [item.strip() for item in args.agents.split(",") if item.strip()]
    if not names:
        raise YoyoError("--agents must name at least one agent")
    if len(names) != len(set(names)):
        raise YoyoError("--agents must not repeat an agent; consensus needs independent reviewers")
    synthesizer = args.synthesizer or names[0]
    for name in [*names, synthesizer]:
        if name not in agents:
            known = ", ".join(sorted(agents))
            raise YoyoError(f"Unknown agent {name!r}. Known agents: {known}")
    if args.timeout <= 0:
        raise YoyoError("--timeout must be greater than 0")
    if args.max_input_bytes < 1:
        raise YoyoError("--max-input-bytes must be at least 1")
    if args.max_output_bytes < 1:
        raise YoyoError("--max-output-bytes must be at least 1")
    # Fail loudly before spending tokens if any reviewer cannot run read-only.
    for name in {*names, synthesizer}:
        command_for_agent(agents[name], review_call_args(args, name, "review", "probe", "probe"))

    cwd = resolve_cwd(args.cwd)
    diff, scope, untracked = collect_review_diff(cwd, args.base)
    encoded = diff.encode("utf-8")
    if len(encoded) > args.max_input_bytes:
        diff = encoded[: args.max_input_bytes].decode("utf-8", errors="replace") + "\n[diff truncated by yoyo review]"
        eprint(f"warning: diff truncated to --max-input-bytes={args.max_input_bytes}")

    review_prompt = REVIEW_DIFF_PROMPT.format(scope=scope, cwd=cwd, diff=diff)
    if untracked:
        shown = untracked[:50]
        more = f"\n... and {len(untracked) - len(shown)} more" if len(untracked) > len(shown) else ""
        review_prompt += (
            "\n\nUntracked files NOT included in the diff (read them in the repo if relevant to the change):\n"
            + "\n".join(shown)
            + more
        )
        eprint(f"warning: {len(untracked)} untracked files are not in the diff; reviewers are told to read them from the repo")
    eprint(f"review {args.trace_id}: scope={scope} agents={','.join(names)} synthesizer={synthesizer}")

    def run_reviewer(name: str) -> dict[str, Any]:
        call_args = review_call_args(args, name, "review", review_prompt, name)
        return execute_agent_call(name, call_args, build_prompt(call_args), agents)

    if args.dry_run:
        for name in names:
            emit_dry_run_result(run_reviewer(name), args.json)
        return 0

    reviews: list[dict[str, Any]] = []
    with ThreadPoolExecutor(max_workers=len(names)) as pool:
        futures = {pool.submit(run_reviewer, name): index for index, name in enumerate(names)}
        indexed: dict[int, dict[str, Any]] = {}
        for future in as_completed(futures):
            index = futures[future]
            try:
                result = future.result()
            except Exception as exc:
                result = {"agent": names[index], "exit_code": 2, "stdout": "", "stderr": str(exc), "stderr_plain": str(exc)}
            indexed[index] = result
            status = "ok" if int(result.get("exit_code", 1)) == 0 else f"exit {result.get('exit_code')}"
            eprint(f"review {args.trace_id}: {names[index]} {status}")
        reviews = [indexed[index] for index in range(len(names))]

    successful = [r for r in reviews if int(r.get("exit_code", 1)) == 0 and str(r.get("stdout", "")).strip()]
    failed = [r for r in reviews if r not in successful]
    for result in failed:
        eprint(f"review {args.trace_id}: {result.get('agent')} failed: {str(result.get('stderr_plain') or result.get('stderr') or '')[:200]}")
    if not successful:
        eprint(f"review {args.trace_id}: all reviewers failed")
        return 1

    synthesis: dict[str, Any] | None = None
    if len(successful) == 1:
        final_text = str(successful[0]["stdout"]).strip()
    else:
        reviews_block = "\n\n".join(
            f'<review agent="{r["agent"]}">\n{str(r["stdout"]).strip()}\n</review>' for r in successful
        )
        synth_prompt = REVIEW_SYNTHESIS_PROMPT.format(count=len(successful), diff=diff, reviews=reviews_block)
        synth_args = review_call_args(args, synthesizer, None, synth_prompt, "synthesis")
        synthesis = execute_agent_call(synthesizer, synth_args, build_prompt(synth_args), agents)
        if int(synthesis.get("exit_code", 1)) == 0 and str(synthesis.get("stdout", "")).strip():
            final_text = str(synthesis["stdout"]).strip()
        else:
            eprint(f"review {args.trace_id}: synthesis via {synthesizer} failed; printing the raw reviews instead")
            final_text = "\n\n".join(
                f"=== review by {r['agent']} ===\n{str(r['stdout']).strip()}" for r in successful
            )

    if args.json:
        print(
            json.dumps(
                slim_result_for_emission(
                    {
                        "trace_id": args.trace_id,
                        "scope": scope,
                        "agents": names,
                        "reviews": reviews,
                        "synthesis": synthesis,
                        "review": final_text,
                        "exit_code": 0,
                    }
                ),
                ensure_ascii=False,
            )
        )
    else:
        print(final_text)

    if args.pr:
        header = f"## yoyo review ({len(successful)} agents: {', '.join(r['agent'] for r in successful)})\n\n"
        post_pr_comment(cwd, header + final_text)
        eprint(f"review {args.trace_id}: posted PR comment via gh")
    return 0


# Each lens is a distinct investigative angle. The point of research is diverse
# perspectives, not a vote — so every researcher is told to go deep from ONE
# angle and ignore the others, and the synthesis surfaces the disagreement
# rather than averaging it away.
RESEARCH_LENSES: dict[str, str] = {
    "proponent": (
        "Research lens: PROPONENT. Build the strongest evidence-based case FOR the proposition in "
        "the question and surface the biggest opportunities. What does success look like, what is "
        "the upside, and under what conditions is this clearly the right move? Do not hedge toward "
        "balance — other researchers cover the downside."
    ),
    "skeptic": (
        "Research lens: SKEPTIC. Build the strongest case AGAINST. Hunt for failure modes, hidden "
        "costs, risks, and the conditions under which this would be a mistake. Find who has tried "
        "something similar and failed, and why. Be specific and evidence-led, not merely cynical."
    ),
    "analyst": (
        "Research lens: ANALYST (first principles). Establish the load-bearing facts and "
        "fundamentals from primary sources. Separate what is actually known from what is assumed or "
        "asserted, and quantify wherever possible — show your numbers and where they came from."
    ),
    "explorer": (
        "Research lens: EXPLORER (prior art and alternatives). Map the landscape: comparable "
        "approaches, prior art, and alternatives that may not yet be on the table. For each, note "
        "what its adopters chose it for and what they traded away."
    ),
    "pragmatist": (
        "Research lens: PRAGMATIST (execution). Focus on how this would actually get done: concrete "
        "steps, effort, dependencies, cost, and the realistic path with its tradeoffs. Distinguish "
        "the cheap reversible first move from the expensive irreversible one."
    ),
}


RESEARCH_DEFAULT_LENSES = "proponent,skeptic,analyst,explorer,pragmatist"


def research_lens_preamble(name: str, freeform: bool = False) -> str:
    preset = RESEARCH_LENSES.get(name)
    if preset:
        return preset
    # Free-text lens (--lens "..."): the caller wrote the full investigative
    # angle; use it verbatim so nothing is forced through a canned template.
    if freeform:
        return f"Research lens: {name.strip()}"
    # Unknown --lenses name -> treat the string as an ad-hoc angle so callers
    # can research any domain-specific lens (e.g. --lenses "regulatory,market").
    return (
        f"Research lens: {name.upper()}. Investigate the question specifically through the lens of "
        f"{name}: what does this angle reveal that a generic answer would miss? Stay in this lens "
        f"and go deep rather than broad."
    )


def research_lens_label(name: str, index: int) -> str:
    """A short, trace-safe label for a lens (free-text lenses get a slug)."""
    slug = re.sub(r"[^A-Za-z0-9_-]+", "-", name.strip()).strip("-")[:24].rstrip("-")
    return slug or f"lens{index + 1}"


RESEARCH_BRIEF_PROMPT = """You are one of several independent researchers investigating the same
question, each assigned a DIFFERENT lens so the group surfaces genuinely diverse perspectives. Stay
in your lens — do not try to be balanced or cover every angle; the others are handled by other
researchers. Going deep from one angle is the whole point.

{lens}

Question / topic:
{topic}{context}

Investigate thoroughly with whatever sources you can reach — the repository at {cwd}, web search,
documentation, code, and primary sources. Do not invent facts: every finding must trace to evidence
you can name. This is investigation only; do not modify files.

Return concise sections:
- Key findings (each with the evidence or source that backs it)
- Strongest point from this lens
- Confidence, and what would change your view
- Open questions this lens raises"""


RESEARCH_SYNTHESIS_PROMPT = """You are synthesizing {count} independent research perspectives on the
same question, each produced by a different agent working from a different lens. The goal is to
inform a decision about what to do next — surface the diversity, do not flatten it into bland
consensus.

Question / topic:
{topic}

Write a decision brief with these sections:
1. CONVERGENCE — points that two or more perspectives independently support (name them); treat
   these as higher-confidence.
2. TENSION — where perspectives genuinely disagree or trade off. This is the most important
   section: state each side, who argued it, and what evidence would settle it.
3. KEY EVIDENCE — the most load-bearing facts and sources surfaced, with their origin. Flag
   anything asserted without support.
4. OPEN QUESTIONS — what remains unknown or unverified before a confident decision.
5. OPTIONS & NEXT STEPS — 2-4 distinct paths forward, each with its main tradeoff, plus the
   smallest next action that would most reduce the remaining uncertainty.

Attribute claims to the lens/agent that raised them. Do not invent findings no perspective raised.

{perspectives}"""


def research_call_args(args: argparse.Namespace, agent_name: str, prompt_text: str, trace_suffix: str) -> argparse.Namespace:
    return argparse.Namespace(
        cwd=str(resolve_cwd(args.cwd)),
        agent=agent_name,
        role=None,
        read_only=args.read_only,
        caller=args.caller,
        trace_id=f"{args.trace_id}:{trace_suffix}",
        timeout=args.timeout,
        max_input_bytes=args.max_input_bytes,
        max_output_bytes=args.max_output_bytes,
        model=args.model,
        agent_arg=None,
        session=None,
        session_info=None,
        dry_run=args.dry_run,
        quiet=args.quiet,
        idle_timeout=None,
        prompt=[prompt_text],
        file=[],
        skill=[],
        use_stdin_context=False,
    )


def cmd_research(args: argparse.Namespace) -> int:
    agents = load_agents()
    agent_names = [item.strip() for item in args.agents.split(",") if item.strip()]
    if not agent_names:
        raise YoyoError("--agents must name at least one agent")
    # Lenses come from --lenses (comma-separated names, canned or ad-hoc) plus
    # repeatable --lens (free text used verbatim; commas allowed). Duplicates
    # are deliberate: the same lens assigned round-robin to different agents is
    # a best-of-n sample across vendors — the point of multi-agent research.
    lens_specs = [(item.strip(), False) for item in (args.lenses or "").split(",") if item.strip()]
    lens_specs.extend((item.strip(), True) for item in (args.lens or []) if item.strip())
    if not lens_specs:
        lens_specs = [(item.strip(), False) for item in RESEARCH_DEFAULT_LENSES.split(",")]
    lenses = [lens for lens, _ in lens_specs]
    if args.no_synthesis and args.synthesizer:
        raise YoyoError("--no-synthesis and --synthesizer are mutually exclusive")
    synthesizer = args.synthesizer or agent_names[0]
    for name in [*agent_names, synthesizer]:
        if name not in agents:
            known = ", ".join(sorted(agents))
            raise YoyoError(f"Unknown agent {name!r}. Known agents: {known}")
    if args.timeout <= 0:
        raise YoyoError("--timeout must be greater than 0")
    if args.max_input_bytes < 1:
        raise YoyoError("--max-input-bytes must be at least 1")
    if args.max_output_bytes < 1:
        raise YoyoError("--max-output-bytes must be at least 1")
    topic = " ".join(args.prompt).strip()
    if not topic:
        raise YoyoError("research needs a topic or question. Pass it as positional text.")

    cwd = resolve_cwd(args.cwd)
    # Assign each lens an agent round-robin so perspectives span both lenses and
    # vendors; with the default agents the for/against split lands on different
    # vendors, which makes the disagreement more credible.
    jobs = [
        (index, lens, freeform, research_lens_label(lens, index), agent_names[index % len(agent_names)])
        for index, (lens, freeform) in enumerate(lens_specs)
    ]

    # Fail loudly before spending tokens if any agent that will actually run
    # cannot build its command (e.g. agy under --read-only has no headless
    # read-only mode). Probe only the scheduled researcher agents, plus the
    # synthesizer when synthesis will actually run — probing an unscheduled
    # pool agent would reject an otherwise-valid reduced-lens run.
    probe_targets = {name for _, _, _, _, name in jobs}
    if len(jobs) >= 2 and not args.no_synthesis:
        probe_targets.add(synthesizer)
    for name in probe_targets:
        command_for_agent(agents[name], research_call_args(args, name, "probe", "probe"))

    # Read caller context once, here, so parallel researchers never race on the
    # same input; it is embedded into each researcher's prompt text directly.
    # research defaults to full-access, so warn on --file context exactly like
    # build_prompt does for ask — file content may be untrusted.
    context = ""
    if args.file:
        if not args.read_only and not os.environ.get("YOYO_SUPPRESS_FULL_ACCESS_WARNING"):
            eprint("warning: full-access delegation includes --file context; use --read-only for untrusted input")
        context = "\n\nContext from the caller:\n" + read_file_context(args.file, cwd, args.max_input_bytes)

    def run_researcher(index: int, lens: str, freeform: bool, label: str, name: str) -> dict[str, Any]:
        prompt_text = RESEARCH_BRIEF_PROMPT.format(
            lens=research_lens_preamble(lens, freeform), topic=topic, context=context, cwd=cwd
        )
        call_args = research_call_args(args, name, prompt_text, f"{index + 1}.{label}.{name}")
        return execute_agent_call(name, call_args, build_prompt(call_args), agents)

    mode = "read-only" if args.read_only else "full-access"
    labels = [label for _, _, _, label, _ in jobs]
    synth_note = "none (caller synthesizes)" if args.no_synthesis else synthesizer
    eprint(
        f"research {args.trace_id}: lenses={','.join(labels)} agents={','.join(agent_names)} "
        f"synthesizer={synth_note} mode={mode}"
    )

    if args.dry_run:
        for index, lens, freeform, label, name in jobs:
            emit_dry_run_result(run_researcher(index, lens, freeform, label, name), args.json)
        return 0

    with ThreadPoolExecutor(max_workers=len(jobs)) as pool:
        futures = {
            pool.submit(run_researcher, index, lens, freeform, label, name): index
            for index, lens, freeform, label, name in jobs
        }
        indexed: dict[int, dict[str, Any]] = {}
        for future in as_completed(futures):
            index = futures[future]
            _, lens, _, label, name = jobs[index]
            try:
                result = future.result()
            except Exception as exc:
                result = {"agent": name, "exit_code": 2, "stdout": "", "stderr": str(exc), "stderr_plain": str(exc)}
            result["lens"] = lens
            indexed[index] = result
            status = "ok" if int(result.get("exit_code", 1)) == 0 else f"exit {result.get('exit_code')}"
            eprint(f"research {args.trace_id}: {label} via {name} {status}")
        perspectives = [indexed[index] for index in range(len(jobs))]

    successful = [p for p in perspectives if int(p.get("exit_code", 1)) == 0 and str(p.get("stdout", "")).strip()]
    failed = [p for p in perspectives if p not in successful]
    for result in failed:
        eprint(
            f"research {args.trace_id}: {result.get('lens')} via {result.get('agent')} failed: "
            f"{str(result.get('stderr_plain') or result.get('stderr') or '')[:200]}"
        )
    if not successful:
        eprint(f"research {args.trace_id}: all researchers failed")
        return 1

    synthesis: dict[str, Any] | None = None
    raw_report = "\n\n".join(
        f"=== {p['lens']} (via {p['agent']}) ===\n{str(p['stdout']).strip()}" for p in successful
    )
    if len(successful) == 1:
        final_text = str(successful[0]["stdout"]).strip()
    elif args.no_synthesis:
        # The caller keeps synthesis for itself: it usually has the decision
        # context the perspectives lack, so it is often the better judge.
        final_text = raw_report
    else:
        perspectives_block = "\n\n".join(
            f'<perspective lens="{p["lens"]}" agent="{p["agent"]}">\n{str(p["stdout"]).strip()}\n</perspective>'
            for p in successful
        )
        if args.synthesis_prompt:
            # Custom instructions are used verbatim (no .format, so braces are
            # safe); the topic and perspectives are appended after them.
            synth_prompt = (
                f"{args.synthesis_prompt.strip()}\n\nQuestion / topic:\n{topic}\n\n{perspectives_block}"
            )
        else:
            synth_prompt = RESEARCH_SYNTHESIS_PROMPT.format(
                count=len(successful), topic=topic, perspectives=perspectives_block
            )
        synth_args = research_call_args(args, synthesizer, synth_prompt, "synthesis")
        synthesis = execute_agent_call(synthesizer, synth_args, build_prompt(synth_args), agents)
        if int(synthesis.get("exit_code", 1)) == 0 and str(synthesis.get("stdout", "")).strip():
            final_text = str(synthesis["stdout"]).strip()
        else:
            eprint(f"research {args.trace_id}: synthesis via {synthesizer} failed; printing the raw perspectives instead")
            final_text = raw_report

    if args.json:
        print(
            json.dumps(
                slim_result_for_emission(
                    {
                        "trace_id": args.trace_id,
                        "topic": topic,
                        "agents": agent_names,
                        "lenses": lenses,
                        "perspectives": perspectives,
                        "synthesis": synthesis,
                        "report": final_text,
                        "exit_code": 0,
                    }
                ),
                ensure_ascii=False,
            )
        )
    else:
        print(final_text)
    return 0


def wait_run(args: argparse.Namespace) -> int:
    if args.timeout <= 0:
        raise YoyoError("--timeout must be greater than 0")
    if args.poll <= 0:
        raise YoyoError("--poll must be greater than 0")
    validate_run_id(args.run_id)
    deadline = time.monotonic() + args.timeout
    while True:
        run_dir = run_dir_for(args.run_id)
        status = run_status(run_dir)
        if status == "done":
            return show_run(args.run_id, args.json, exit_with_result=True)
        if status in ("dead", "unknown"):
            if args.json:
                meta = run_meta(run_dir)
                print(json.dumps({"run_id": args.run_id, "status": status, "meta": meta}, ensure_ascii=False))
            else:
                eprint(f"run {args.run_id} status: {status}")
            return 4
        now = time.monotonic()
        if now >= deadline:
            if args.json:
                print(json.dumps({"run_id": args.run_id, "status": "timeout"}, ensure_ascii=False))
            else:
                eprint(f"timed out waiting for run {args.run_id}")
            return 124
        time.sleep(min(args.poll, max(0.0, deadline - now)))


def session_rows() -> list[dict[str, Any]]:
    registry = read_session_registry()
    rows: list[dict[str, Any]] = []
    for key, record in registry["sessions"].items():
        if not isinstance(record, dict):
            continue
        row = dict(record)
        row["key"] = key
        rows.append(row)
    return sorted(rows, key=lambda row: (str(row.get("agent", "")), str(row.get("name", ""))))


def list_sessions(args: argparse.Namespace) -> int:
    rows = session_rows()
    if args.json:
        print(json.dumps(rows, ensure_ascii=False))
        return 0
    if not rows:
        print("no sessions found")
        return 0
    print(f"{'name':<24}  {'agent':<12}  {'backend_id':<36}  {'created_at':<20}  last_used")
    for row in rows:
        print(
            f"{str(row.get('name') or ''):<24}  {str(row.get('agent') or ''):<12}  "
            f"{str(row.get('backend_id') or ''):<36}  {str(row.get('created_at') or ''):<20}  "
            f"{str(row.get('last_used') or '')}"
        )
    return 0


def remove_session(args: argparse.Namespace) -> int:
    if args.all and args.sessions_target:
        raise YoyoError("sessions rm accepts either a key or --all, not both")
    registry = read_session_registry()
    if args.all:
        registry["sessions"] = {}
        write_session_registry(registry)
        return 0
    if not args.sessions_target:
        raise YoyoError("sessions rm requires <agent>:<name> or --all")
    key = args.sessions_target
    if key not in registry["sessions"]:
        raise YoyoError(f"Unknown session: {key}")
    del registry["sessions"][key]
    write_session_registry(registry)
    return 0


def cmd_sessions(args: argparse.Namespace) -> int:
    action = args.sessions_action
    if action == "list":
        if args.sessions_target:
            raise YoyoError("sessions list does not accept a session key")
        if args.all:
            raise YoyoError("sessions list does not accept --all")
        return list_sessions(args)
    if action == "rm":
        if args.json:
            raise YoyoError("sessions rm does not accept --json")
        return remove_session(args)
    raise YoyoError(f"Unknown sessions action: {action}")


def list_agents(args: argparse.Namespace) -> int:
    agents = load_agents()
    rows = []
    for name, spec in sorted(agents.items()):
        rows.append({"name": name, "command": spec.command, "found": bool(shutil.which(spec.command[0]))})
    if args.json:
        print(json.dumps(rows, indent=2))
        return 0
    width = max([len(row["name"]) for row in rows] + [5])
    for row in rows:
        status = "ok" if row["found"] else "missing"
        print(f"{row['name']:<{width}}  {status:7}  {shlex.join(row['command'])}")
    return 0


def list_skills(args: argparse.Namespace) -> int:
    rows = discover_skills()
    if args.json:
        print(json.dumps(rows, indent=2))
        return 0
    if not rows:
        print("no skills found; set YOYO_SKILL_PATH or install skills under ~/.claude/skills etc.")
        return 0
    width = max(len(row["name"]) for row in rows)
    for row in rows:
        print(f"{row['name']:<{width}}  {row['path']}")
    return 0


def doctor(args: argparse.Namespace) -> int:
    if getattr(args, "live", False):
        return doctor_live(args)
    if args.agent or args.json or args.timeout is not None:
        raise YoyoError("--agent, --json, and --timeout require doctor --live")

    agents = load_agents()
    failed = 0
    for name, spec in sorted(agents.items()):
        found = shutil.which(spec.command[0])
        if not found:
            failed += 1
            print(f"{name}: missing ({spec.command[0]})")
            continue
        print(f"{name}: ok ({found})")
    path = config_path()
    print(f"config: {path} ({'present' if path.exists() else 'not present'})")
    source_path = source_record_path()
    if os.environ.get("YOYO_SOURCE_ROOT") or source_path.exists():
        try:
            source = read_recorded_source()
            print(f"source: {source} (present)")
        except YoyoError as exc:
            failed += 1
            print(f"source: invalid ({exc})")
    else:
        print(f"source: {source_path} (not recorded)")
    return 1 if failed and args.strict else 0


def doctor_agent_names(agents: dict[str, AgentSpec], requested: list[str] | None) -> list[str]:
    if not requested:
        return sorted(agents)

    names: list[str] = []
    seen: set[str] = set()
    for name in requested:
        if name not in agents:
            known = ", ".join(sorted(agents))
            raise YoyoError(f"Unknown agent {name!r}. Known agents: {known}")
        if name not in seen:
            seen.add(name)
            names.append(name)
    return names


def doctor_supports_read_only(spec: AgentSpec) -> bool:
    # agy is intentionally absent: it has no headless read-only mode, so its
    # read-only probe is skipped and reported as unsupported.
    return spec.flavor in ("codex", "claude", "pi", "cursor", "grok") or bool(spec.read_only_args)


def doctor_probe_args(agent: str, cwd: Path, timeout: float, read_only: bool) -> argparse.Namespace:
    mode = "read-only" if read_only else "full-access"
    return argparse.Namespace(
        cwd=str(cwd),
        agent=agent,
        read_only=read_only,
        timeout=timeout,
        max_output_bytes=DEFAULT_GATE_OUTPUT_BYTES,
        model=None,
        agent_arg=[],
        session=None,
        session_info=None,
        dry_run=False,
        json=False,
        trace_id=f"doctor-{agent}-{mode}",
        quiet=True,
        idle_timeout=None,
    )


def doctor_missing_result(name: str, command: str) -> dict[str, Any]:
    return {
        "agent": name,
        "mode": "missing",
        "status": "missing",
        "ok": False,
        "exit_code": None,
        "duration_s": 0.0,
        "stderr_snippet": "",
        "command": command,
    }


def doctor_skipped_result(name: str) -> dict[str, Any]:
    return {
        "agent": name,
        "mode": "skipped",
        "status": "skipped",
        "ok": False,
        "exit_code": None,
        "duration_s": 0.0,
        "stderr_snippet": "",
        "reason": "no read_only_args",
    }


def doctor_run_probe(
    name: str,
    mode: str,
    timeout: float,
    agents: dict[str, AgentSpec],
) -> dict[str, Any]:
    read_only = mode == "read-only"
    with tempfile.TemporaryDirectory(prefix="yoyo-doctor-") as tmp:
        probe_args = doctor_probe_args(name, Path(tmp), timeout, read_only)
        result = execute_agent_call(name, probe_args, "Reply with exactly: OK", agents)

    stdout = str(result.get("stdout", ""))
    ok = int(result["exit_code"]) == 0 and bool(stdout)
    stderr = str(result.get("stderr", ""))
    return {
        "agent": name,
        "mode": mode,
        "status": "ok" if ok else "failed",
        "ok": ok,
        "exit_code": int(result["exit_code"]),
        "duration_s": result["duration_s"],
        "stderr_snippet": "" if ok else stderr[-500:],
    }


def doctor_probe_agent(name: str, spec: AgentSpec, timeout: float, agents: dict[str, AgentSpec]) -> list[dict[str, Any]]:
    rows: list[dict[str, Any]] = []
    if doctor_supports_read_only(spec):
        rows.append(doctor_run_probe(name, "read-only", timeout, agents))
    else:
        rows.append(doctor_skipped_result(name))
    rows.append(doctor_run_probe(name, "full-access", timeout, agents))
    return rows


def doctor_format_duration(value: float) -> str:
    return f"{value:.1f}s"


def doctor_print_live_report(rows: list[dict[str, Any]]) -> None:
    for row in rows:
        status = row["status"]
        if status == "missing":
            print(f"{row['agent']}: missing ({row['command']})")
        elif status == "skipped":
            print(f"{row['agent']}: read-only skipped: {row['reason']}")
        elif status == "ok":
            print(f"{row['agent']}: {row['mode']} ok ({doctor_format_duration(float(row['duration_s']))})")
        else:
            line = (
                f"{row['agent']}: {row['mode']} FAIL exit {row['exit_code']} "
                f"({doctor_format_duration(float(row['duration_s']))})"
            )
            if row["stderr_snippet"]:
                line += f": {row['stderr_snippet']}"
            print(line)


def doctor_live(args: argparse.Namespace) -> int:
    timeout = 120.0 if args.timeout is None else args.timeout
    if timeout <= 0:
        raise YoyoError("--timeout must be greater than 0")
    args.timeout = timeout

    agents = load_agents()
    names = doctor_agent_names(agents, args.agent)
    by_agent: dict[str, list[dict[str, Any]]] = {}
    probe_names: list[str] = []
    for name in names:
        spec = agents[name]
        if not shutil.which(spec.command[0]):
            by_agent[name] = [doctor_missing_result(name, spec.command[0])]
        else:
            probe_names.append(name)

    if probe_names:
        max_workers = min(4, len(probe_names))
        with ThreadPoolExecutor(max_workers=max_workers) as pool:
            futures = {
                pool.submit(doctor_probe_agent, name, agents[name], args.timeout, agents): name
                for name in probe_names
            }
            for future in as_completed(futures):
                by_agent[futures[future]] = future.result()

    rows = [row for name in names for row in by_agent[name]]
    if args.json:
        print(json.dumps(rows, indent=2))
    else:
        doctor_print_live_report(rows)

    failed = any(row["status"] in ("failed", "missing") for row in rows)
    return 1 if failed and args.strict else 0


def install_skill(args: argparse.Namespace) -> int:
    source_env = os.environ.get("YOYO_SKILL_SOURCE")
    if source_env:
        source = Path(source_env).expanduser()
    else:
        source = Path(__file__).resolve().parents[1] / "skills"
    if not source.exists():
        raise YoyoError(f"Bundled skill not found: {source}")

    if (source / "SKILL.md").exists():
        skill_sources = [source]
    else:
        skill_sources = [child for child in source.iterdir() if child.is_dir() and (child / "SKILL.md").exists()]
    if not skill_sources:
        raise YoyoError(f"No bundled skills found under: {source}")

    # Some bundled skills only make sense when the agent that powers them is
    # actually installed.
    skill_requirements = {"yoyo-imagegen": "codex"}
    kept: list[Path] = []
    for skill_source in skill_sources:
        required = skill_requirements.get(skill_source.name)
        if required and not shutil.which(required):
            print(f"skipped skill: {skill_source.name} (requires {required} on PATH)")
            continue
        kept.append(skill_source)
    skill_sources = kept

    target_roots = [
        Path("~/.codex/skills").expanduser(),
        Path("~/.claude/skills").expanduser(),
        Path("~/.agents/skills").expanduser(),
        Path("~/.config/opencode/skills").expanduser(),
        Path(os.environ.get("PI_CODING_AGENT_DIR", "~/.pi/agent")).expanduser() / "skills",
    ]
    for skill_source in skill_sources:
        for target_root in target_roots:
            target = target_root / skill_source.name
            target.parent.mkdir(parents=True, exist_ok=True)
            if target.exists():
                shutil.rmtree(target)
            shutil.copytree(skill_source, target, dirs_exist_ok=True)
            print(f"installed skill: {target}")
    return 0


def run_checked(cmd: list[str], cwd: Path, *, env: dict[str, str] | None = None, dry_run: bool = False) -> None:
    if dry_run:
        print(shlex.join(cmd))
        return
    try:
        subprocess.check_call(cmd, cwd=str(cwd), env=env)
    except FileNotFoundError as exc:
        raise YoyoError(f"Command not found: {cmd[0]}") from exc
    except subprocess.CalledProcessError as exc:
        raise YoyoError(f"Command failed with exit code {exc.returncode}: {shlex.join(cmd)}") from exc


def git_current_branch(source: Path) -> str:
    proc = subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        cwd=str(source),
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if proc.returncode != 0:
        raise YoyoError(f"Could not determine git branch in {source}: {proc.stderr.strip()}")
    branch = proc.stdout.strip()
    if not branch or branch == "HEAD":
        return "main"
    return branch


def update_yoyo(args: argparse.Namespace) -> int:
    source = read_recorded_source()
    if not args.no_pull:
        if not (source / ".git").exists():
            raise YoyoError(f"Recorded yoyo source checkout is not a git repo: {source}")
        branch = args.branch or ("<current-branch>" if args.dry_run else git_current_branch(source))
        run_checked(["git", "fetch", "origin", branch], source, dry_run=args.dry_run)
        run_checked(["git", "pull", "--ff-only", "origin", branch], source, dry_run=args.dry_run)

    env = os.environ.copy()
    if args.prefix:
        env["PREFIX"] = args.prefix
    run_checked(["/bin/sh", str(source / "install.sh")], source, env=env, dry_run=args.dry_run)
    if not args.dry_run:
        print(f"updated yoyo from {source}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="yoyo", description="Tiny cross-agent delegation CLI")
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    sub = parser.add_subparsers(dest="command", required=True)

    ask = sub.add_parser("ask", help="Call another agent non-interactively; a comma-separated list fans the same prompt out in parallel")
    ask.add_argument(
        "agent",
        help="Agent name (codex, claude, pi, or a configured custom agent), or a comma-separated list to fan the same prompt out to several agents in parallel",
    )
    ask.add_argument("prompt", nargs="*", help="Prompt text. Also accepts piped stdin.")
    ask.add_argument(
        "--judge",
        help="With a fan-out (comma-separated agents): an agent that compares the independent answers and recommends the best one",
    )
    ask.add_argument(
        "--judge-prompt",
        help="Custom judging instructions for --judge (the task and candidate answers are appended)",
    )
    ask.add_argument(
        "--judge-only",
        action="store_true",
        help="With --judge: return only the judge's verdict; raw candidate answers are spilled to files under the state dir and referenced by path (a failed judge still falls back to the raw answers)",
    )
    ask.add_argument("--role", choices=sorted(ROLE_PROMPTS), default=None, help="Role preamble (default: opinion; incompatible with --raw)")
    ask.add_argument(
        "--raw",
        action="store_true",
        help="Send the prompt text verbatim with no role/context wrapper, so the target CLI sees a leading /command and can expand it",
    )
    ask.add_argument("--caller", default=os.environ.get("YOYO_CALLER", "unknown"))
    ask.add_argument("--cwd", default=os.getcwd())
    ask.add_argument("--file", action="append", default=[], help="Add a file as explicit context")
    ask.add_argument("--skill", action="append", default=[], help="Inject a named skill (SKILL.md) as guidance for the target agent; repeatable")
    ask.add_argument("--timeout", type=float, default=float(os.environ.get("YOYO_TIMEOUT", str(DEFAULT_TIMEOUT_SECONDS))))
    ask.add_argument("--trace-id", default=os.environ.get("YOYO_TRACE_ID") or uuid.uuid4().hex)
    ask.add_argument("--max-input-bytes", type=int, default=int(os.environ.get("YOYO_MAX_INPUT_BYTES", str(DEFAULT_MAX_INPUT_BYTES))))
    ask.add_argument("--max-output-bytes", type=int, default=int(os.environ.get("YOYO_MAX_OUTPUT_BYTES", str(DEFAULT_MAX_OUTPUT_BYTES))))
    ask.add_argument("--idle-timeout", type=float, default=None, help="Kill the agent if it emits no output for this many seconds (hang guard)")
    ask.add_argument("--quiet", action="store_true", help="Suppress the periodic progress heartbeat on stderr")
    ask.add_argument("--stdin-wait", type=float, default=None, help="Seconds to wait for piped stdin before giving up (default 0: read only if already available)")
    ask.add_argument("--no-stdin", action="store_true", help="Never read stdin as context, even when piped")
    ask.add_argument("--model", help="Pass a model name to agents that support --model")
    ask.add_argument("--read-only", action="store_true", help="Constrain the target agent to read-only mode where supported")
    ask.add_argument("--write", action="store_false", dest="read_only", help=argparse.SUPPRESS)
    ask.add_argument("--agent-arg", action="append", help="Append a raw argument to the target agent command")
    ask.add_argument("--session", help="Use or create a named durable backend session")
    ask.add_argument("--json", action="store_true", help="Emit a JSON result envelope")
    ask.add_argument("--dry-run", action="store_true", help="Print command and rendered prompt without running")
    ask.add_argument("--background", action="store_true", help="Detach the ask run and record it in the run ledger")
    ask.set_defaults(func=run_agent, collect_unknown_prompt=True)

    chat = sub.add_parser("chat", help="Open an interactive session with another agent")
    chat.add_argument("agent", help="Agent name: codex, claude, pi, or configured custom agent")
    chat.add_argument("prompt", nargs="*", help="Optional initial prompt")
    chat.add_argument("--cwd", default=os.getcwd())
    chat.add_argument("--model", help="Pass a model name to agents that support --model")
    chat.add_argument("--read-only", action="store_true", help="Constrain the target agent to read-only mode where supported")
    chat.add_argument("--agent-arg", action="append", help="Append a raw argument to the target agent command")
    chat.add_argument("--session", help="Use or create a named durable backend session")
    chat.add_argument("--dry-run", action="store_true", help="Print command without launching the agent")
    chat.set_defaults(func=chat_agent, collect_unknown_prompt=True)

    workflow = sub.add_parser("workflow", help="Run a multi-agent workflow from a JSON spec or template name")
    workflow.add_argument("spec", nargs="?", help="Path to a workflow JSON spec, or a template name (see --list)")
    workflow.add_argument("--list", action="store_true", dest="list_templates", help="List available workflow templates")
    workflow.add_argument("--input", help="Optional workflow input text passed to jobs")
    workflow.add_argument("--cwd", default=os.getcwd())
    workflow.add_argument("--caller", default=os.environ.get("YOYO_CALLER", "unknown"))
    workflow.add_argument("--trace-id", default=os.environ.get("YOYO_TRACE_ID"))
    workflow.add_argument("--timeout", type=float, default=float(os.environ.get("YOYO_TIMEOUT", str(DEFAULT_TIMEOUT_SECONDS))))
    workflow.add_argument("--max-input-bytes", type=int, default=int(os.environ.get("YOYO_MAX_INPUT_BYTES", str(DEFAULT_MAX_INPUT_BYTES))))
    workflow.add_argument("--max-output-bytes", type=int, default=int(os.environ.get("YOYO_MAX_OUTPUT_BYTES", str(DEFAULT_MAX_OUTPUT_BYTES))))
