    imagegen = sub.add_parser("imagegen", help="Generate an image via an agent's native image-generation skill")
    imagegen.add_argument("prompt_text", help="Image prompt (quote it)")
    imagegen.add_argument("--out", required=True, help="Output image path (.png, .jpg, .jpeg, or .webp)")
    imagegen.add_argument("--agent", default="codex", help="Agent to delegate to (default: codex, which has the native image_gen tool)")
    imagegen.add_argument("--size", help="Image size as WIDTHxHEIGHT, e.g. 1536x1024")
    imagegen.add_argument("--quality", choices=["low", "medium", "high", "auto"], help="Generation quality hint")
    imagegen.add_argument("--edit", help="Existing image to edit instead of generating from scratch")
    imagegen.add_argument("--cwd", default=os.getcwd())
    imagegen.add_argument("--caller", default=os.environ.get("YOYO_CALLER", "unknown"))
    imagegen.add_argument("--trace-id", default=os.environ.get("YOYO_TRACE_ID") or uuid.uuid4().hex)
    imagegen.add_argument("--timeout", type=float, default=float(os.environ.get("YOYO_TIMEOUT", str(DEFAULT_TIMEOUT_SECONDS))))
